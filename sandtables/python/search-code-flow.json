{
  "id": "python.search-code-flow",
  "language": "python",
  "title": "Python semantic search source-text and tests pipe flow",
  "coverage": [
    "language-registry",
    "json-schema",
    "search-flow",
    "deps-query",
    "performance",
    "real-trigger"
  ],
  "tags": [
    "query-composition",
    "python-layout",
    "real-trigger"
  ],
  "workdir": {
    "relative": "languages/python-lang-project-harness"
  },
  "budgets": {
    "maxCommands": 10,
    "maxTotalLinesWarn": 120,
    "maxTotalStdoutBytesWarn": 75000
  },
  "steps": [
    {
      "id": "registry-json-schema",
      "kind": "schema-contract",
      "coverage": [
        "language-registry",
        "json-schema"
      ],
      "command": [
        "py-harness",
        "agent",
        "doctor",
        "--json",
        "."
      ],
      "expect": {
        "stdoutJsonSchema": "schemas/semantic-language-registry.v1.schema.json",
        "stdoutJsonEquals": {
          "registryId": "agent.semantic-protocols.semantic-language-registry",
          "languages.0.languageId": "python",
          "languages.0.providerId": "py-harness",
          "languages.0.binary": "py-harness"
        },
        "stdoutJsonArrayContains": {
          "languages.0.schemas": {
            "schemaId": "agent.semantic-protocols.semantic-graph",
            "path": "schemas/semantic-graph.v1.schema.json"
          }
        },
        "maxStdoutLinesWarn": 12,
        "maxStdoutBytesWarn": 19000,
        "maxElapsedMsWarn": 1500
      }
    },
    {
      "id": "prime-json-schema",
      "kind": "schema-contract",
      "coverage": [
        "json-schema",
        "search-flow",
        "performance"
      ],
      "command": [
        "py-harness",
        "search",
        "prime",
        "--json",
        "--workspace",
        "."
      ],
      "expect": {
        "stdoutJsonSchema": "schemas/semantic-search-packet.v1.schema.json",
        "stdoutJsonEquals": {
          "schemaId": "agent.semantic-protocols.semantic-search-packet",
          "languageId": "python",
          "providerId": "py-harness",
          "method": "search/prime",
          "searchSynthesis.algorithm": "owner-rank-frontier",
          "searchSynthesis.scope": "prime"
        },
        "maxStdoutLinesWarn": 12,
        "maxStdoutBytesWarn": 22000,
        "maxElapsedMsWarn": 4000
      }
    },
    {
      "id": "dependency-json-schema",
      "kind": "schema-contract",
      "coverage": [
        "json-schema",
        "deps-query",
        "performance"
      ],
      "command": [
        "py-harness",
        "search",
        "dependency",
        "ruff",
        "--json",
        "--workspace",
        "."
      ],
      "expect": {
        "stdoutJsonSchema": "schemas/semantic-search-packet.v1.schema.json",
        "stdoutJsonEquals": {
          "schemaId": "agent.semantic-protocols.semantic-search-packet",
          "languageId": "python",
          "providerId": "py-harness",
          "method": "search/dependency",
          "query": "ruff"
        },
        "maxStdoutLinesWarn": 12,
        "maxStdoutBytesWarn": 3200,
        "maxElapsedMsWarn": 2500
      }
    },
    {
      "id": "workspace",
      "command": [
        "py-harness",
        "search",
        "workspace",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-workspace]"
        ],
        "maxStdoutLinesWarn": 8,
        "maxElapsedMsWarn": 4500
      }
    },
    {
      "id": "prime",
      "command": [
        "py-harness",
        "search",
        "prime",
        "--view",
        "seeds",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-prime]",
          "alg=fast-prime-frontier-v1",
          "legend: ID=kind:role(value)!next; entries profile(selectors=>returns); frontier ID.next",
          "G>{",
          "rank=",
          "frontier=",
          "entries=owner-tests(O=>covering-tests+test-entrypoints+fixtures)",
          "omit=items,blocks,code,full-json reason=fast-seeds-frontier"
        ],
        "maxStdoutLinesWarn": 18,
        "maxElapsedMsWarn": 3000,
        "stdoutNotContains": [
          "|seed",
          "|synthesis",
          "G=search:result!query"
        ]
      }
    },
    {
      "id": "text-owner-tests-pipe",
      "command": [
        "py-harness",
        "search",
        "fzf",
        "--query-set",
        "PythonSemanticSearchOptions",
        "--query-set",
        "render_python_semantic_search_packet",
        "owner",
        "tests",
        "--owner",
        "src/python_lang_project_harness/__init__.py",
        "--workspace",
        "."
      ],
      "capture": {
        "pyOwner": "\\|owner ([^\\s]+)"
      },
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-fzf]",
          "querySet=2",
          "selector=fuzzy-set",
          "scopeOwner=src/python_lang_project_harness/__init__.py",
          "pipes=owner,tests",
          "source=parser-visible-source",
          "tests:src/python_lang_project_harness/__init__.py"
        ],
        "maxStdoutLinesWarn": 24,
        "maxStdoutBytesWarn": 12000,
        "maxElapsedMsWarn": 3500
      }
    },
    {
      "id": "layout-query-set-synthesis",
      "command": [
        "py-harness",
        "search",
        "fzf",
        "--query-set",
        "metadata",
        "--query-set",
        "package-roots",
        "--query-set",
        "package_paths",
        "--query-set",
        "_src_layout_findings",
        "--query-set",
        "scope.source_paths",
        "--query-set",
        "package_roots",
        "--query-set",
        "root / \"src\"",
        "--query-set",
        "return True",
        "--query-set",
        "return False",
        "--query-set",
        "relative_to",
        "--query-set",
        "ValueError",
        "owner",
        "tests",
        "--view",
        "seeds",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-fzf]",
          "querySet=11",
          "owner:path(src/python_lang_project_harness/_project_policy_layout.py)",
          "legend: ID=kind:role(value)!next; edge SRC>{DST:rel}; frontier ID.next",
          "G>{",
          "rank=",
          "frontier="
        ],
        "maxStdoutLinesWarn": 38,
        "maxStdoutBytesWarn": 20000,
        "maxElapsedMsWarn": 7000,
        "stdoutNotContains": [
          "|seed",
          "|synthesis",
          "G=search:result!query"
        ]
      }
    },
    {
      "id": "layout-query-set-json-schema",
      "kind": "schema-contract",
      "coverage": [
        "json-schema",
        "search-flow",
        "real-trigger"
      ],
      "command": [
        "py-harness",
        "search",
        "fzf",
        "--query-set",
        "_src_layout_findings",
        "--query-set",
        "scope.source_paths",
        "owner",
        "tests",
        "--json",
        "--workspace",
        "."
      ],
      "expect": {
        "stdoutJsonSchema": "schemas/semantic-search-packet.v1.schema.json",
        "stdoutJsonEquals": {
          "schemaId": "agent.semantic-protocols.semantic-search-packet",
          "method": "search/fzf",
          "querySet.0.value": "_src_layout_findings",
          "querySet.1.value": "scope.source_paths",
          "queryCoverage.0.value": "_src_layout_findings",
          "searchSynthesis.seeds.0.target": "src/python_lang_project_harness/_project_policy_layout.py"
        },
        "maxStdoutLinesWarn": 12,
        "maxStdoutBytesWarn": 20000,
        "maxElapsedMsWarn": 7000
      }
    },
    {
      "id": "owner-from-pipe",
      "command": [
        "py-harness",
        "search",
        "owner",
        "{pyOwner}",
        "--view",
        "seeds",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-owner]",
          "legend: ID=kind:role(value)!next; edge SRC>{DST:rel}; frontier ID.next",
          "G>{",
          "rank=",
          "frontier="
        ],
        "maxStdoutLinesWarn": 12,
        "maxElapsedMsWarn": 2500,
        "stdoutNotContains": [
          "|seed",
          "|synthesis",
          "G=search:result!query"
        ]
      }
    },
    {
      "id": "rg-to-ingest",
      "stdinCommand": [
        "rg",
        "-n",
        "PythonSemanticSearchOptions|parser-visible-source|search ingest",
        "src",
        "tests",
        "README.md"
      ],
      "stdinCommandAllowNonZero": true,
      "command": [
        "py-harness",
        "search",
        "ingest",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-ingest]"
        ],
        "maxStdoutLinesWarn": 18,
        "maxElapsedMsWarn": 2500
      }
    }
  ]
}
