{
  "id": "python.fastapi-intent-matrix",
  "language": "python",
  "title": "FastAPI large-library feature/API/principle intent matrix",
  "coverage": [
    "search-flow",
    "performance",
    "large-library"
  ],
  "tags": [
    "large-library",
    "fastapi",
    "intent-matrix"
  ],
  "evidence": {
    "source": "handwritten",
    "fixtureTier": "large-library",
    "targetLibrary": {
      "language": "python",
      "name": "FastAPI",
      "package": "fastapi",
      "repository": "fastapi/fastapi",
      "workdirKind": "checkout"
    },
    "intentCases": [
      {
        "intentKind": "feature-implementation",
        "intent": "Implement lifespan or startup behavior after locating compact owners and tests",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "lifespan"
        ]
      },
      {
        "intentKind": "api-usage",
        "intent": "Find APIRouter API usage and callsites",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "APIRouter"
        ]
      },
      {
        "intentKind": "implementation-principle",
        "intent": "Understand dependency solving implementation paths from parser-owned facts",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "solve_dependencies"
        ]
      }
    ]
  },
  "workdir": {
    "env": "SANDTABLE_PY_FASTAPI_ROOT",
    "candidates": [
      "~/ghq/github.com/fastapi/fastapi",
      "~/src/fastapi",
      "~/work/fastapi"
    ]
  },
  "budgets": {
    "maxCommands": 4,
    "maxTotalLinesWarn": 42,
    "maxTotalStdoutBytesWarn": 20000
  },
  "steps": [
    {
      "id": "prime",
      "command": [
        "py-harness",
        "search",
        "prime",
        "--view",
        "seeds",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-prime]",
          "root=fastapi",
          "alg=fast-prime-frontier-v1",
          "entries=owner-tests(O=>covering-tests+test-entrypoints+fixtures)",
          "omit=items,blocks,code,full-json reason=fast-seeds-frontier"
        ],
        "maxStdoutLinesWarn": 9,
        "maxElapsedMs": 300,
        "maxElapsedMsWarn": 250
      }
    },
    {
      "id": "owner-routing",
      "command": [
        "py-harness",
        "search",
        "owner",
        "fastapi/routing.py",
        "--view",
        "seeds",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-owner]",
          "fastapi/routing.py",
          "entries=owner-tests(O=>covering-tests+test-entrypoints+fixtures)"
        ],
        "maxStdoutLinesWarn": 14,
        "maxElapsedMs": 300,
        "maxElapsedMsWarn": 250
      }
    },
    {
      "id": "deps-pydantic",
      "command": [
        "py-harness",
        "search",
        "deps",
        "pydantic",
        "--view",
        "seeds",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-dependency]",
          "pydantic",
          "frontier="
        ],
        "maxStdoutLinesWarn": 16,
        "maxElapsedMs": 300,
        "maxElapsedMsWarn": 250
      }
    },
    {
      "id": "intent-query-set",
      "command": [
        "py-harness",
        "search",
        "fzf",
        "--query-set",
        "lifespan",
        "--query-set",
        "APIRouter",
        "--query-set",
        "solve_dependencies",
        "owner",
        "tests",
        "--view",
        "seeds",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-fzf]",
          "querySet=3",
          "fastapi/dependencies/utils.py",
          "fastapi/routing.py",
          "entries=owner-query(O,Q=>items+tests+dependency-usage),owner-tests(O=>covering-tests+test-entrypoints+fixtures)"
        ],
        "maxStdoutLinesWarn": 14,
        "maxElapsedMs": 300,
        "maxElapsedMsWarn": 250
      }
    }
  ]
}
