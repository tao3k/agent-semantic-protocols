#!/usr/bin/env python3
"""Fake Claude Code CLI used by sandtable agentCli scenarios."""

from __future__ import annotations

import json
import os
import sys


def main() -> int:
    args = sys.argv[1:]
    prompt = _option(args, "-p", "")
    output_format = _option(args, "--output-format", "text")
    input_format = _option(args, "--input-format", None)
    payload = {
        "agent": "fake-claude-code",
        "prompt": prompt,
        "outputFormat": output_format,
        "inputFormat": input_format,
        "includePartialMessages": "--include-partial-messages" in args,
        "includeHookEvents": "--include-hook-events" in args,
        "verbose": "--verbose" in args,
        "model": _option(args, "--model", None),
        "baseUrl": os.environ.get("ANTHROPIC_BASE_URL"),
        "hasAuthToken": bool(os.environ.get("ANTHROPIC_AUTH_TOKEN")),
    }

    if output_format == "stream-json":
        print(json.dumps({"type": "system", "subtype": "init", "agent": payload["agent"]}))
        print(json.dumps({"type": "result", "subtype": "success", **payload}))
        return 0
    if output_format == "json":
        print(json.dumps(payload))
        return 0
    print(f"[fake-claude] prompt={prompt} outputFormat={output_format}")
    return 0


def _option(args: list[str], name: str, default: str | None) -> str | None:
    try:
        index = args.index(name)
    except ValueError:
        return default
    value_index = index + 1
    if value_index >= len(args):
        return default
    return args[value_index]


if __name__ == "__main__":
    raise SystemExit(main())
