{
  "id": "root.custom-subagent-install-flow",
  "language": "root",
  "coverage": [
    "codex-hooks",
    "cli-hooks",
    "real-trigger"
  ],
  "workdir": ".",
  "steps": [
    {
      "id": "hook-install-writes-custom-subagents",
      "command": [
        "python",
        "sandtables/root/fixtures/custom_subagent_install.py"
