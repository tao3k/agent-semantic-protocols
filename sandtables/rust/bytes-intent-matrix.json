{
  "id": "rust.bytes-intent-matrix",
  "language": "rust",
  "title": "bytes large-library feature/API/principle intent matrix",
  "coverage": [
    "search-flow",
    "performance",
    "large-library"
  ],
  "tags": [
    "large-library",
    "bytes",
    "intent-matrix"
  ],
  "evidence": {
    "source": "handwritten",
    "fixtureTier": "large-library",
    "targetLibrary": {
      "language": "rust",
      "name": "bytes",
      "package": "bytes",
      "repository": "tokio-rs/bytes",
      "workdirKind": "registry"
    },
    "intentCases": [
      {
        "intentKind": "feature-implementation",
        "intent": "Implement a BytesMut capacity or reserve behavior change from compact owner seeds",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "reserve"
        ]
      },
      {
        "intentKind": "api-usage",
        "intent": "Find how BytesMut is exposed and used",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "BytesMut"
        ]
      },
      {
        "intentKind": "implementation-principle",
        "intent": "Understand BufMut implementation principles without reading the whole crate",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "BufMut"
        ]
      }
    ],
    "deepQuestionCases": [
      {
        "id": "bytes-bytesmut-reserve-growth",
        "question": "BytesMut reserve/capacity 增长策略的关键 owner 在哪里？为什么不能只看 public API 文档下结论？",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "BytesMut",
          "reserve",
          "capacity"
        ],
        "audit": {
          "maxAspCommands": 7,
          "maxSearchCommands": 4,
          "maxQueryCommands": 3,
          "maxRepeatedCommands": 0,
          "requiresGraphSignals": true,
          "requiresQuerySet": true,
          "requiresHookEvents": true
        }
      },
      {
        "id": "bytes-bufmut-unsafely-advance",
        "question": "BufMut 的 advance_mut/unsafe 写入边界如何被组织？先找 trait 和实现 owner。",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "BufMut",
          "advance_mut",
          "unsafe"
        ],
        "audit": {
          "maxAspCommands": 7,
          "maxSearchCommands": 4,
          "maxQueryCommands": 3,
          "maxRepeatedCommands": 0,
          "requiresGraphSignals": true,
          "requiresQuerySet": true,
          "requiresHookEvents": true
        }
      },
      {
        "id": "bytes-split-freeze-sharing",
        "question": "BytesMut split/freeze 之后共享底层存储的语义是什么？需要定位实现路径和测试入口。",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "split",
          "freeze",
          "shared"
        ],
        "audit": {
          "maxAspCommands": 7,
          "maxSearchCommands": 4,
          "maxQueryCommands": 3,
          "maxRepeatedCommands": 0,
          "requiresGraphSignals": true,
          "requiresQuerySet": true,
          "requiresHookEvents": true
        }
      }
    ]
  },
  "workdir": {
    "env": "SANDTABLE_RUST_BYTES_ROOT",
    "candidates": [
      "~/.cargo/registry/src/*/bytes-[0-9]*"
    ]
  },
  "budgets": {
    "maxCommands": 2,
    "maxTotalLinesWarn": 24,
    "maxTotalStdoutBytesWarn": 16000
  },
  "steps": [
    {
      "id": "prime",
      "command": [
        "rs-harness",
        "search",
        "prime",
        "--view",
        "seeds",
        "--seeds",
        "4",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-prime]",
          "analysis=structure",
          "nativeSyntaxFacts=skipped",
          "policyFindings=skipped",
          "entries=",
          "legend: ID=kind:role(value)!next; entries profile(selectors=>returns); frontier ID.next",
          "G>{",
          "rank=",
          "frontier="
        ],
        "maxStdoutLinesWarn": 10,
        "maxElapsedMsWarn": 2500,
        "stdoutNotContains": [
          "|seed",
          "|synthesis",
          "G=search:result!query"
        ]
      }
    },
    {
      "id": "intent-query-set",
      "command": [
        "rs-harness",
        "search",
        "fzf",
        "--query-set",
        "reserve",
        "--query-set",
        "BytesMut",
        "--query-set",
        "BufMut",
        "--view",
        "seeds",
        "--seeds",
        "4",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-fzf]",
          "querySet=3",
          "legend: ID=kind:role(value)!next; edge SRC>{DST:rel}; frontier ID.next",
          "G>{",
          "rank=",
          "frontier=",
          "entries=owner-query(O,Q=>items+tests+dependency-usage),owner-tests(O=>covering-tests+test-entrypoints+fixtures)"
        ],
        "maxStdoutLinesWarn": 10,
        "maxElapsedMsWarn": 2500,
        "stdoutNotContains": [
          "|seed",
          "|synthesis",
          "G=search:result!query"
        ]
      }
    }
  ]
}
