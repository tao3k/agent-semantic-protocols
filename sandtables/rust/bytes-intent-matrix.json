{
  "id": "rust.bytes-intent-matrix",
  "language": "rust",
  "title": "bytes large-library feature/API/principle intent matrix",
  "coverage": [
    "search-flow",
    "performance",
    "large-library"
  ],
  "tags": [
    "large-library",
    "bytes",
    "intent-matrix"
  ],
  "evidence": {
    "source": "handwritten",
    "fixtureTier": "large-library",
    "targetLibrary": {
      "language": "rust",
      "name": "bytes",
      "package": "bytes",
      "repository": "tokio-rs/bytes",
      "workdirKind": "registry"
    },
    "intentCases": [
      {
        "intentKind": "feature-implementation",
        "intent": "Implement a BytesMut capacity or reserve behavior change from compact owner seeds",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "reserve"
        ]
      },
      {
        "intentKind": "api-usage",
        "intent": "Find how BytesMut is exposed and used",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "BytesMut"
        ]
      },
      {
        "intentKind": "implementation-principle",
        "intent": "Understand BufMut implementation principles without reading the whole crate",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "BufMut"
        ]
      }
    ]
  },
  "workdir": {
    "env": "SANDTABLE_RUST_BYTES_ROOT",
    "candidates": [
      "~/.cargo/registry/src/*/bytes-[0-9]*"
    ]
  },
  "budgets": {
    "maxCommands": 2,
    "maxTotalLinesWarn": 24,
    "maxTotalStdoutBytesWarn": 16000
  },
  "steps": [
    {
      "id": "prime",
      "command": [
        "rs-harness",
        "search",
        "prime",
        "--view",
        "seeds",
        "--seeds",
        "4",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-prime]",
          "legend: ID=kind:role(value)!next; edge SRC>{DST:rel}; frontier ID.next",
          "alias: graph:{G=search",
          "G>{",
          "rank=",
          "frontier="
        ],
        "maxStdoutLinesWarn": 10,
        "maxElapsedMsWarn": 2500,
        "stdoutNotContains": [
          "|seed",
          "|synthesis",
          "G=search:result!query"
        ]
      }
    },
    {
      "id": "intent-query-set",
      "command": [
        "rs-harness",
        "search",
        "fzf",
        "--query-set",
        "reserve",
        "--query-set",
        "BytesMut",
        "--query-set",
        "BufMut",
        "--view",
        "seeds",
        "--seeds",
        "4",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-fzf]",
          "querySet=3",
          "legend: ID=kind:role(value)!next; edge SRC>{DST:rel}; frontier ID.next",
          "alias: graph:{G=search",
          "G>{",
          "rank=",
          "frontier=",
          "entries=owner-query(O,Q=>items+tests+dependency-usage),owner-tests(O=>covering-tests+test-entrypoints+fixtures)"
        ],
        "maxStdoutLinesWarn": 10,
        "maxElapsedMsWarn": 2500,
        "stdoutNotContains": [
          "|seed",
          "|synthesis",
          "G=search:result!query"
        ]
      }
    }
  ]
}
