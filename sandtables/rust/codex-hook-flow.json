{
  "id": "rust.codex-hook-flow",
  "language": "rust",
  "title": "Codex hook replay for Rust source-read and search-flow gates",
  "coverage": [
    "codex-hooks",
    "cli-hooks",
    "policy-blackbox",
    "security"
  ],
  "workdir": {
    "env": "SANDTABLE_RUST_HOOK_ROOT",
    "candidates": [
      "../rust-lang-project-harness"
    ]
  },
  "budgets": {
    "maxCommands": 5,
    "maxTotalLinesWarn": 40
  },
  "steps": [
    {
      "id": "direct-read-deny",
      "command": [
        "semantic-agent-hook",
        "hook",
        "--client",
        "codex",
        "pre-tool",
        "--emit",
        "decision"
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"Read\",\"tool_input\":{\"path\":\"src/lib.rs\"}}",
      "expect": {
        "stdoutJsonEquals": {
          "decision": "deny",
          "reasonKind": "direct-source-read"
        },
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 700
      }
    },
    {
      "id": "command-execution-read-deny",
      "command": [
        "semantic-agent-hook",
        "hook",
        "--client",
        "codex",
        "pre-tool",
        "--emit",
        "decision"
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"command_execution\",\"tool_input\":{\"command\":\"/bin/zsh -lc \\\"sed -n '1,8p' src/lib.rs\\\"\"}}",
      "expect": {
        "stdoutJsonEquals": {
          "decision": "deny",
          "reasonKind": "bulk-source-dump"
        },
        "stdoutJsonContains": {
          "message": "rs-harness agent guide ."
        },
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 700
      }
    },
    {
      "id": "raw-rg-deny",
      "command": [
        "semantic-agent-hook",
        "hook",
        "--client",
        "codex",
        "pre-tool",
        "--emit",
        "decision"
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"functions.exec_command\",\"tool_input\":{\"cmd\":\"rg -n \\\"fn run_agent\\\" src tests\"}}",
      "expect": {
        "stdoutJsonEquals": {
          "decision": "deny",
          "reasonKind": "raw-broad-search"
        },
        "stdoutJsonContains": {
          "message": "rs-harness agent guide ."
        },
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 700
      }
    },
    {
      "id": "ingest-pipe-allow",
      "command": [
        "semantic-agent-hook",
        "hook",
        "--client",
        "codex",
        "pre-tool",
        "--emit",
        "decision"
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"Bash\",\"tool_input\":{\"command\":\"rg -n \\\"fn run_agent\\\" --glob '*.rs' src tests | rs-harness search ingest items tests --view seeds --seeds 8 .\"}}",
      "expect": {
        "stdoutJsonEquals": {
          "decision": "allow",
          "reasonKind": "none"
        },
        "maxElapsedMsWarn": 700
      }
    },
    {
      "id": "subagent-receipt-required",
      "command": [
        "semantic-agent-hook",
        "hook",
        "--client",
        "codex",
        "subagent-stop",
        "--emit",
        "decision"
      ],
      "stdin": "{\"hook_event_name\":\"SubagentStop\",\"turn_id\":\"sandtable\",\"last_assistant_message\":\"done\"}",
      "expect": {
        "stdoutJsonEquals": {
          "decision": "block",
          "reasonKind": "subagent-receipt-required"
        },
        "stdoutJsonContains": {
          "message": "[search-subagent]"
        },
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 700
      }
    }
  ]
}
