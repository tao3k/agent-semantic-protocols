{
  "id": "rust.codex-desktop-hook-smoke",
  "language": "rust",
  "title": "Codex Desktop tool payloads route raw Rust reads through rs-harness policy",
  "coverage": [
    "desktop-hooks",
    "codex-hooks",
    "codex-wrapper",
    "policy-blackbox",
    "security",
    "performance"
  ],
  "workdir": {
    "relative": "sandtables/fixtures/codex-desktop-hook-smoke"
  },
  "budgets": {
    "maxCommands": 8,
    "maxTotalLinesWarn": 40
  },
  "steps": [
    {
      "id": "exec-command-rtk-read",
      "command": [
        "semantic-agent-hook",
        "hook",
        "--client",
        "codex",
        "pre-tool"
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"functions.exec_command\",\"tool_input\":{\"cmd\":\"rtk read src/lib.rs\"}}",
      "expect": {
        "stdoutJsonEquals": {
          "hookSpecificOutput.permissionDecision": "deny"
        },
        "stdoutContains": [
          "\"permissionDecisionReason\":\"direct-source-read denied",
          "\\\"paths\\\":[\\\"src/lib.rs\\\"]",
          "\\\"providerId\\\":\\\"rs-harness\\\""
        ],
        "stdoutNotContains": [
          "codex-desktop-smoke-fixture"
        ],
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 1000
      }
    },
    {
      "id": "exec-command-rtk-rg",
      "command": [
        "semantic-agent-hook",
        "hook",
        "--client",
        "codex",
        "pre-tool"
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"functions.exec_command\",\"tool_input\":{\"cmd\":\"rtk rg -n smoke src tests\"}}",
      "expect": {
        "stdoutJsonEquals": {
          "hookSpecificOutput.permissionDecision": "deny"
        },
        "stdoutContains": [
          "\"permissionDecisionReason\":\"raw-broad-search denied",
          "\\\"reasonKind\\\":\\\"raw-broad-search\\\"",
          "\\\"kind\\\":\\\"query\\\""
        ],
        "stdoutNotContains": [
          "codex-desktop-smoke-fixture"
        ],
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 500
      }
    },
    {
      "id": "parallel-nested-exec-command",
      "command": [
        "semantic-agent-hook",
        "hook",
        "--client",
        "codex",
        "pre-tool"
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"multi_tool_use.parallel\",\"tool_input\":{\"tool_uses\":[{\"recipient_name\":\"functions.exec_command\",\"parameters\":{\"cmd\":\"rtk read src/lib.rs\"}}]}}",
      "expect": {
        "stdoutJsonEquals": {
          "hookSpecificOutput.permissionDecision": "deny"
        },
        "stdoutContains": [
          "\"permissionDecisionReason\":\"direct-source-read denied",
          "\\\"paths\\\":[\\\"src/lib.rs\\\"]"
        ],
        "stdoutNotContains": [
          "codex-desktop-smoke-fixture"
        ],
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 500
      }
    },
    {
      "id": "shell-read",
      "command": [
        "semantic-agent-hook",
        "hook",
        "--client",
        "codex",
        "pre-tool"
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"functions.exec_command\",\"tool_input\":{\"cmd\":\"sed -n '1,40p' src/lib.rs\"}}",
      "expect": {
        "stdoutJsonEquals": {
          "hookSpecificOutput.permissionDecision": "deny"
        },
        "stdoutContains": [
          "\"permissionDecisionReason\":\"bulk-source-dump denied",
          "\\\"paths\\\":[\\\"src/lib.rs:1:40\\\"]"
        ],
        "stdoutNotContains": [
          "codex-desktop-smoke-fixture"
        ],
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 500
      }
    },
    {
      "id": "guard-rtk-read",
      "command": [
        "semantic-agent-hook",
        "hook",
        "--client",
        "codex",
        "pre-tool",
        "--emit",
        "decision"
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"functions.exec_command\",\"tool_input\":{\"cmd\":\"rtk read src/lib.rs\"}}",
      "expect": {
        "stdoutJsonEquals": {
          "decision": "deny",
          "reasonKind": "direct-source-read",
          "subject.paths.0": "src/lib.rs"
        },
        "stdoutNotContains": [
          "codex-desktop-smoke-fixture"
        ],
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 500
      }
    },
    {
      "id": "guard-rtk-rg",
      "command": [
        "semantic-agent-hook",
        "hook",
        "--client",
        "codex",
        "pre-tool",
        "--emit",
        "decision"
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"functions.exec_command\",\"tool_input\":{\"cmd\":\"rtk rg -n smoke src tests\"}}",
      "expect": {
        "stdoutJsonEquals": {
          "decision": "deny",
          "reasonKind": "raw-broad-search",
          "routes.0.kind": "query"
        },
        "stdoutNotContains": [
          "codex-desktop-smoke-fixture"
        ],
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 500
      }
    },
    {
      "id": "guard-shell-read",
      "command": [
        "semantic-agent-hook",
        "hook",
        "--client",
        "codex",
        "pre-tool",
        "--emit",
        "decision"
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"functions.exec_command\",\"tool_input\":{\"cmd\":\"sed -n '1,40p' src/lib.rs\"}}",
      "expect": {
        "stdoutJsonEquals": {
          "decision": "deny",
          "reasonKind": "bulk-source-dump",
          "subject.paths.0": "src/lib.rs:1:40"
        },
        "stdoutNotContains": [
          "codex-desktop-smoke-fixture"
        ],
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 500
      }
    },
    {
      "id": "guard-exact-file-search",
      "command": [
        "semantic-agent-hook",
        "hook",
        "--client",
        "codex",
        "pre-tool",
        "--emit",
        "decision"
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"functions.exec_command\",\"tool_input\":{\"cmd\":\"rg -n smoke src/lib.rs\"}}",
      "expect": {
        "stdoutJsonEquals": {
          "decision": "deny",
          "reasonKind": "raw-broad-search",
          "routes.0.kind": "query"
        },
        "maxElapsedMsWarn": 500
      }
    }
  ]
}
