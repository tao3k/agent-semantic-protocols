{
  "id": "rust.codex-desktop-hook-smoke",
  "language": "rust",
  "title": "Codex Desktop tool payloads route raw Rust reads through rs-harness policy",
  "coverage": [
    "desktop-hooks",
    "codex-hooks",
    "codex-wrapper",
    "policy-blackbox",
    "security",
    "performance"
  ],
  "workdir": {
    "relative": "sandtables/fixtures/codex-desktop-hook-smoke"
  },
  "budgets": {
    "maxCommands": 11,
    "maxTotalLinesWarn": 40
  },
  "steps": [
    {
      "id": "exec-command-rtk-read",
      "command": [
        "rs-harness",
        "agent",
        "hook",
        "--client",
        "codex",
        "pre-tool",
        "."
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"functions.exec_command\",\"tool_input\":{\"cmd\":\"rtk read src/lib.rs\"}}",
      "expect": {
        "stdoutContains": [
          "\"permissionDecision\":\"deny\"",
          "\"reasonKind\":\"direct-source-read\"",
          "\"paths\":[\"src/lib.rs\"]",
          "rs-harness"
        ],
        "stdoutNotContains": [
          "codex-desktop-smoke-fixture"
        ],
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 1000
      }
    },
    {
      "id": "exec-command-rtk-rg",
      "command": [
        "rs-harness",
        "agent",
        "hook",
        "--client",
        "codex",
        "pre-tool",
        "."
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"functions.exec_command\",\"tool_input\":{\"cmd\":\"rtk rg -n smoke src tests\"}}",
      "expect": {
        "stdoutContains": [
          "\"permissionDecision\":\"deny\"",
          "\"reasonKind\":\"raw-broad-search\"",
          "\"kind\":\"ingest\"",
          "\"stdinMode\":\"pipe-candidates\""
        ],
        "stdoutNotContains": [
          "codex-desktop-smoke-fixture"
        ],
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 500
      }
    },
    {
      "id": "parallel-nested-exec-command",
      "command": [
        "rs-harness",
        "agent",
        "hook",
        "--client",
        "codex",
        "pre-tool",
        "."
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"multi_tool_use.parallel\",\"tool_input\":{\"tool_uses\":[{\"recipient_name\":\"functions.exec_command\",\"parameters\":{\"cmd\":\"rtk read src/lib.rs\"}}]}}",
      "expect": {
        "stdoutContains": [
          "\"permissionDecision\":\"deny\"",
          "\"reasonKind\":\"direct-source-read\"",
          "\"paths\":[\"src/lib.rs\"]"
        ],
        "stdoutNotContains": [
          "codex-desktop-smoke-fixture"
        ],
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 500
      }
    },
    {
      "id": "shell-read",
      "command": [
        "rs-harness",
        "agent",
        "hook",
        "--client",
        "codex",
        "pre-tool",
        "."
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"functions.exec_command\",\"tool_input\":{\"cmd\":\"sed -n '1,40p' src/lib.rs\"}}",
      "expect": {
        "stdoutContains": [
          "\"permissionDecision\":\"deny\"",
          "\"reasonKind\":\"direct-source-read\"",
          "\"paths\":[\"src/lib.rs\"]"
        ],
        "stdoutNotContains": [
          "codex-desktop-smoke-fixture"
        ],
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 500
      }
    },
    {
      "id": "guard-rtk-read",
      "command": [
        "rs-harness",
        "agent",
        "guard",
        "--client",
        "codex",
        "--json",
        ".",
        "--",
        "rtk",
        "read",
        "src/lib.rs"
      ],
      "expect": {
        "exitCode": 1,
        "stdoutContains": [
          "\"permissionDecision\":\"deny\"",
          "\"reasonKind\":\"direct-source-read\"",
          "\"paths\":[\"src/lib.rs\"]"
        ],
        "stdoutNotContains": [
          "codex-desktop-smoke-fixture"
        ],
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 500
      }
    },
    {
      "id": "guard-rtk-rg",
      "command": [
        "rs-harness",
        "agent",
        "guard",
        "--client",
        "codex",
        "--json",
        ".",
        "--",
        "rtk",
        "rg",
        "-n",
        "smoke",
        "src",
        "tests"
      ],
      "expect": {
        "exitCode": 1,
        "stdoutContains": [
          "\"permissionDecision\":\"deny\"",
          "\"reasonKind\":\"raw-broad-search\"",
          "\"kind\":\"ingest\"",
          "\"stdinMode\":\"pipe-candidates\""
        ],
        "stdoutNotContains": [
          "codex-desktop-smoke-fixture"
        ],
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 500
      }
    },
    {
      "id": "guard-shell-read",
      "command": [
        "rs-harness",
        "agent",
        "guard",
        "--client",
        "codex",
        "--json",
        ".",
        "--",
        "sed",
        "-n",
        "1,40p",
        "src/lib.rs"
      ],
      "expect": {
        "exitCode": 1,
        "stdoutContains": [
          "\"permissionDecision\":\"deny\"",
          "\"reasonKind\":\"direct-source-read\"",
          "\"paths\":[\"src/lib.rs\"]"
        ],
        "stdoutNotContains": [
          "codex-desktop-smoke-fixture"
        ],
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 500
      }
    },
    {
      "id": "guard-exact-file-search",
      "command": [
        "rs-harness",
        "agent",
        "guard",
        "--client",
        "codex",
        ".",
        "--",
        "rg",
        "-n",
        "smoke",
        "src/lib.rs"
      ],
      "expect": {
        "stdoutEmpty": true,
        "maxElapsedMsWarn": 500
      }
    },
    {
      "id": "shim-rtk-read",
      "command": [
        ".codex/rs-harness/bin/rtk",
        "read",
        "src/lib.rs"
      ],
      "expect": {
        "exitCode": 1,
        "stdoutEmpty": true,
        "stderrContains": [
          "[rs-harness-flow] blocked=read-rs path=src/lib.rs",
          "rs-harness search owner src/lib.rs items"
        ],
        "maxStderrLinesWarn": 8,
        "maxElapsedMsWarn": 500
      }
    },
    {
      "id": "shim-rtk-rg",
      "command": [
        ".codex/rs-harness/bin/rtk",
        "rg",
        "-n",
        "smoke",
        "src",
        "tests"
      ],
      "expect": {
        "exitCode": 1,
        "stdoutEmpty": true,
        "stderrContains": [
          "Raw broad Rust search",
          "rs-harness search ingest"
        ],
        "maxStderrLinesWarn": 3,
        "maxElapsedMsWarn": 500
      }
    },
    {
      "id": "shim-sed-read",
      "command": [
        ".codex/rs-harness/bin/sed",
        "-n",
        "1,40p",
        "src/lib.rs"
      ],
      "expect": {
        "exitCode": 1,
        "stdoutEmpty": true,
        "stderrContains": [
          "[rs-harness-flow] blocked=read-rs path=src/lib.rs",
          "rs-harness search owner src/lib.rs items"
        ],
        "maxStderrLinesWarn": 8,
        "maxElapsedMsWarn": 500
      }
    }
  ]
}
