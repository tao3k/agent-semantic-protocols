{
  "id": "rust.codex-desktop-hook-smoke",
  "language": "rust",
  "title": "Codex Desktop tool payloads route real Rust workspace reads through rs-harness policy",
  "coverage": [
    "desktop-hooks",
    "codex-hooks",
    "codex-wrapper",
    "policy-blackbox",
    "security",
    "performance",
    "real-trigger"
  ],
  "tags": [
    "real-trigger",
    "rust-provider-workspace",
    "desktop-hooks"
  ],
  "workdir": {
    "relative": "languages/rust-lang-project-harness"
  },
  "budgets": {
    "maxCommands": 8,
    "maxTotalLinesWarn": 40
  },
  "steps": [
    {
      "id": "exec-command-rtk-read",
      "command": [
        "asp",
        "hook",
        "pre-tool",
        "--client",
        "codex"
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"functions.exec_command\",\"tool_input\":{\"cmd\":\"rtk read src/lib.rs\"}}",
      "expect": {
        "stdoutJsonEquals": {
          "hookSpecificOutput.permissionDecision": "deny"
        },
        "stdoutContains": [
          "\\\"reasonKind\\\":\\\"direct-source-read\\\"",
          "\\\"paths\\\":[\\\"src/lib.rs\\\"]",
          "\\\"providerId\\\":\\\"rs-harness\\\""
        ],
        "stdoutNotContains": [
          "pub mod",
          "fn "
        ],
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 8000
      }
    },
    {
      "id": "exec-command-rtk-rg",
      "command": [
        "asp",
        "hook",
        "pre-tool",
        "--client",
        "codex"
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"functions.exec_command\",\"tool_input\":{\"cmd\":\"rtk rg -n smoke src tests\"}}",
      "expect": {
        "stdoutJsonEquals": {},
        "stdoutContains": [
          "{}"
        ],
        "stdoutNotContains": [
          "pub mod",
          "fn "
        ],
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 6500
      }
    },
    {
      "id": "parallel-nested-exec-command",
      "command": [
        "asp",
        "hook",
        "pre-tool",
        "--client",
        "codex"
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"multi_tool_use.parallel\",\"tool_input\":{\"tool_uses\":[{\"recipient_name\":\"functions.exec_command\",\"parameters\":{\"cmd\":\"rtk read src/lib.rs\"}}]}}",
      "expect": {
        "stdoutJsonEquals": {
          "hookSpecificOutput.permissionDecision": "deny"
        },
        "stdoutContains": [
          "\\\"reasonKind\\\":\\\"direct-source-read\\\"",
          "\\\"paths\\\":[\\\"src/lib.rs\\\"]"
        ],
        "stdoutNotContains": [
          "pub mod",
          "fn "
        ],
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 6500
      }
    },
    {
      "id": "shell-read",
      "command": [
        "asp",
        "hook",
        "pre-tool",
        "--client",
        "codex"
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"functions.exec_command\",\"tool_input\":{\"cmd\":\"sed -n '1,40p' src/lib.rs\"}}",
      "expect": {
        "stdoutJsonEquals": {
          "hookSpecificOutput.permissionDecision": "deny"
        },
        "stdoutContains": [
          "\\\"reasonKind\\\":\\\"bulk-source-dump\\\"",
          "\\\"paths\\\":[\\\"src/lib.rs:1:40\\\""
        ],
        "stdoutNotContains": [
          "pub mod",
          "fn "
        ],
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 6500
      }
    },
    {
      "id": "guard-rtk-read",
      "command": [
        "asp",
        "hook",
        "pre-tool",
        "--client",
        "codex",
        "--emit",
        "decision"
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"functions.exec_command\",\"tool_input\":{\"cmd\":\"rtk read src/lib.rs\"}}",
      "expect": {
        "stdoutJsonEquals": {
          "decision": "deny",
          "reasonKind": "direct-source-read",
          "subject.paths.0": "src/lib.rs"
        },
        "stdoutNotContains": [
          "pub mod",
          "fn "
        ],
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 6500
      }
    },
    {
      "id": "guard-rtk-rg",
      "command": [
        "asp",
        "hook",
        "pre-tool",
        "--client",
        "codex",
        "--emit",
        "decision"
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"functions.exec_command\",\"tool_input\":{\"cmd\":\"rtk rg -n smoke src tests\"}}",
      "expect": {
        "stdoutJsonEquals": {
          "decision": "allow",
          "reasonKind": "none"
        },
        "stdoutNotContains": [
          "pub mod",
          "fn "
        ],
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 6500
      }
    },
    {
      "id": "guard-shell-read",
      "command": [
        "asp",
        "hook",
        "pre-tool",
        "--client",
        "codex",
        "--emit",
        "decision"
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"functions.exec_command\",\"tool_input\":{\"cmd\":\"sed -n '1,40p' src/lib.rs\"}}",
      "expect": {
        "stdoutJsonEquals": {
          "decision": "deny",
          "reasonKind": "bulk-source-dump",
          "subject.paths.0": "src/lib.rs:1:40"
        },
        "stdoutNotContains": [
          "pub mod",
          "fn "
        ],
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 6500
      }
    },
    {
      "id": "guard-exact-file-search",
      "command": [
        "asp",
        "hook",
        "pre-tool",
        "--client",
        "codex",
        "--emit",
        "decision"
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"functions.exec_command\",\"tool_input\":{\"cmd\":\"rg -n smoke src/lib.rs\"}}",
      "expect": {
        "stdoutJsonEquals": {
          "decision": "deny",
          "reasonKind": "raw-broad-search",
          "routes.0.kind": "fzf"
        },
        "maxElapsedMsWarn": 6500
      }
    }
  ]
}
