{
  "id": "rust.tokio-intent-matrix",
  "language": "rust",
  "title": "Tokio large-library feature/API/principle intent matrix",
  "coverage": [
    "search-flow",
    "performance",
    "large-library"
  ],
  "tags": [
    "large-library",
    "tokio",
    "intent-matrix"
  ],
  "evidence": {
    "source": "handwritten",
    "fixtureTier": "large-library",
    "targetLibrary": {
      "language": "rust",
      "name": "Tokio",
      "package": "tokio",
      "repository": "tokio-rs/tokio",
      "workdirKind": "registry"
    },
    "intentCases": [
      {
        "intentKind": "feature-implementation",
        "intent": "Implement an io-uring related async IO feature without opening large owners directly",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "io_uring"
        ]
      },
      {
        "intentKind": "api-usage",
        "intent": "Find how AsyncRead is exposed and used before choosing owners",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "AsyncRead"
        ]
      },
      {
        "intentKind": "implementation-principle",
        "intent": "Understand the runtime scheduler implementation path from compact search packets",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "scheduler"
        ]
      }
    ]
  },
  "workdir": {
    "env": "SANDTABLE_RUST_TOKIO_ROOT",
    "candidates": [
      "~/.cargo/registry/src/*/tokio-[0-9]*"
    ]
  },
  "budgets": {
    "maxCommands": 2,
    "maxTotalLinesWarn": 24,
    "maxTotalStdoutBytesWarn": 16000
  },
  "steps": [
    {
      "id": "prime",
      "command": [
        "rs-harness",
        "search",
        "prime",
        "--view",
        "seeds",
        "--seeds",
        "4",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-prime]",
          "legend: ID=kind:role(value)!next; edge SRC>{DST:rel}; frontier ID.next",
          "alias: graph:{G=search",
          "G>{",
          "rank=",
          "frontier=",
          "entries="
        ],
        "maxStdoutLinesWarn": 10,
        "maxElapsedMsWarn": 2500,
        "stdoutNotContains": [
          "|seed",
          "|synthesis",
          "G=search:result!query"
        ]
      }
    },
    {
      "id": "intent-query-set",
      "command": [
        "rs-harness",
        "search",
        "fzf",
        "--query-set",
        "io_uring",
        "--query-set",
        "AsyncRead",
        "--query-set",
        "scheduler",
        "--view",
        "seeds",
        "--seeds",
        "4",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-fzf]",
          "querySet=3",
          "legend: ID=kind:role(value)!next; edge SRC>{DST:rel}; frontier ID.next",
          "alias: graph:{G=search",
          "G>{",
          "rank=",
          "frontier=",
          "entries=owner-query(O,Q=>items+tests+dependency-usage),owner-tests(O=>covering-tests+test-entrypoints+fixtures)"
        ],
        "maxStdoutLinesWarn": 10,
        "maxElapsedMsWarn": 2500,
        "stdoutNotContains": [
          "|seed",
          "|synthesis",
          "G=search:result!query"
        ]
      }
    }
  ]
}
