{
  "id": "rust.tokio-intent-matrix",
  "language": "rust",
  "title": "Tokio large-library feature/API/principle intent matrix",
  "coverage": [
    "search-flow",
    "performance",
    "large-library"
  ],
  "tags": [
    "large-library",
    "tokio",
    "intent-matrix"
  ],
  "evidence": {
    "source": "handwritten",
    "fixtureTier": "large-library",
    "targetLibrary": {
      "language": "rust",
      "name": "Tokio",
      "package": "tokio",
      "repository": "tokio-rs/tokio",
      "workdirKind": "registry"
    },
    "intentCases": [
      {
        "intentKind": "feature-implementation",
        "intent": "Implement an io-uring related async IO feature without opening large owners directly",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "io_uring"
        ]
      },
      {
        "intentKind": "api-usage",
        "intent": "Find how AsyncRead is exposed and used before choosing owners",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "AsyncRead"
        ]
      },
      {
        "intentKind": "implementation-principle",
        "intent": "Understand the runtime scheduler implementation path from compact search packets",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "scheduler"
        ]
      }
    ],
    "deepQuestionCases": [
      {
        "id": "tokio-vec-scalar-collection-fields",
        "question": "tokio 0.6.0 的 Vec<scalar> collection fields 意义是什么？它们在结构体字段建模里为什么不是普通 scalar field？",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "Vec",
          "scalar",
          "collection",
          "fields"
        ],
        "audit": {
          "maxAspCommands": 8,
          "maxSearchCommands": 4,
          "maxQueryCommands": 4,
          "maxRepeatedCommands": 0,
          "requiresGraphSignals": true,
          "requiresQuerySet": true,
          "requiresHookEvents": true
        }
      },
      {
        "id": "tokio-scheduler-work-stealing",
        "question": "Tokio runtime scheduler 的 work stealing 路径如何组织？先定位 owner，不要直接读完整 scheduler 文件。",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "scheduler",
          "steal",
          "worker"
        ],
        "audit": {
          "maxAspCommands": 7,
          "maxSearchCommands": 4,
          "maxQueryCommands": 3,
          "maxRepeatedCommands": 0,
          "requiresGraphSignals": true,
          "requiresQuerySet": true,
          "requiresHookEvents": true
        }
      },
      {
        "id": "tokio-async-read-exposure",
        "question": "Tokio 的 AsyncRead trait 是如何对外暴露并被 io 模块复用的？需要先给 API owner frontier。",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "AsyncRead",
          "io",
          "trait"
        ],
        "audit": {
          "maxAspCommands": 7,
          "maxSearchCommands": 4,
          "maxQueryCommands": 3,
          "maxRepeatedCommands": 0,
          "requiresGraphSignals": true,
          "requiresQuerySet": true,
          "requiresHookEvents": true
        }
      },
      {
        "id": "tokio-io-uring-feature-path",
        "question": "如果要理解或修改 Tokio 的 io_uring 相关 async IO 路径，应该从哪些 compact search owner 开始？",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "io_uring",
          "driver",
          "async"
        ],
        "audit": {
          "maxAspCommands": 7,
          "maxSearchCommands": 4,
          "maxQueryCommands": 3,
          "maxRepeatedCommands": 0,
          "requiresGraphSignals": true,
          "requiresQuerySet": true,
          "requiresHookEvents": true
        }
      },
      {
        "id": "tokio-runtime-handle-enter-owner-frontier",
        "question": "Tokio runtime Handle::enter 的上下文进入和 guard 生命周期应该从哪些 owner frontier 开始定位？",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "Handle",
          "enter",
          "guard",
          "runtime"
        ],
        "audit": {
          "maxAspCommands": 6,
          "maxSearchCommands": 3,
          "maxQueryCommands": 3,
          "maxRepeatedCommands": 0,
          "requiresGraphSignals": true,
          "requiresQuerySet": true,
          "requiresHookEvents": true
        }
      },
      {
        "id": "tokio-async-read-public-owner-strict",
        "question": "Tokio AsyncRead 的 public owner frontier 能否在三条 ASP 命令内定位，并说明下一步不应直接读完整 io 模块？",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "AsyncRead",
          "public",
          "owner"
        ],
        "audit": {
          "maxAspCommands": 3,
          "maxSearchCommands": 2,
          "maxQueryCommands": 1,
          "maxRepeatedCommands": 0,
          "requiresGraphSignals": true,
          "requiresQuerySet": true,
          "requiresHookEvents": true,
          "requiresComplexPipeFlow": true,
          "requiresTokenCost": true
        },
        "expectedAspFlow": {
          "requiredStages": [
            "search-prime",
            "search-pipe",
            "query-selector"
          ],
          "forbiddenStages": [
            "repeated-prime",
            "repeated-commands",
            "direct-read"
          ]
        }
      }
    ]
  },
  "workdir": {
    "env": "SANDTABLE_RUST_TOKIO_ROOT",
    "candidates": [
      "~/.cargo/registry/src/*/tokio-[0-9]*"
    ]
  },
  "budgets": {
    "maxCommands": 4,
    "maxTotalLinesWarn": 42,
    "maxTotalStdoutBytesWarn": 24000
  },
  "steps": [
    {
      "id": "prime",
      "command": [
        "asp",
        "rust",
        "search",
        "prime",
        "--view",
        "seeds",
        "--seeds",
        "4",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-prime]",
          "alg=budgeted-prime-frontier-v1",
          "|decision purpose=decision-primer",
          "capabilities=pipe,lexical,fd-query,rg-query,owner-items,selector-code,treesitter-query",
          "legend: ID=kind:role(value)!next; entries profile(selectors=>returns); frontier ID.next",
          "G>{",
          "rank=",
          "frontier=",
          "omit=items,blocks,code,full-test-list",
          "avoid=raw-read"
        ],
        "maxStdoutLinesWarn": 10,
        "maxElapsedMs": 300,
        "maxElapsedMsWarn": 250,
        "stdoutNotContains": [
          "|seed",
          "|synthesis",
          "G=search:result!query"
        ]
      }
    },
    {
      "id": "owner-lib",
      "command": [
        "asp",
        "rust",
        "search",
        "owner",
        "src/lib.rs",
        "--view",
        "seeds",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-owner]",
          "src/lib.rs",
          "entries=owner-tests(O=>covering-tests+test-entrypoints+fixtures)"
        ],
        "maxStdoutLinesWarn": 14,
        "maxElapsedMs": 300,
        "maxElapsedMsWarn": 250,
        "stdoutNotContains": [
          "|seed",
          "|synthesis",
          "G=search:result!query"
        ]
      }
    },
    {
      "id": "deps-tokio",
      "command": [
        "asp",
        "rust",
        "search",
        "deps",
        "tokio",
        "--view",
        "seeds",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-dependency]",
          "q=tokio",
          "frontier="
        ],
        "maxStdoutLinesWarn": 16,
        "maxElapsedMs": 300,
        "maxElapsedMsWarn": 250,
        "stdoutNotContains": [
          "|seed",
          "|synthesis",
          "G=search:result!query"
        ]
      }
    },
    {
      "id": "intent-query-set",
      "command": [
        "asp",
        "rust",
        "search",
        "lexical",
        "--query",
        "io_uring",
        "--query",
        "AsyncRead",
        "--query",
        "scheduler",
        "--view",
        "seeds",
        "--seeds",
        "4",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-lexical]",
          "querySet=3",
          "legend: ID=kind:role(value)!next; edge SRC>{DST:rel}; frontier ID.next",
          "G>{",
          "rank=",
          "frontier=",
          "entries=owner-query(O,Q=>items+tests+dependency-usage),owner-tests(O=>covering-tests+test-entrypoints+fixtures)"
        ],
        "maxStdoutLinesWarn": 10,
        "maxElapsedMs": 300,
        "maxElapsedMsWarn": 250,
        "stdoutNotContains": [
          "|seed",
          "|synthesis",
          "G=search:result!query"
        ]
      }
    }
  ]
}
