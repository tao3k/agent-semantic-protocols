{
  "id": "rust.bytes-buffer-flow",
  "language": "rust",
  "title": "bytes BytesMut buffer flow",
  "coverage": [
    "search-flow",
    "performance"
  ],
  "workdir": {
    "env": "SANDTABLE_RUST_BYTES_ROOT",
    "candidates": [
      "~/.cargo/registry/src/*/bytes-[0-9]*"
    ]
  },
  "budgets": {
    "maxCommands": 4,
    "maxTotalLinesWarn": 48
  },
  "steps": [
    {
      "id": "prime",
      "command": [
        "asp rust",
        "search",
        "prime",
        "--view",
        "seeds",
        "--seeds",
        "8",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-prime]",
          "legend: ID=kind:role(value)!next; entries profile(selectors=>returns); frontier ID.next",
          "G>{",
          "rank=",
          "frontier="
        ],
        "maxStdoutLinesWarn": 10,
        "maxElapsedMsWarn": 1500,
        "stdoutNotContains": [
          "|seed",
          "|synthesis",
          "G=search:result!query"
        ]
      }
    },
    {
      "id": "text-bytes-mut",
      "command": [
        "asp rust",
        "search",
        "lexical",
        "BytesMut",
        "--view",
        "seeds",
        "--seeds",
        "8",
        "--workspace",
        "."
      ],
      "capture": {
        "bytesOwner": "owner:path\\(([^)]+)\\)!owner"
      },
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-lexical]",
          "legend: ID=kind:role(value)!next; edge SRC>{DST:rel}; frontier ID.next",
          "G>{",
          "rank=",
          "frontier="
        ],
        "maxStdoutLinesWarn": 8,
        "maxElapsedMsWarn": 1500,
        "stdoutNotContains": [
          "|seed",
          "|synthesis",
          "G=search:result!query"
        ]
      }
    },
    {
      "id": "owner-bytes-items",
      "command": [
        "asp rust",
        "search",
        "owner",
        "{bytesOwner}",
        "items",
        "--trace",
        "--view",
        "seeds",
        "--seeds",
        "8",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-owner]",
          "legend: ID=kind:role(value)!next; edge SRC>{DST:rel}; frontier ID.next",
          "G>{",
          "rank=",
          "frontier="
        ],
        "maxStdoutLinesWarn": 20,
        "maxElapsedMsWarn": 1800,
        "stdoutNotContains": [
          "|seed",
          "|synthesis",
          "G=search:result!query"
        ]
      }
    },
    {
      "id": "tests-bytes-owner",
      "command": [
        "asp rust",
        "search",
        "tests",
        "{bytesOwner}",
        "--view",
        "seeds",
        "--seeds",
        "4",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-tests]"
        ],
        "maxStdoutLinesWarn": 10,
        "maxElapsedMsWarn": 1500
      }
    }
  ]
}
