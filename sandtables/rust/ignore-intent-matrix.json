{
  "id": "rust.ignore-intent-matrix",
  "language": "rust",
  "title": "ignore large-library feature/API/principle intent matrix",
  "coverage": [
    "search-flow",
    "deps-query",
    "performance",
    "large-library"
  ],
  "tags": [
    "large-library",
    "ignore",
    "intent-matrix"
  ],
  "evidence": {
    "source": "handwritten",
    "fixtureTier": "large-library",
    "targetLibrary": {
      "language": "rust",
      "name": "ignore",
      "package": "ignore",
      "repository": "BurntSushi/ripgrep",
      "workdirKind": "registry"
    },
    "intentCases": [
      {
        "intentKind": "feature-implementation",
        "intent": "Implement an override or gitignore matching feature while preserving compact search boundaries",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "OverrideBuilder"
        ]
      },
      {
        "intentKind": "api-usage",
        "intent": "Find WalkBuilder API usage and dependency-facing paths",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "WalkBuilder"
        ]
      },
      {
        "intentKind": "implementation-principle",
        "intent": "Understand how gitignore matching is organized internally",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "gitignore"
        ]
      }
    ],
    "deepQuestionCases": [
      {
        "id": "ignore-overridebuilder-precedence",
        "question": "OverrideBuilder 的匹配优先级和 gitignore 规则如何交互？先定位 builder、matcher 和测试 owner。",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "OverrideBuilder",
          "precedence",
          "gitignore"
        ],
        "audit": {
          "maxAspCommands": 7,
          "maxSearchCommands": 4,
          "maxQueryCommands": 3,
          "maxRepeatedCommands": 0,
          "requiresGraphSignals": true,
          "requiresQuerySet": true,
          "requiresHookEvents": true
        }
      },
      {
        "id": "ignore-walkbuilder-filter-composition",
        "question": "WalkBuilder 如何组合 hidden、gitignore、override 等过滤条件？需要 compact frontier 而不是全文阅读。",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "WalkBuilder",
          "filter",
          "hidden"
        ],
        "audit": {
          "maxAspCommands": 7,
          "maxSearchCommands": 4,
          "maxQueryCommands": 3,
          "maxRepeatedCommands": 0,
          "requiresGraphSignals": true,
          "requiresQuerySet": true,
          "requiresHookEvents": true
        }
      },
      {
        "id": "ignore-gitignore-nested-whitelist",
        "question": "嵌套 .gitignore 和白名单规则冲突时 ignore crate 的组织原则是什么？先找 rule parse 和 matcher owner。",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "gitignore",
          "whitelist",
          "matcher"
        ],
        "audit": {
          "maxAspCommands": 7,
          "maxSearchCommands": 4,
          "maxQueryCommands": 3,
          "maxRepeatedCommands": 0,
          "requiresGraphSignals": true,
          "requiresQuerySet": true,
          "requiresHookEvents": true
        }
      }
    ]
  },
  "workdir": {
    "env": "SANDTABLE_RUST_IGNORE_ROOT",
    "candidates": [
      "~/.cargo/registry/src/*/ignore-[0-9]*"
    ]
  },
  "budgets": {
    "maxCommands": 2,
    "maxTotalLinesWarn": 24,
    "maxTotalStdoutBytesWarn": 16000
  },
  "steps": [
    {
      "id": "prime",
      "command": [
        "rs-harness",
        "search",
        "prime",
        "--view",
        "seeds",
        "--seeds",
        "4",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-prime]",
          "analysis=structure",
          "nativeSyntaxFacts=skipped",
          "policyFindings=skipped",
          "legend: ID=kind:role(value)!next; entries profile(selectors=>returns); frontier ID.next",
          "entries=owner-tests(O=>covering-tests+test-entrypoints+fixtures)",
        "G>{",
        "rank=",
          "frontier="
        ],
        "maxStdoutLinesWarn": 10,
        "maxElapsedMsWarn": 2500,
        "stdoutNotContains": [
          "|seed",
          "|synthesis",
          "G=search:result!query"
        ]
      }
    },
    {
      "id": "intent-query-set",
      "command": [
        "rs-harness",
        "search",
        "fzf",
        "--query-set",
        "OverrideBuilder",
        "--query-set",
        "WalkBuilder",
        "--query-set",
        "gitignore",
        "--view",
        "seeds",
        "--seeds",
        "4",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-fzf]",
          "querySet=3",
          "legend: ID=kind:role(value)!next; edge SRC>{DST:rel}; frontier ID.next",
          "G>{",
          "rank=",
          "frontier=",
          "entries=owner-query(O,Q=>items+tests+dependency-usage),owner-tests(O=>covering-tests+test-entrypoints+fixtures)"
        ],
        "maxStdoutLinesWarn": 10,
        "maxElapsedMsWarn": 2500,
        "stdoutNotContains": [
          "|seed",
          "|synthesis",
          "G=search:result!query"
        ]
      }
    }
  ]
}
