{
  "id": "rust.tokio-real-trigger-flow",
  "title": "Tokio async IO live-agent prompt-only flow",
  "language": "rust",
  "skipUnlessEnv": [
    "ASP_LIVE_CLAUDE_CLI",
    "ANTHROPIC_AUTH_TOKEN"
  ],
  "tags": [
    "real-trigger",
    "tokio",
    "async-io",
    "prompt-only"
  ],
  "coverage": [
    "search-flow",
    "performance",
    "real-trigger"
  ],
  "workdir": {
    "env": "SANDTABLE_RUST_TOKIO_ROOT",
    "candidates": [
      "~/.cargo/registry/src/*/tokio-[0-9]*"
    ]
  },
  "execution": {
    "mode": "parallel",
    "maxConcurrentSteps": 1
  },
  "budgets": {
    "maxTotalElapsedMsWarn": 120000,
    "maxTotalStdoutBytesWarn": 200000
  },
  "evidence": {
    "source": "real-trigger",
    "intent": "Implement a feature-level async IO change before selecting files to edit",
    "recordedAt": "2026-06-08",
    "receiptPath": "sandtables/receipts/rust/tokio-real-trigger-flow.receipt.json",
    "editBoundary": "before-edit",
    "metrics": {
      "tokenDelta": "lower"
    },
    "deepQuestionCases": [
      {
        "id": "tokio-async-io-owner-frontier",
        "question": "In Tokio 1.52.3, where should AsyncRead and AsyncWrite poll_read or poll_write behavior be located before selecting files to edit?",
        "stepIds": [
          "claude-tokio-async-io"
        ],
        "queryTerms": [
          "AsyncRead",
          "AsyncWrite",
          "poll_read",
          "poll_write"
        ],
        "audit": {
          "maxAspCommands": 5,
          "maxSearchCommands": 3,
          "maxQueryCommands": 2,
          "maxRepeatedCommands": 0,
          "requiresGraphSignals": true,
          "requiresHookEvents": true,
          "requiresTokenCost": true
        },
        "expectedAspFlow": {
          "requiredStages": [
            "search-prime",
            "search-pipe"
          ],
          "forbiddenStages": [
            "repeated-prime",
            "repeated-commands",
            "read-loop-risk"
          ],
          "notes": [
            "The scenario input is only the user question. ASP commands must come from the agent workflow and hook recovery, not scripted scenario steps."
          ]
        }
      }
    ]
  },
  "liveAgent": {
    "client": "claude",
    "outputFormat": "stream-json",
    "includeHookEvents": true,
    "verbose": true,
    "useRepoClaudeSettings": true,
    "env": {
      "ANTHROPIC_AUTH_TOKEN": "${ANTHROPIC_AUTH_TOKEN}"
    },
    "requiredEnv": [
      "ANTHROPIC_AUTH_TOKEN"
    ],
    "timeoutSeconds": 120,
    "expect": {
      "allowNonZeroExit": true,
      "agentAnswer": {
        "required": true,
        "afterLastToolUse": true,
        "minTextBytes": 250,
        "contains": [
          "AsyncRead",
          "poll"
        ]
      },
      "pipeFlow": {
        "maxAspCommands": 5,
        "maxSearchCommands": 3,
        "maxQueryCommands": 1,
        "maxGuideCommands": 1,
        "maxRepeatedCommands": 0,
        "maxSearchPipeCommands": 2,
        "maxSearchPrimeCommands": 1,
        "maxReadLoopDuplicateSelectors": 0,
        "maxReadLoopAdjacentRangeWindows": 0,
        "maxReadLoopSameOwnerScans": 0,
        "maxReadLoopMemorySuppressibleReads": 0,
        "requireTokenCost": true,
        "requiredStages": [
          "search-prime",
          "search-pipe"
        ],
        "forbiddenStages": [
          "repeated-prime",
          "repeated-commands",
          "read-loop-risk",
          "read-loop-memory-risk"
        ]
      },
      "stdoutContains": [
        "AsyncRead"
      ],
      "maxStdoutBytesWarn": 200000,
      "maxElapsedMsWarn": 120000
    }
  }
}
