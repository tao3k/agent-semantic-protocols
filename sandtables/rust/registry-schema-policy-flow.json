{
  "id": "rust.registry-schema-policy-flow",
  "language": "rust",
  "title": "Rust registry, JSON schema, policy, performance, and hook contract flow",
  "coverage": [
    "language-registry",
    "json-schema",
    "search-flow",
    "policy-blackbox",
    "policy-whitebox",
    "performance",
    "security",
    "codex-hooks",
    "codex-wrapper",
    "evidence-assurance"
  ],
  "workdir": {
    "env": "SANDTABLE_RUST_HOOK_ROOT",
    "candidates": [
      "../rust-lang-project-harness"
    ]
  },
  "budgets": {
    "maxCommands": 7,
    "maxTotalLinesWarn": 12,
    "maxTotalElapsedMsWarn": 3500,
    "maxTotalStdoutBytesWarn": 24000
  },
  "steps": [
    {
      "id": "registry-json-schema",
      "kind": "schema-contract",
      "coverage": ["language-registry", "json-schema", "policy-whitebox", "evidence-assurance"],
      "command": [
        "rs-harness",
        "agent",
        "doctor",
        "--client",
        "codex",
        "--json",
        "."
      ],
      "expect": {
        "stdoutJsonSchema": "schemas/semantic-language-registry.v1.schema.json",
        "stdoutJsonEquals": {
          "registryId": "agent.semantic-protocols.semantic-language-registry",
          "languages.0.languageId": "rust",
          "languages.0.providerId": "rs-harness",
          "languages.0.binary": "rs-harness"
        },
        "stdoutJsonArrayContains": {
          "languages.0.methods": "evidence/assurance",
          "languages.0.schemas": {
            "schemaId": "agent.semantic-protocols.semantic-assurance-case",
            "schemaVersion": "1",
            "path": "schemas/semantic-assurance-case.v1.schema.json"
          },
          "languages.0.methodDescriptors": {
            "method": "evidence/assurance",
            "command": "evidence",
            "input": "assurance"
          }
        },
        "stdoutNotContains": [
          "agent/guard",
          "agent/hook"
        ],
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 800
      }
    },
    {
      "id": "assurance-case-schema",
      "kind": "schema-contract",
      "coverage": ["evidence-assurance", "json-schema", "performance"],
      "command": [
        "rs-harness",
        "evidence",
        "assurance",
        "--evidence-graph-json",
        "../agent-semantic-protocols/tests/fixtures/rust/assurance-evidence-graph.json",
        "--json",
        "."
      ],
      "expect": {
        "stdoutJsonSchema": "schemas/semantic-assurance-case.v1.schema.json",
        "stdoutJsonEquals": {
          "schemaId": "agent.semantic-protocols.semantic-assurance-case",
          "protocolId": "agent.semantic-protocols.assurance-case",
          "cases.0.status": "needs-review",
          "cases.0.claim.kind": "invariant"
        },
        "stdoutContains": [
          "\"cases\":1",
          "\"claims\":1",
          "\"openGaps\":1",
          "\"staleItems\":1"
        ],
        "maxStdoutLinesWarn": 1,
        "maxStdoutBytesWarn": 2500,
        "maxElapsedMsWarn": 800
      }
    },
    {
      "id": "prime-search-packet-schema",
      "kind": "schema-contract",
      "coverage": ["json-schema", "search-flow", "performance"],
      "command": [
        "rs-harness",
        "search",
        "prime",
        "--json",
        "--view",
        "seeds",
        "--seeds",
        "4",
        "."
      ],
      "expect": {
        "stdoutJsonSchema": "schemas/semantic-search-packet.v1.schema.json",
        "stdoutJsonEquals": {
          "schemaId": "agent.semantic-protocols.semantic-search-packet",
          "languageId": "rust",
          "providerId": "rs-harness",
          "method": "search/prime",
          "renderMode": "seeds"
        },
        "maxStdoutLinesWarn": 1,
        "maxStdoutBytesWarn": 9000,
        "maxElapsedMsWarn": 1000
      }
    },
    {
      "id": "dependency-query-set-packet-schema",
      "kind": "schema-contract",
      "coverage": ["json-schema", "search-flow", "deps-query", "performance"],
      "command": [
        "rs-harness",
        "search",
        "dependency",
        "serde,serde_json",
        "--json",
        "--view",
        "seeds",
        "--seeds",
        "4",
        "."
      ],
      "expect": {
        "stdoutJsonSchema": "schemas/semantic-search-packet.v1.schema.json",
        "stdoutJsonEquals": {
          "schemaId": "agent.semantic-protocols.semantic-search-packet",
          "languageId": "rust",
          "providerId": "rs-harness",
          "method": "search/dependency",
          "query": "serde,serde_json",
          "header.fields.selector": "exact-set",
          "querySet.0.value": "serde",
          "querySet.1.value": "serde_json",
          "queryComposition.mode": "query-set",
          "queryComposition.selector": "exact-set"
        },
        "stdoutJsonContains": {
          "header.fields": "\"querySet\": 2"
        },
        "maxStdoutLinesWarn": 1,
        "maxStdoutBytesWarn": 12000,
        "maxElapsedMsWarn": 1000
      }
    },
    {
      "id": "hook-decision-schema",
      "kind": "hook-replay",
      "coverage": ["codex-hooks", "json-schema", "policy-blackbox", "security"],
      "command": [
        "semantic-agent-hook",
        "hook",
        "--client",
        "codex",
        "pre-tool",
        "--emit",
        "decision"
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"Read\",\"tool_input\":{\"path\":\"src/lib.rs\"}}",
      "expect": {
        "stdoutJsonSchema": "schemas/semantic-agent-hook-decision.v1.schema.json",
        "stdoutJsonEquals": {
          "decision": "deny",
          "reasonKind": "direct-source-read",
          "languageIds": ["rust"]
        },
        "stdoutNotContains": [
          "pub mod",
          "fn main"
        ],
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 800
      }
    },
    {
      "id": "guard-decision-schema",
      "kind": "wrapper",
      "coverage": ["codex-wrapper", "json-schema", "policy-blackbox", "security"],
      "command": [
        "semantic-agent-hook",
        "hook",
        "--client",
        "codex",
        "pre-tool",
        "--emit",
        "decision"
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"functions.exec_command\",\"tool_input\":{\"cmd\":\"sed -n '1,40p' src/lib.rs\"}}",
      "expect": {
        "stdoutJsonSchema": "schemas/semantic-agent-hook-decision.v1.schema.json",
        "stdoutJsonEquals": {
          "decision": "deny",
          "reasonKind": "bulk-source-dump"
        },
        "stdoutNotContains": [
          "pub mod",
          "fn main"
        ],
        "maxStdoutLinesWarn": 1,
        "maxElapsedMsWarn": 800
      }
    },
    {
      "id": "raw-broad-search-denied",
      "kind": "policy-blackbox",
      "coverage": ["policy-blackbox", "security", "performance"],
      "command": [
        "semantic-agent-hook",
        "hook",
        "--client",
        "codex",
        "pre-tool",
        "--emit",
        "decision"
      ],
      "stdin": "{\"hook_event_name\":\"PreToolUse\",\"tool_name\":\"functions.exec_command\",\"tool_input\":{\"cmd\":\"rg -n run_agent src/cli/runner.rs\"}}",
      "expect": {
        "stdoutJsonEquals": {
          "decision": "deny",
          "reasonKind": "raw-broad-search"
        },
    "stdoutJsonArrayContains": {
      "routes": {
        "binary": "rs-harness",
        "kind": "query",
        "languageId": "rust"
      }
    },
        "maxElapsedMsWarn": 800
      }
    }
  ]
}
