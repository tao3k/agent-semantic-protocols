{
  "id": "typescript.vite-intent-matrix",
  "language": "typescript",
  "title": "Vite large-library feature/API/principle intent matrix",
  "coverage": [
    "search-flow",
    "performance",
    "large-library"
  ],
  "tags": [
    "large-library",
    "vite",
    "intent-matrix"
  ],
  "evidence": {
    "source": "handwritten",
    "fixtureTier": "large-library",
    "targetLibrary": {
      "language": "typescript",
      "name": "Vite",
      "package": "vite",
      "repository": "vitejs/vite",
      "workdirKind": "checkout"
    },
    "intentCases": [
      {
        "intentKind": "feature-implementation",
        "intent": "Implement a dev-server HMR feature after locating compact owners and tests",
        "stepIds": [
          "prime",
          "feature-hmr"
        ],
        "queryTerms": [
          "handleHotUpdate"
        ]
      },
      {
        "intentKind": "api-usage",
        "intent": "Find createServer API usage and public surface owners",
        "stepIds": [
          "prime",
          "api-create-server"
        ],
        "queryTerms": [
          "createServer"
        ]
      },
      {
        "intentKind": "implementation-principle",
        "intent": "Understand plugin container execution flow from search packets",
        "stepIds": [
          "prime",
          "principle-plugin-container"
        ],
        "queryTerms": [
          "pluginContainer"
        ]
      }
    ]
  },
  "workdir": {
    "env": "SANDTABLE_TS_VITE_ROOT",
    "candidates": [
      "~/ghq/github.com/vitejs/vite",
      "~/src/vite",
      "~/work/vite"
    ]
  },
  "budgets": {
    "maxCommands": 4,
    "maxTotalLinesWarn": 60,
    "maxTotalStdoutBytesWarn": 32000
  },
  "steps": [
    {
      "id": "prime",
      "command": [
        "ts-harness",
        "search",
        "prime",
        "--view",
        "seeds",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-prime]"
        ],
        "maxStdoutLinesWarn": 16,
        "maxElapsedMsWarn": 9000
      }
    },
    {
      "id": "feature-hmr",
      "command": [
        "ts-harness",
        "search",
        "fzf",
        "handleHotUpdate",
        "--view",
        "seeds",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-fzf]"
        ],
        "maxStdoutLinesWarn": 14,
        "maxElapsedMsWarn": 9000
      }
    },
    {
      "id": "api-create-server",
      "command": [
        "ts-harness",
        "search",
        "api",
        "createServer",
        "--view",
        "seeds",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-api]"
        ],
        "maxStdoutLinesWarn": 14,
        "maxElapsedMsWarn": 9000
      }
    },
    {
      "id": "principle-plugin-container",
      "command": [
        "ts-harness",
        "search",
        "fzf",
        "pluginContainer",
        "--view",
        "seeds",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-fzf]"
        ],
        "maxStdoutLinesWarn": 16,
        "maxElapsedMsWarn": 9000
      }
    }
  ]
}
