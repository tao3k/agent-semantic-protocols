{
  "id": "typescript.vite-intent-matrix",
  "language": "typescript",
  "title": "Vite large-library feature/API/principle intent matrix",
  "coverage": [
    "search-flow",
    "performance",
    "large-library"
  ],
  "tags": [
    "large-library",
    "vite",
    "intent-matrix"
  ],
  "evidence": {
    "source": "handwritten",
    "fixtureTier": "large-library",
    "targetLibrary": {
      "language": "typescript",
      "name": "Vite",
      "package": "vite",
      "repository": "vitejs/vite",
      "workdirKind": "checkout"
    },
    "intentCases": [
      {
        "intentKind": "feature-implementation",
        "intent": "Implement a dev-server HMR feature after locating compact owners and tests",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "handleHotUpdate"
        ]
      },
      {
        "intentKind": "api-usage",
        "intent": "Find createServer API usage and public surface owners",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "createServer"
        ]
      },
      {
        "intentKind": "implementation-principle",
        "intent": "Understand plugin container execution flow from search packets",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "pluginContainer"
        ]
      }
    ],
    "deepQuestionCases": [
      {
        "id": "vite-plugin-container-hmr-owner-flow",
        "question": "In Vite, which plugin container, handleHotUpdate, and module graph owners should an agent inspect before changing HMR invalidation behavior?",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "pluginContainer",
          "handleHotUpdate",
          "moduleGraph"
        ],
        "audit": {
          "maxAspCommands": 7,
          "maxSearchCommands": 4,
          "maxQueryCommands": 3,
          "maxRepeatedCommands": 0,
          "requiresGraphSignals": true,
          "requiresQuerySet": true,
          "requiresHookEvents": true
        },
        "expectedAspFlow": {
          "requiredStages": [
            "search-prime",
            "search-pipe",
            "query-selector"
          ],
          "forbiddenStages": [
            "repeated-prime",
            "repeated-commands"
          ]
        }
      },
      {
        "id": "vite-config-resolve-plugin-deep",
        "question": "In Vite, how should an agent connect config resolution, plugin container ordering, and dev server owners before changing plugin hook execution?",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "resolveConfig",
          "pluginContainer",
          "createServer"
        ],
        "audit": {
          "maxAspCommands": 7,
          "maxSearchCommands": 4,
          "maxQueryCommands": 3,
          "maxRepeatedCommands": 0,
          "requiresGraphSignals": true,
          "requiresQuerySet": true,
          "requiresHookEvents": true
        },
        "expectedAspFlow": {
          "requiredStages": [
            "search-prime",
            "search-pipe",
            "query-selector"
          ],
          "forbiddenStages": [
            "repeated-prime",
            "repeated-commands",
            "direct-read"
          ]
        }
      }
    ]
  },
  "workdir": {
    "env": "SANDTABLE_TS_VITE_ROOT",
    "candidates": [
      "~/ghq/github.com/vitejs/vite",
      "~/src/vite",
      "~/work/vite"
    ]
  },
  "budgets": {
    "maxCommands": 2,
    "maxTotalLinesWarn": 24,
    "maxTotalStdoutBytesWarn": 16000
  },
  "steps": [
    {
      "id": "prime",
      "command": [
        "asp",
        "typescript",
        "search",
        "prime",
        "--view",
        "seeds",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-prime]",
          "analysis=structure",
          "nativeSyntaxFacts=skipped",
          "policyFindings=skipped",
          "entries=owner-query(O,Q=>items+tests+dependency-usage),owner-tests(O=>covering-tests+test-entrypoints+fixtures)"
        ],
        "maxStdoutLinesWarn": 16,
        "maxElapsedMs": 300,
        "maxElapsedMsWarn": 250
      }
    },
    {
      "id": "intent-query-set",
      "command": [
        "asp",
        "typescript",
        "search",
        "fzf",
        "--query-set",
        "handleHotUpdate",
        "--query-set",
        "createServer",
        "--query-set",
        "pluginContainer",
        "owner",
        "tests",
        "--view",
        "seeds",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-fzf]",
          "querySet=3",
          "entries=owner-query(O,Q=>items+tests+dependency-usage),owner-tests(O=>covering-tests+test-entrypoints+fixtures)"
        ],
        "maxStdoutLinesWarn": 14,
        "maxElapsedMs": 300,
        "maxElapsedMsWarn": 250
      }
    }
  ]
}
