{
  "id": "typescript.typescript-intent-matrix",
  "language": "typescript",
  "title": "TypeScript compiler large-library feature/API/principle intent matrix",
  "coverage": [
    "search-flow",
    "performance",
    "large-library"
  ],
  "tags": [
    "large-library",
    "typescript",
    "intent-matrix"
  ],
  "evidence": {
    "source": "handwritten",
    "fixtureTier": "large-library",
    "targetLibrary": {
      "language": "typescript",
      "name": "TypeScript",
      "package": "typescript",
      "repository": "microsoft/TypeScript",
      "workdirKind": "checkout"
    },
    "intentCases": [
      {
        "intentKind": "feature-implementation",
        "intent": "Implement or modify project reference behavior from compact compiler owners",
        "stepIds": [
          "prime-compiler",
          "intent-query-set"
        ],
        "queryTerms": [
          "projectReferences"
        ]
      },
      {
        "intentKind": "api-usage",
        "intent": "Find createProgram API usage and exported surface owners",
        "stepIds": [
          "prime-compiler",
          "intent-query-set"
        ],
        "queryTerms": [
          "createProgram"
        ]
      },
      {
        "intentKind": "implementation-principle",
        "intent": "Understand module resolution implementation paths without broad source reads",
        "stepIds": [
          "prime-compiler",
          "intent-query-set"
        ],
        "queryTerms": [
          "resolveModuleName"
        ]
      }
    ],
    "findings": [
      {
        "kind": "scoped-prime-required",
        "severity": "warning",
        "message": "Full-project search prime on the TypeScript compiler checkout exceeded the 30s sandtable step timeout; this matrix uses --package src/compiler to keep the first packet bounded."
      }
    ]
  },
  "workdir": {
    "env": "SANDTABLE_TS_TYPESCRIPT_ROOT",
    "candidates": [
      "~/ghq/github.com/microsoft/TypeScript",
      "~/src/TypeScript",
      "~/work/TypeScript"
    ]
  },
  "budgets": {
    "maxCommands": 2,
    "maxTotalLinesWarn": 24,
    "maxTotalStdoutBytesWarn": 10000
  },
  "steps": [
    {
      "id": "prime-compiler",
      "command": [
        "ts-harness",
        "search",
        "prime",
        "--package",
        "src/compiler",
        "--view",
        "seeds",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-prime]",
          "src/compiler",
          "analysis=structure",
          "nativeSyntaxFacts=skipped",
          "policyFindings=skipped",
          "entries=owner-query(O,Q=>items+tests+dependency-usage),owner-tests(O=>covering-tests+test-entrypoints+fixtures)"
        ],
        "maxStdoutLinesWarn": 10,
        "maxElapsedMsWarn": 18000
      }
    },
    {
      "id": "intent-query-set",
      "command": [
        "ts-harness",
        "search",
        "fzf",
        "--query-set",
        "projectReferences",
        "--query-set",
        "createProgram",
        "--query-set",
        "resolveModuleName",
        "owner",
        "tests",
        "--package",
        "src/compiler",
        "--view",
        "seeds",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-fzf]",
          "querySet=3",
          "entries=owner-query(O,Q=>items+tests+dependency-usage),owner-tests(O=>covering-tests+test-entrypoints+fixtures)"
        ],
        "maxStdoutLinesWarn": 14,
        "maxElapsedMsWarn": 9000
      }
    }
  ]
}
