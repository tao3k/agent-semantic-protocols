{
  "id": "typescript.typescript-intent-matrix",
  "language": "typescript",
  "title": "TypeScript compiler large-library feature/API/principle intent matrix",
  "coverage": [
    "search-flow",
    "performance",
    "large-library"
  ],
  "tags": [
    "large-library",
    "typescript",
    "intent-matrix"
  ],
  "evidence": {
    "source": "handwritten",
    "fixtureTier": "large-library",
    "targetLibrary": {
      "language": "typescript",
      "name": "TypeScript",
      "package": "typescript",
      "repository": "microsoft/TypeScript",
      "workdirKind": "checkout"
    },
    "intentCases": [
      {
        "intentKind": "feature-implementation",
        "intent": "Implement or modify project reference behavior from compact compiler owners",
        "stepIds": [
          "prime-compiler",
          "intent-query-set"
        ],
        "queryTerms": [
          "projectReferences"
        ]
      },
      {
        "intentKind": "api-usage",
        "intent": "Find createProgram API usage and exported surface owners",
        "stepIds": [
          "prime-compiler",
          "intent-query-set"
        ],
        "queryTerms": [
          "createProgram"
        ]
      },
      {
        "intentKind": "implementation-principle",
        "intent": "Understand module resolution implementation paths without broad source reads",
        "stepIds": [
          "prime-compiler",
          "intent-query-set"
        ],
        "queryTerms": [
          "resolveModuleName"
        ]
      }
    ],
    "deepQuestionCases": [
      {
        "id": "typescript-program-public-owner-strict",
        "question": "In the TypeScript compiler, can an agent locate createProgram public owners and the next selector in three ASP commands without running a full-project prime?",
        "stepIds": [
          "prime-compiler",
          "intent-query-set"
        ],
        "queryTerms": [
          "createProgram",
          "public",
          "owner"
        ],
        "audit": {
          "maxAspCommands": 3,
          "maxSearchCommands": 2,
          "maxQueryCommands": 1,
          "maxRepeatedCommands": 0,
          "requiresGraphSignals": true,
          "requiresQuerySet": true,
          "requiresHookEvents": true,
          "requiresTokenCost": true
        },
        "expectedAspFlow": {
          "requiredStages": [
            "search-prime",
            "search-pipe",
            "query-selector"
          ],
          "forbiddenStages": [
            "repeated-prime",
            "repeated-commands",
            "read-loop-risk"
          ]
        }
      },
      {
        "id": "typescript-module-resolution-deep-owner-flow",
        "question": "In the TypeScript compiler, how should an agent trace module resolution from project references through resolveModuleName owners and tests before proposing a behavior change?",
        "stepIds": [
          "prime-compiler",
          "intent-query-set"
        ],
        "queryTerms": [
          "projectReferences",
          "resolveModuleName",
          "tests"
        ],
        "audit": {
          "maxAspCommands": 8,
          "maxSearchCommands": 4,
          "maxQueryCommands": 4,
          "maxRepeatedCommands": 0,
          "requiresGraphSignals": true,
          "requiresQuerySet": true,
          "requiresHookEvents": true,
          "requiresComplexPipeFlow": true
        },
        "expectedAspFlow": {
          "requiredStages": [
            "search-prime",
            "search-pipe",
            "query-selector"
          ],
          "forbiddenStages": [
            "repeated-prime",
            "repeated-commands",
            "direct-read"
          ]
        }
      }
    ],
    "findings": [
      {
        "kind": "scoped-prime-required",
        "severity": "warning",
        "message": "Full-project search prime on the TypeScript compiler checkout exceeded the 30s sandtable step timeout; this matrix uses --package src/compiler to keep the first packet bounded."
      }
    ]
  },
  "workdir": {
    "env": "SANDTABLE_TS_TYPESCRIPT_ROOT",
    "candidates": [
      "~/ghq/github.com/microsoft/TypeScript",
      "~/src/TypeScript",
      "~/work/TypeScript"
    ]
  },
  "budgets": {
    "maxCommands": 4,
    "maxTotalLinesWarn": 42,
    "maxTotalStdoutBytesWarn": 20000
  },
  "steps": [
    {
      "id": "prime-compiler",
      "command": [
        "asp",
        "typescript",
        "search",
        "prime",
        "--package",
        "src/compiler",
        "--view",
        "seeds",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-prime]",
          "src/compiler",
          "analysis=structure",
          "nativeSyntaxFacts=skipped",
          "policyFindings=skipped",
          "entries=owner-query(O,Q=>items+tests+dependency-usage),owner-tests(O=>covering-tests+test-entrypoints+fixtures)"
        ],
        "maxStdoutLinesWarn": 10,
        "maxElapsedMs": 300,
        "maxElapsedMsWarn": 250
      }
    },
    {
      "id": "owner-program",
      "command": [
        "asp",
        "typescript",
        "search",
        "owner",
        "src/compiler/program.ts",
        "--view",
        "seeds",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-owner]",
          "src/compiler/program.ts",
          "entries=owner-tests(O=>covering-tests+test-entrypoints+fixtures)"
        ],
        "maxStdoutLinesWarn": 14,
        "maxElapsedMs": 300,
        "maxElapsedMsWarn": 250
      }
    },
    {
      "id": "deps-typescript",
      "command": [
        "asp",
        "typescript",
        "search",
        "deps",
        "typescript",
        "--view",
        "seeds",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-dependency]",
          "typescript",
          "frontier="
        ],
        "maxStdoutLinesWarn": 16,
        "maxElapsedMs": 300,
        "maxElapsedMsWarn": 250
      }
    },
    {
      "id": "intent-query-set",
      "command": [
        "asp",
        "typescript",
        "search",
        "lexical",
        "--query",
        "projectReferences",
        "--query",
        "createProgram",
        "--query",
        "resolveModuleName",
        "--query",
        "owner",
        "--query",
        "tests",
        "--package",
        "src/compiler",
        "--view",
        "seeds",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-lexical]",
          "querySet=3",
          "entries=owner-query(O,Q=>items+tests+dependency-usage),owner-tests(O=>covering-tests+test-entrypoints+fixtures)"
        ],
        "maxStdoutLinesWarn": 14,
        "maxElapsedMs": 300,
        "maxElapsedMsWarn": 250
      }
    }
  ]
}
