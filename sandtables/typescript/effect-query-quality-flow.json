    "deepQuestionCases": [
      {
        "id": "effect-high-concurrency-practices",
        "question": "In Effect 3.21.3, what repo-backed practices should a high-concurrency service use to bound fan-out, handle interruption/cancellation, choose between Effect.forEach concurrency, Queue, Stream, Fiber, and Scope, and avoid unbounded fiber or resource leaks?",
        "stepIds": [
          "effect-prime",
          "effect-concurrency-pipe",
          "effect-rg-query",
          "effect-primary-selector-code"
        ],
        "queryTerms": [
          "Effect",
          "concurrency",
          "Fiber",
          "Queue",
          "Stream",
          "Scope"
        ],
        "audit": {
          "maxAspCommands": 4,
          "maxSearchCommands": 3,
          "maxQueryCommands": 1,
          "maxRepeatedCommands": 0,
          "requiresGraphSignals": true,
          "requiresQuerySet": true,
          "requiresComplexPipeFlow": true
        },
        "expectedAspFlow": {
          "canonicalCommands": [
            "asp typescript search prime --view seeds .",
            "asp typescript search pipe 'Effect concurrency Fiber Queue Stream Scope' --view seeds .",
            "asp rg -query 'Fiber|Queue|Stream|Scope|concurrency|Runtime|Scheduler' .",
            "asp typescript query --selector packages/ai/ai/src/EmbeddingModel.ts:109:123 --workspace . --code"
          ],
          "requiredStages": [
            "search-prime",
            "search-pipe",
            "rg-query",
            "query-selector"
          ],
          "forbiddenStages": [
            "repeated-prime",
            "repeated-commands",
            "read-loop-risk",
            "direct-read"
          ],
          "notes": [
            "This sandbox fixes the provider-facing query quality contract behind the live Claude Effect flow without requiring ANTHROPIC_AUTH_TOKEN.",
          "The pipe step must expose handles and nextClasses for a second-stage LLM-generated rg/fd query; the final query step is the only code-producing command."
          ]
        }
      }
    ],
    "metrics": {
      "recordedCommandCount": 4,
      "aspCommands": 4,
      "searchCommands": 3,
      "queryCommands": 1,
      "directReadCommands": 0,
      "repeatedCommands": 0,
      "repeatedSearches": 0,
      "jsonSearches": 0,
      "compactSearches": 3,
      "tokenDelta": "lower"
    },
    "findings": [
      {
        "kind": "asp-pipe-surface-required",
        "severity": "info",
        "message": "TypeScript provider binaries own parser facts, but search pipe is an ASP facade surface. This sandbox intentionally uses asp typescript search pipe so Effect question quality is tested at the same boundary agents use."
      },
      {
        "kind": "locator-before-code",
        "severity": "info",
        "message": "The pipe output must cover all query terms, expose handles/nextClasses, and select the EmbeddingModel embedMany selector before the final pure-code query."
      },
      {
        "kind": "agent-benefit-gate",
        "severity": "info",
        "message": "The sandbox checks source-reading reduction, useful locator timing, feedback-learning via queryCoverage and seedPlan, and second-stage keyword packet behavior through rg -query; failure evidence is out of scope for this success-path Effect question but direct-read and repeated widening are forbidden."
      }
    ]
  },
  "steps": [
