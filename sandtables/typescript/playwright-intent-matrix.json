{
  "id": "typescript.playwright-intent-matrix",
  "language": "typescript",
  "title": "Playwright large-library feature/API/principle intent matrix",
  "coverage": [
    "search-flow",
    "performance",
    "large-library"
  ],
  "tags": [
    "large-library",
    "playwright",
    "intent-matrix"
  ],
  "evidence": {
    "source": "handwritten",
    "fixtureTier": "large-library",
    "targetLibrary": {
      "language": "typescript",
      "name": "Playwright",
      "package": "playwright",
      "repository": "microsoft/playwright",
      "workdirKind": "checkout"
    },
    "intentCases": [
      {
        "intentKind": "feature-implementation",
        "intent": "Implement trace or recorder behavior after finding compact feature owners",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "trace"
        ]
      },
      {
        "intentKind": "api-usage",
        "intent": "Find locator API usage and public surface owners",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "locator"
        ]
      },
      {
        "intentKind": "implementation-principle",
        "intent": "Understand browser context implementation paths from ranked search packets",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "BrowserContext"
        ]
      }
    ],
    "deepQuestionCases": [
      {
        "id": "playwright-fixture-lifecycle-owner-frontier",
        "question": "In Playwright, how should an agent locate the fixture lifecycle and worker/test scope owners before changing setup or teardown behavior?",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "fixture",
          "testInfo",
          "worker",
          "scope"
        ],
        "audit": {
          "maxAspCommands": 6,
          "maxSearchCommands": 3,
          "maxQueryCommands": 3,
          "maxRepeatedCommands": 0,
          "requiresGraphSignals": true,
          "requiresQuerySet": true,
          "requiresHookEvents": true
        },
        "expectedAspFlow": {
          "requiredStages": [
            "search-prime",
            "search-pipe",
            "query-selector"
          ],
          "forbiddenStages": [
            "repeated-prime",
            "repeated-commands"
          ]
        }
      },
      {
        "id": "playwright-trace-viewer-owner-deep",
        "question": "In Playwright, how should an agent connect trace collection, trace viewer rendering, and BrowserContext ownership before changing trace output semantics?",
        "stepIds": [
          "prime",
          "intent-query-set"
        ],
        "queryTerms": [
          "trace",
          "trace viewer",
          "BrowserContext"
        ],
        "audit": {
          "maxAspCommands": 8,
          "maxSearchCommands": 4,
          "maxQueryCommands": 4,
          "maxRepeatedCommands": 0,
          "requiresGraphSignals": true,
          "requiresQuerySet": true,
          "requiresHookEvents": true,
          "requiresComplexPipeFlow": true
        },
        "expectedAspFlow": {
          "requiredStages": [
            "search-prime",
            "search-pipe",
            "query-selector"
          ],
          "forbiddenStages": [
            "repeated-prime",
            "repeated-commands",
            "direct-read"
          ]
        }
      }
    ]
  },
  "workdir": {
    "env": "SANDTABLE_TS_PLAYWRIGHT_ROOT",
    "candidates": [
      "~/ghq/github.com/microsoft/playwright",
      "~/src/playwright",
      "~/work/playwright"
    ]
  },
  "budgets": {
    "maxCommands": 2,
    "maxTotalLinesWarn": 24,
    "maxTotalStdoutBytesWarn": 16000
  },
  "steps": [
    {
      "id": "prime",
      "command": [
        "ts-harness",
        "search",
        "prime",
        "--view",
        "seeds",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-prime]",
          "analysis=structure",
          "nativeSyntaxFacts=skipped",
          "policyFindings=skipped",
          "entries=owner-query(O,Q=>items+tests+dependency-usage),owner-tests(O=>covering-tests+test-entrypoints+fixtures)"
        ],
        "maxStdoutLinesWarn": 16,
        "maxElapsedMsWarn": 20000
      }
    },
    {
      "id": "intent-query-set",
      "command": [
        "ts-harness",
        "search",
        "fzf",
        "--query-set",
        "trace",
        "--query-set",
        "locator",
        "--query-set",
        "BrowserContext",
        "owner",
        "tests",
        "--view",
        "seeds",
        "--workspace",
        "."
      ],
      "expect": {
        "lineProtocol": true,
        "stdoutContains": [
          "[search-fzf]",
          "querySet=3",
          "entries=owner-query(O,Q=>items+tests+dependency-usage),owner-tests(O=>covering-tests+test-entrypoints+fixtures)"
        ],
        "maxStdoutLinesWarn": 14,
        "maxElapsedMsWarn": 9000
      }
    }
  ]
}
