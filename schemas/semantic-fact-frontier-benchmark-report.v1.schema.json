{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-fact-frontier-benchmark-report.v1.schema.json",
  "title": "Semantic Fact Frontier Benchmark Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "reportId",
    "sourceReceiptFixtureCatalog",
    "sourceBenchmarkFixture",
    "scenarios",
    "summary"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-fact-frontier-benchmark-report"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.semantic-fact-frontier-feedback"
    },
    "protocolVersion": {
      "const": "1"
    },
    "reportId": {
      "type": "string",
      "minLength": 1
    },
    "sourceReceiptFixtureCatalog": {
      "type": "string",
      "minLength": 1
    },
    "sourceBenchmarkFixture": {
      "type": "string",
      "minLength": 1
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scenario"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenarioId",
        "captureKind",
        "receiptFixtureId",
        "receiptId",
        "goldContext",
        "receiptMetrics",
        "benchmarkMetrics",
        "contextMetrics",
        "benchmarkReadiness"
      ],
      "properties": {
        "scenarioId": {
          "type": "string",
          "minLength": 1
        },
        "captureKind": {
          "enum": [
            "task-session",
            "graph-turbo-runtime",
            "asp-runtime-frontier",
            "asp-runtime-followed-frontier"
          ]
        },
        "receiptFixtureId": {
          "type": "string",
          "minLength": 1
        },
        "receiptId": {
          "type": "string",
          "minLength": 1
        },
        "goldContext": {
          "$ref": "#/$defs/goldContext"
        },
        "receiptMetrics": {
          "$ref": "#/$defs/receiptMetrics"
        },
        "benchmarkMetrics": {
          "$ref": "#/$defs/benchmarkMetrics"
        },
        "contextMetrics": {
          "$ref": "#/$defs/contextMetrics"
        },
        "benchmarkReadiness": {
          "$ref": "#/$defs/benchmarkReadiness"
        }
      }
    },
    "goldContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "goldFrontierNodeIds",
        "goldSelectors",
        "goldTestAction"
      ],
      "properties": {
        "goldFrontierNodeIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "goldSelectors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "goldTestAction": {
          "$ref": "#/$defs/goldTestAction"
        }
      }
    },
    "goldTestAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "argv",
        "expectedStatus"
      ],
      "properties": {
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "expectedStatus": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "receiptMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "frontierReturnedCount",
        "frontierFollowedCount",
        "frontierFollowRate",
        "codeActuallyReadCount",
        "rawReadFallbackCount",
        "duplicateSelectorCount",
        "sameOwnerScanCount",
        "relationChannelCount",
        "pprIterations",
        "pprResidual",
        "stdoutBytesToFrontier",
        "commandsToFirstUsefulLocator",
        "commandsToValidation"
      ],
      "properties": {
        "frontierReturnedCount": {
          "type": "integer",
          "minimum": 0
        },
        "frontierFollowedCount": {
          "type": "integer",
          "minimum": 0
        },
        "frontierFollowRate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "codeActuallyReadCount": {
          "type": "integer",
          "minimum": 0
        },
        "rawReadFallbackCount": {
          "type": "integer",
          "minimum": 0
        },
        "duplicateSelectorCount": {
          "type": "integer",
          "minimum": 0
        },
        "sameOwnerScanCount": {
          "type": "integer",
          "minimum": 0
        },
        "relationChannelCount": {
          "type": "integer",
          "minimum": 0
        },
        "pprIterations": {
          "type": "integer",
          "minimum": 0
        },
        "pprResidual": {
          "type": "number",
          "minimum": 0
        },
        "stdoutBytesToFrontier": {
          "type": "integer",
          "minimum": 0
        },
        "commandsToFirstUsefulLocator": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "commandsToValidation": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "benchmarkMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "cacheMode",
        "pathBackend",
        "pathPairCount",
        "pathCandidateCount",
        "pathFallbackCount",
        "projectedTypedPathCount",
        "relationChannelCount",
        "pprIterations",
        "pprResidual",
        "medianMs",
        "p95Ms"
      ],
      "properties": {
        "profile": {
          "type": "string",
          "minLength": 1
        },
        "cacheMode": {
          "enum": [
            "disabled",
            "enabled",
            "hit"
          ]
        },
        "pathBackend": {
          "type": "string",
          "minLength": 1
        },
        "pathPairCount": {
          "type": "integer",
          "minimum": 0
        },
        "pathCandidateCount": {
          "type": "integer",
          "minimum": 0
        },
        "pathFallbackCount": {
          "type": "integer",
          "minimum": 0
        },
        "projectedTypedPathCount": {
          "type": "integer",
          "minimum": 0
        },
        "relationChannelCount": {
          "type": "integer",
          "minimum": 0
        },
        "pprIterations": {
          "type": "integer",
          "minimum": 0
        },
        "pprResidual": {
          "type": "number",
          "minimum": 0
        },
        "medianMs": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "p95Ms": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "contextMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "goldFrontierCount",
        "emittedFrontierCount",
        "goldFrontierHitCount",
        "followedGoldFrontierCount",
        "goldSelectorReadCount",
        "contextPrecision",
        "contextRecall",
        "contextUtilization",
        "exactCodeSuccess",
        "testSelectionPrecision"
      ],
      "properties": {
        "goldFrontierCount": {
          "type": "integer",
          "minimum": 0
        },
        "emittedFrontierCount": {
          "type": "integer",
          "minimum": 0
        },
        "goldFrontierHitCount": {
          "type": "integer",
          "minimum": 0
        },
        "goldFrontierBestRank": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "goldSelectorActionRank": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "followedGoldFrontierCount": {
          "type": "integer",
          "minimum": 0
        },
        "goldSelectorReadCount": {
          "type": "integer",
          "minimum": 0
        },
        "contextPrecision": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "contextRecall": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "contextUtilization": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "exactCodeSuccess": {
          "type": "boolean"
        },
        "testSelectionPrecision": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "benchmarkReadiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hasFollowedFrontier",
        "hasValidationCommand",
        "hasRuntimeCapture",
        "readyForWeightCalibration"
      ],
      "properties": {
        "hasFollowedFrontier": {
          "type": "boolean"
        },
        "hasValidationCommand": {
          "type": "boolean"
        },
        "hasRuntimeCapture": {
          "type": "boolean"
        },
        "readyForWeightCalibration": {
          "type": "boolean"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenarioCount",
        "receiptFixtureCount",
        "minFrontierFollowRate",
        "maxRawReadFallbackCount",
        "allRelationChannelsVisible",
        "runtimeCaptureScenarioCount",
        "calibrationReadyScenarioCount",
        "nextAction"
      ],
      "properties": {
        "scenarioCount": {
          "type": "integer",
          "minimum": 0
        },
        "receiptFixtureCount": {
          "type": "integer",
          "minimum": 0
        },
        "minFrontierFollowRate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "maxRawReadFallbackCount": {
          "type": "integer",
          "minimum": 0
        },
        "allRelationChannelsVisible": {
          "type": "boolean"
        },
        "runtimeCaptureScenarioCount": {
          "type": "integer",
          "minimum": 0
        },
        "calibrationReadyScenarioCount": {
          "type": "integer",
          "minimum": 0
        },
        "weightCalibrationDecision": {
          "$ref": "#/$defs/weightCalibrationDecision"
        },
        "nextAction": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "weightCalibrationDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reason",
        "requiredEvidence"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "deferred-until-new-failing-receipt"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "requiredEvidence": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
