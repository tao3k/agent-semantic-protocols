{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-compact-graph-render.v1.schema.json",
  "title": "Semantic Compact Graph Render Template",
  "description": "Shared agent-facing compact graph render template for search --view seeds output. This schema owns the line grammar and action alias vocabulary that language providers implement.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "renderKind",
    "sourcePacketSchemaId",
    "lineGrammar",
    "headerFields",
    "actionSpecs",
    "relationSpecs"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-compact-graph-render"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.semantic-language"
    },
    "protocolVersion": {
      "const": "1"
    },
    "renderKind": {
      "const": "compact-graph-render-template"
    },
    "sourcePacketSchemaId": {
      "const": "agent.semantic-protocols.semantic-search-packet"
    },
    "lineGrammar": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "header",
        "legend",
        "alias",
        "edge",
        "groupedEdge",
        "rankFrontier",
        "denseAliasSeparator"
      ],
      "properties": {
        "header": {
          "const": "[search-<view>] (q=<query>|root=<root>) [querySet=<n>] [selector=<selector>] [scope=<scope>] alg=<algorithm>"
        },
        "legend": {
          "const": "alias: graph:{<ID>=<nodeType>,...}"
        },
        "alias": {
          "const": "<ID>=<nodeType>:<target>!<action>"
        },
        "edge": {
          "const": "<SRC>{<DST>:<relation>,...}"
        },
        "groupedEdge": {
          "const": "(<SRC>,...)><DST>:<relation>"
        },
        "rankFrontier": {
          "const": "rank=<ID>,... frontier=<ID>.<action>,..."
        },
        "denseAliasSeparator": {
          "const": ";"
        }
      }
    },
    "headerFields": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "algorithm", "retained"],
      "properties": {
        "identity": {
          "type": "array",
          "minItems": 2,
          "items": {
            "enum": ["q", "root"]
          },
          "contains": {
            "const": "q"
          }
        },
        "algorithm": {
          "const": "alg"
        },
        "retained": {
          "type": "array",
          "items": {
            "enum": ["querySet", "selector", "scope"]
          },
          "uniqueItems": true
        }
      }
    },
    "actionSpecs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/actionSpec"
      }
    },
    "relationSpecs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/relationSpec"
      }
    }
  },
  "$defs": {
    "actionSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceKind", "nodeType", "aliasPrefix", "action"],
      "properties": {
        "sourceKind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "nodeType": {
          "enum": [
            "owner",
            "test",
            "symbol",
            "query",
            "dependency",
            "doc",
            "feature",
            "cfg",
            "import",
            "package",
            "finding",
            "item",
            "search",
            "custom"
          ]
        },
        "aliasPrefix": {
          "type": "string",
          "pattern": "^[A-Z]$"
        },
        "action": {
          "enum": [
            "owner",
            "tests",
            "symbol",
            "query",
            "fzf",
            "deps",
            "docs",
            "features",
            "cfg",
            "import",
            "items",
            "code",
            "read"
          ]
        }
      }
    },
    "relationSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targetNodeType",
        "relation"
      ],
      "properties": {
        "targetNodeType": {
          "enum": [
            "owner",
            "test",
            "symbol",
            "query",
            "dependency",
            "doc",
            "feature",
            "cfg",
            "import",
            "package",
            "finding",
            "item",
            "search",
            "custom"
          ]
        },
        "relation": {
          "enum": [
            "selects",
            "matches",
            "covers",
            "uses",
            "imports",
            "contains",
            "explains",
            "flags",
            "gates"
          ]
        }
      }
    }
  }
}
