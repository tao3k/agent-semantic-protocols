{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tao3k.github.io/agent-semantic-protocols/schemas/provider-workspace-install.v1.schema.json",
  "title": "Provider Workspace Install Descriptor v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "schemaAuthority",
    "providerId",
    "binary",
    "workspaceArtifact",
    "workspaceBuild"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.provider-workspace-install"
    },
    "schemaVersion": {
      "const": "1"
    },
    "schemaAuthority": {
      "const": "https://tao3k.github.io/agent-semantic-protocols/schemas/"
    },
    "providerId": {
      "type": "string",
      "minLength": 1
    },
    "binary": {
      "type": "string",
      "minLength": 1
    },
    "workspaceArtifact": {
      "$ref": "#/$defs/workspaceArtifact"
    },
    "workspaceBuild": {
      "$ref": "#/$defs/workspaceBuild"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "workspaceArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root",
        "entrypoint"
      ],
      "properties": {
        "root": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "entrypoint": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "launch": {
          "$ref": "#/$defs/workspaceArtifactLaunch"
        }
      }
    },
    "workspaceArtifactLaunch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "program",
        "args",
        "programRelativeToArtifact",
        "argsRelativeToArtifact"
      ],
      "properties": {
        "program": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "args": {
          "$ref": "#/$defs/stringArray"
        },
        "programRelativeToArtifact": {
          "type": "boolean"
        },
        "argsRelativeToArtifact": {
          "type": "boolean"
        }
      }
    },
    "workspaceBuild": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "program",
        "args",
        "workingDirectory",
        "derivedPaths",
        "env"
      ],
      "properties": {
        "program": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "args": {
          "$ref": "#/$defs/stringArray"
        },
        "workingDirectory": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "derivedPaths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    }
  }
}
