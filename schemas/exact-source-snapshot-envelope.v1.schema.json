{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.dev/schemas/exact-source-snapshot-envelope.v1.schema.json",
  "title": "ASP Exact Source Snapshot Envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "providerId",
    "sourceSnapshot",
    "casRoot",
    "owners"
  ],
  "properties": {
    "schemaId": {
      "const": "asp.exact-source-snapshot-envelope.v1"
    },
    "schemaVersion": {
      "const": "1"
    },
    "providerId": {
      "type": "string",
      "minLength": 1
    },
    "sourceSnapshot": {
      "type": "object",
      "required": [
        "schemaId",
        "algorithm",
        "rootDigest",
        "sourceKind",
        "leafCount",
        "providerDigest"
      ]
    },
    "casRoot": {
      "type": "string",
      "minLength": 1
    },
    "owners": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/owner"
      }
    }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "snapshotLeafDigest",
        "blobDigest",
        "sourceContentDigest",
        "casPath"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "snapshotLeafDigest": {
          "$ref": "#/$defs/digest"
        },
        "blobDigest": {
          "$ref": "#/$defs/digest"
        },
        "sourceContentDigest": {
          "$ref": "#/$defs/digest"
        },
        "casPath": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
