{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://agent-semantic-protocols.local/schemas/semantic-graph-turbo-ablation-set.v1.schema.json",
    "title": "Semantic graph turbo ablation set",
    "description": "Graph-turbo request variants used to calibrate sandtable ranking quality.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "schemaId",
        "schemaVersion",
        "protocolId",
        "protocolVersion",
        "packetKind",
        "sourceProfile",
        "variants"
    ],
    "properties": {
        "schemaId": {
            "const": "agent.semantic-protocols.semantic-graph-turbo-ablation-set"
        },
        "schemaVersion": {
            "const": "1"
        },
        "protocolId": {
            "const": "agent.semantic-protocols.semantic-language"
        },
        "protocolVersion": {
            "const": "1"
        },
        "packetKind": {
            "const": "graph-turbo-ablation-set"
        },
        "sourceProfile": {
            "type": [
                "string",
                "null"
            ]
        },
        "variants": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "variant",
                    "changes",
                    "packet"
                ],
                "properties": {
                    "variant": {
                        "enum": [
                            "full",
                            "no-receipt",
                            "no-read-memory",
                            "no-quality-fields",
                            "no-provider-facts",
                            "relation-weight-flat",
                            "no-query-seed-prior",
                            "no-package-cohesion",
                            "no-query-clause-coverage"
                        ]
                    },
                    "changes": {
                        "type": "object"
                    },
                    "packet": {
                        "type": "object",
                        "required": [
                            "schemaId",
                            "schemaVersion",
                            "protocolId",
                            "protocolVersion",
                            "packetKind",
                            "graph"
                        ],
                        "properties": {
                            "schemaId": {
                                "const": "agent.semantic-protocols.semantic-graph-turbo-request"
                            },
                            "schemaVersion": {
                                "const": "1"
                            },
                            "protocolId": {
                                "const": "agent.semantic-protocols.semantic-language"
                            },
                            "protocolVersion": {
                                "const": "1"
                            },
                            "packetKind": {
                                "const": "graph-turbo-request"
                            },
                            "graph": {
                                "type": "object"
                            }
                        }
                    }
                }
            }
        }
    }
}
