{
  "schemaId": "agent.semantic-protocols.software-criterion-catalog",
  "schemaVersion": "1",
  "protocolId": "agent.semantic-protocols.software-criterion",
  "protocolVersion": "1",
  "criterionSetId": "software-criterion.v1.control-flow",
  "description": "Legacy-named software criterion canon for cross-language control-flow and native-idiom navigation vocabulary; ecosystem doctrine is provider-owned criterion extension policy.",
  "sourceVersion": "docs/10-19-rfcs/10.13-software-criterion-policy.org#013",
  "criteria": [
    {
      "criterionId": "control-flow.decision-stack",
      "domain": "control-flow",
      "title": "Decision stack",
      "agentRisk": "Agent must retain nested predicates and terminal paths before editing one branch.",
      "sourceEvidence": [
        {
          "kind": "official-manual",
          "claim": "Native control-flow constructs should make branch intent and exhaustiveness visible."
        },
        {
          "kind": "parser-fact",
          "claim": "Providers can measure nesting depth, branch count, terminal else paths, and match or switch usage."
        }
      ],
      "parserFacts": [
        {
          "factKey": "max_nesting_depth"
        },
        {
          "factKey": "terminal_else_count"
        },
        {
          "factKey": "match_count"
        }
      ],
      "repairRecipes": [
        {
          "recipeId": "control-flow.guard-clauses",
          "summary": "Prefer guard clauses and named predicates when they expose the decision model."
        },
        {
          "recipeId": "control-flow.typed-dispatch",
          "summary": "Use enum, match, case, switch, discriminated union, or dispatch where the finite domain is real."
        }
      ],
      "defaultSeverity": "info",
      "promotable": true,
      "promotionPolicy": [
        {
          "targetSeverity": "blocking-candidate",
          "requiredEvidence": [
            "official-manual",
            "parser-fact",
            "self-fixture",
            "real-project-evidence"
          ],
          "requiresFixture": true,
          "requiresRealProjectEvidence": true,
          "description": "Blocking requires parser proof, fixture stability, and real-project repair value."
        }
      ]
    },
    {
      "criterionId": "control-flow.traversal-knot",
      "domain": "control-flow",
      "title": "Traversal knot",
      "agentRisk": "Traversal, filtering, accumulation, and failure handling are interleaved, making local edits unsafe.",
      "sourceEvidence": [
        {
          "kind": "official-manual",
          "claim": "Language-native iteration and phase boundaries make algorithm intent easier to verify."
        },
        {
          "kind": "agent-code-research",
          "claim": "LLM-generated code needs static feedback on maintainability risks beyond functional correctness."
        }
      ],
      "parserFacts": [
        {
          "factKey": "nested_loop_count"
        },
        {
          "factKey": "loop_with_branch_count"
        },
        {
          "factKey": "accumulator_mutation_count"
        }
      ],
      "repairRecipes": [
        {
          "recipeId": "control-flow.named-phases",
          "summary": "Split traversal, predicate, accumulator, and failure phases into named boundaries."
        }
      ],
      "defaultSeverity": "info",
      "promotable": true
    },
    {
      "criterionId": "control-flow.literal-dispatch-chain",
      "domain": "control-flow",
      "title": "Literal dispatch chain",
      "agentRisk": "A finite domain is hidden in string, number, or bool branches instead of a visible domain model.",
      "sourceEvidence": [
        {
          "kind": "official-manual",
          "claim": "Pattern matching, discriminated unions, enums, and dispatch make finite domains explicit."
        },
        {
          "kind": "community-practice",
          "claim": "Typed mode and state boundaries reduce runtime flag drift in long-lived code."
        }
      ],
      "parserFacts": [
        {
          "factKey": "literal_comparison_count"
        },
        {
          "factKey": "branch_chain_length"
        },
        {
          "factKey": "discriminant_model_present"
        }
      ],
      "repairRecipes": [
        {
          "recipeId": "domain-type.visible-finite-domain",
          "summary": "Move finite modes into an enum, tagged union, pattern match, dispatch type, or equivalent language-native model."
        }
      ],
      "defaultSeverity": "info",
      "promotable": true
    },
    {
      "criterionId": "control-flow.broad-linear-phase",
      "domain": "control-flow",
      "title": "Broad linear phase",
      "agentRisk": "A long flat function hides multiple algorithm phases behind statement order.",
      "sourceEvidence": [
        {
          "kind": "parser-fact",
          "claim": "Providers can count statements, mutation groups, and mixed phase operations."
        },
        {
          "kind": "agent-code-research",
          "claim": "Localization and repair improve when code exposes bounded edit surfaces."
        }
      ],
      "parserFacts": [
        {
          "factKey": "statement_count"
        },
        {
          "factKey": "phase_transition_count"
        },
        {
          "factKey": "local_mutation_group_count"
        }
      ],
      "repairRecipes": [
        {
          "recipeId": "owner-boundary.extract-private-phases",
          "summary": "Extract parse, validate, transform, render, and verify phases behind private helpers while preserving the public API."
        }
      ],
      "defaultSeverity": "info",
      "promotable": true
    },
    {
      "criterionId": "native-idiom.manual-transform-loop",
      "domain": "native-idiom",
      "title": "Manual native transform loop",
      "agentRisk": "A common map, filter, count, sum, or collect transform is encoded with mutable loop state.",
      "sourceEvidence": [
        {
          "kind": "official-manual",
          "claim": "Language-native collection transforms reduce boilerplate while preserving intent."
        },
        {
          "kind": "parser-fact",
          "claim": "Providers can detect accumulator loops without domain-specific side effects."
        }
      ],
      "parserFacts": [
        {
          "factKey": "manual_loop_count"
        },
        {
          "factKey": "accumulator_kind"
        },
        {
          "factKey": "side_effect_boundary_present"
        }
      ],
      "repairRecipes": [
        {
          "recipeId": "native-idiom.collection-transform",
          "summary": "Use the language-native iterator, comprehension, generator, map, filter, reduce, or broadcast form when it keeps the domain clear."
        }
      ],
      "defaultSeverity": "info",
      "promotable": true
    },
    {
      "criterionId": "error-resource.hidden-boundary",
      "domain": "error-resource",
      "title": "Hidden error or resource boundary",
      "agentRisk": "Error, resource, cleanup, or async state behavior is hidden inside branch shape instead of a visible API or type boundary.",
      "sourceEvidence": [
        {
          "kind": "community-practice",
          "claim": "Typed error channels, resource scopes, and actor or message boundaries keep failure and concurrency semantics visible."
        },
        {
          "kind": "parser-fact",
          "claim": "Providers can detect broad catch or except blocks, unchecked public failures, split acquire/release paths, and mixed async state."
        }
      ],
      "parserFacts": [
        {
          "factKey": "broad_error_handler_count"
        },
        {
          "factKey": "unchecked_public_failure_count"
        },
        {
          "factKey": "resource_lifetime_split_count"
        }
      ],
      "repairRecipes": [
        {
          "recipeId": "error-resource.visible-boundary",
          "summary": "Introduce a typed error, result, effect, resource scope, or actor boundary that makes the failure or lifetime contract visible."
        }
      ],
      "defaultSeverity": "info",
      "promotable": true
    }
  ],
