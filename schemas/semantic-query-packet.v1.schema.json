{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-query-packet.v1.schema.json",
  "title": "Semantic Query Packet",
  "description": "Provider-native parser query packet for compact code extraction.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "languageId",
    "providerId",
    "binary",
    "namespace",
    "method",
    "projectRoot",
    "query",
    "queryTerms",
    "matches",
    "truncated"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-query-packet"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.semantic-language"
    },
    "protocolVersion": {
      "const": "1"
    },
    "languageId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "providerId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "binary": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "namespace": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
    },
    "method": {
      "type": "string",
      "pattern": "^query/[a-z][a-z0-9_-]*$"
    },
    "projectRoot": {
      "type": "string",
      "minLength": 1
    },
    "packageName": {
      "type": "string",
      "minLength": 1
    },
    "ownerPath": {
      "$ref": "#/$defs/projectPath"
    },
    "query": {
      "type": "string",
      "minLength": 1
    },
    "queryTerms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "matchMode": {
      "enum": ["exact", "fallback-contains", "mixed", "unknown"]
    },
    "matches": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/match"
      }
    },
    "truncated": {
      "type": "boolean"
    },
    "notes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/note"
      }
    }
  },
  "$defs": {
    "projectPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:\\.|(?!/)(?![A-Za-z]:)(?![0-9]+:)(?!\\.\\.?($|/))(?!.*(^|/)\\.\\.?($|/))(?!.*//)[^\\s:\\\\]+(?:/[^\\s:\\\\]+)*)$"
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "line", "endLine"],
      "properties": {
        "path": {
          "$ref": "#/$defs/projectPath"
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "endLine": {
          "type": "integer",
          "minimum": 1
        },
        "column": {
          "type": "integer",
          "minimum": 1
        },
        "endColumn": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind", "location", "code", "truncated"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "visibility": {
          "enum": ["public", "private", "unknown"]
        },
        "doc": {
          "type": "boolean"
        },
        "location": {
          "$ref": "#/$defs/location"
        },
        "read": {
          "type": "string",
          "pattern": "^(?:\\.|(?!/)(?![A-Za-z]:)(?![0-9]+:)(?!\\.\\.?($|/))(?!.*(^|/)\\.\\.?($|/))(?!.*//)[^\\s:\\\\]+(?:/[^\\s:\\\\]+)*):[1-9][0-9]*-[1-9][0-9]*$"
        },
        "code": {
          "type": "string",
          "description": "Agent-facing compact code. Blank lines are omitted and each retained line is trimmed."
        },
        "truncated": {
          "type": "boolean"
        },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "boolean" }
            ]
          }
        }
      }
    },
    "note": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "message"],
      "properties": {
        "kind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
