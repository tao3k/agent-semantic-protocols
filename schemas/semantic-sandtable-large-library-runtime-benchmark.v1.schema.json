{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.dev/schemas/semantic-sandtable-large-library-runtime-benchmark.v1.schema.json",
  "title": "Large library runtime benchmark receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "packetKind",
    "status",
    "binary",
    "workspaceDeployments",
    "corpora",
    "missingCorpora",
    "commandCoverage",
    "summary",
    "warmups",
    "steps"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-sandtable-large-library-runtime-benchmark"
    },
    "schemaVersion": { "const": "1" },
    "packetKind": { "const": "large-library-runtime-benchmark" },
    "status": { "enum": ["pass", "warn", "fail"] },
    "binary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "releaseVerified"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "releaseVerified": { "type": "boolean" }
      }
    },
    "workspaceDeployments": {
      "type": "array",
      "items": { "$ref": "#/$defs/workspaceDeployment" }
    },
    "corpora": {
      "type": "array",
      "items": { "$ref": "#/$defs/corpus" }
    },
    "missingCorpora": {
      "type": "array",
      "items": { "$ref": "#/$defs/missingCorpus" }
    },
    "commandCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registeredSearchMethodCount",
        "targetSearchCommandCount",
        "runtimeSearchCommandCount",
        "registeredMethods",
        "runtimeMethods",
        "missingMethods",
        "missingCorpusMethods"
      ],
      "properties": {
        "registeredSearchMethodCount": { "type": "integer", "minimum": 0 },
        "targetSearchCommandCount": { "type": "integer", "minimum": 0 },
        "runtimeSearchCommandCount": { "type": "integer", "minimum": 0 },
        "registeredMethods": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "runtimeMethods": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "missingMethods": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "missingCorpusMethods": {
          "type": "array",
          "items": { "$ref": "#/$defs/missingCorpusMethod" }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scenarioCount", "stepCount", "failureCount", "warningCount", "maxElapsedMs"],
      "properties": {
        "scenarioCount": { "type": "integer", "minimum": 0 },
        "stepCount": { "type": "integer", "minimum": 0 },
        "failureCount": { "type": "integer", "minimum": 0 },
        "warningCount": { "type": "integer", "minimum": 0 },
        "maxElapsedMs": { "type": "integer", "minimum": 0 }
      }
    },
    "warmups": {
      "type": "array",
      "items": { "$ref": "#/$defs/warmup" }
    },
    "steps": {
      "type": "array",
      "items": { "$ref": "#/$defs/step" }
    }
  },
  "$defs": {
    "workspaceDeployment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "language",
        "command",
        "status",
        "elapsedMs",
        "stdoutBytes",
        "stderrBytes",
        "errors"
      ],
      "properties": {
        "language": { "type": "string", "minLength": 1 },
        "command": {
          "type": "array",
          "minItems": 5,
          "items": { "type": "string", "minLength": 1 }
        },
        "status": { "enum": ["pass", "fail"] },
        "elapsedMs": { "type": "integer", "minimum": 0 },
        "stdoutBytes": { "type": "integer", "minimum": 0 },
        "stderrBytes": { "type": "integer", "minimum": 0 },
        "errors": { "type": "array", "items": { "type": "string" } }
      }
    },
    "corpus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scenarioId", "language", "repository", "path", "revision"],
      "properties": {
        "scenarioId": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 1 },
        "repository": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "revision": { "type": "string", "minLength": 1 }
      }
    },
    "missingCorpus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scenarioId", "language", "repository", "path", "reason"],
      "properties": {
        "scenarioId": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 1 },
        "repository": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "missingCorpusMethod": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scenarioId", "language", "method"],
      "properties": {
        "scenarioId": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 1 },
        "method": { "type": "string", "pattern": "^search/" }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenarioId",
        "language",
        "method",
        "stepId",
        "command",
        "status",
        "executed",
        "elapsedMs",
        "maxElapsedMs",
        "stdoutBytes",
        "stderrBytes",
        "processTreeTerminated",
        "warnings",
        "errors"
      ],
      "properties": {
        "scenarioId": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 1 },
        "method": { "type": "string", "minLength": 1 },
        "stepId": { "type": "string", "minLength": 1 },
        "command": {
          "type": "array",
          "minItems": 3,
          "items": { "type": "string", "minLength": 1 }
        },
        "status": { "enum": ["pass", "warn", "fail"] },
        "executed": { "type": "boolean" },
        "elapsedMs": { "type": "integer", "minimum": 0 },
        "maxElapsedMs": { "type": "integer", "minimum": 0 },
        "stdoutBytes": { "type": "integer", "minimum": 0 },
        "stderrBytes": { "type": "integer", "minimum": 0 },
        "processTreeTerminated": { "type": "boolean" },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "errors": { "type": "array", "items": { "type": "string" } }
      }
    },
    "warmup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenarioId",
        "language",
        "method",
        "command",
        "status",
        "elapsedMs"
      ],
      "properties": {
        "scenarioId": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 1 },
        "method": { "type": "string", "minLength": 1 },
        "command": {
          "type": "array",
          "minItems": 3,
          "items": { "type": "string", "minLength": 1 }
        },
        "status": { "enum": ["pass", "warn", "fail"] },
        "elapsedMs": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
