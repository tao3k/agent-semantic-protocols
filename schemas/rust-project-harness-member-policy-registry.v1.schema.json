{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.dev/schemas/rust-project-harness-member-policy-registry.v1.schema.json",
  "title": "Rust Project Harness Member Policy Registry v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "harness_execution",
    "members"
  ],
  "properties": {
    "schema_id": {
      "const": "rust-lang-project-harness.member-policy-registry"
    },
    "schema_version": {
      "const": "1"
    },
    "harness_execution": {
      "$ref": "#/$defs/harnessExecution"
    },
    "members": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/memberPolicy"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "$defs": {
    "harnessExecution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runner_package",
        "runner_version",
        "prepare_command"
      ],
      "properties": {
        "runner_package": {
          "const": "rust-project-harness-policy-runner"
        },
        "runner_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$"
        },
        "prepare_command": {
          "type": "array",
          "prefixItems": [
            { "const": "cargo" },
            { "const": "run" },
            { "const": "-p" },
            { "const": "rust-project-harness-policy-runner" },
            { "const": "--" },
            { "const": "prepare" },
            { "const": "--workspace-root" },
            { "const": "." },
            { "const": "--package" },
            { "const": "{cargo-package-name}" }
          ],
          "minItems": 10,
          "maxItems": 10
        }
      }
    },
    "memberPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package",
        "package_directory",
        "gate_label",
        "snapshot_excludes",
        "agent_advice_allow_explanation",
        "cargo_check_advice_allow_explanation",
        "cargo_test_advice_allow_explanation",
        "rule_severity_overrides",
        "verification_skills",
        "owners",
        "dependency_baseline_packages"
      ],
      "properties": {
        "package": {
          "type": "string",
          "minLength": 1
        },
        "package_directory": {
          "type": "string",
          "minLength": 1
        },
        "gate_label": {
          "type": "string",
          "minLength": 1
        },
        "snapshot_excludes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "agent_advice_allow_explanation": {
          "type": ["string", "null"]
        },
        "cargo_check_advice_allow_explanation": {
          "type": ["string", "null"]
        },
        "cargo_test_advice_allow_explanation": {
          "type": ["string", "null"]
        },
        "rule_severity_overrides": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ruleSeverityOverride"
          },
          "uniqueItems": true
        },
        "verification_skills": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verificationSkill"
          },
          "uniqueItems": true
        },
        "owners": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ownerPolicy"
          },
          "uniqueItems": true
        },
        "dependency_baseline_packages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dependencyBaselinePackage"
          },
          "uniqueItems": true
        }
      }
    },
    "ruleSeverityOverride": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "severity"],
      "properties": {
        "rule_id": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "enum": ["info", "warning", "error"]
        }
      }
    },
    "verificationSkill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_kind",
        "skill_id",
        "adapter",
        "tool",
        "command",
        "standard",
        "required_inputs",
        "pass_criteria",
        "receipt_fields"
      ],
      "properties": {
        "task_kind": {
          "$ref": "#/$defs/taskKind"
        },
        "skill_id": {
          "type": "string",
          "minLength": 1
        },
        "adapter": {
          "type": ["string", "null"]
        },
        "tool": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "standard": {
          "type": "string",
          "minLength": 1
        },
        "required_inputs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "pass_criteria": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "receipt_fields": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "ownerPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_path",
        "responsibilities",
        "task_kinds",
        "task_contracts",
        "stability_picture",
        "rationale"
      ],
      "properties": {
        "owner_path": {
          "type": "string",
          "minLength": 1
        },
        "responsibilities": {
          "type": "array",
          "items": {
            "enum": [
              "pure_domain_logic",
              "public_api",
              "external_dependency",
              "persistence",
              "security_boundary",
              "latency_sensitive",
              "availability_critical"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "task_kinds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/taskKind"
          },
          "uniqueItems": true
        },
        "task_contracts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/taskContract"
          },
          "uniqueItems": true
        },
        "stability_picture": {
          "oneOf": [
            { "$ref": "#/$defs/stabilityPicture" },
            { "type": "null" }
          ]
        },
        "rationale": {
          "type": ["string", "null"]
        }
      }
    },
    "taskContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_kind",
        "phase",
        "required_receipt",
        "required_evidence"
      ],
      "properties": {
        "task_kind": {
          "$ref": "#/$defs/taskKind"
        },
        "phase": {
          "enum": [
            "after_unit_tests_pass",
            "before_release",
            "scheduled_regression",
            "before_verification"
          ]
        },
        "required_receipt": {
          "type": "string",
          "minLength": 1
        },
        "required_evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verificationRequirement"
          },
          "uniqueItems": true
        }
      }
    },
    "verificationRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "description"],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "stabilityPicture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "require_long_running_simulation",
        "require_performance_interface",
        "require_resource_delta",
        "require_state_growth",
        "require_determinism",
        "require_stability_artifact",
        "min_iterations",
        "min_duration_seconds"
      ],
      "properties": {
        "require_long_running_simulation": { "type": "boolean" },
        "require_performance_interface": { "type": "boolean" },
        "require_resource_delta": { "type": "boolean" },
        "require_state_growth": { "type": "boolean" },
        "require_determinism": { "type": "boolean" },
        "require_stability_artifact": { "type": "boolean" },
        "min_iterations": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "min_duration_seconds": {
          "type": ["integer", "null"],
          "minimum": 1
        }
      }
    },
    "dependencyBaselinePackage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "source_contains"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "source_contains": { "type": "string", "minLength": 1 }
      }
    },
    "taskKind": {
      "enum": [
        "stress",
        "performance",
        "stability",
        "chaos",
        "security",
        "regression",
        "responsibility_review"
      ]
    }
  }
}
