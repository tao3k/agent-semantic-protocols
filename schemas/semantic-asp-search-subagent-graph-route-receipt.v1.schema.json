{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-asp-search-subagent-graph-route-receipt.v1.schema.json",
  "title": "Semantic ASP Search Subagent GraphRoute Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "kind",
    "receiptSchema",
    "intent",
    "route",
    "state",
    "evidence",
    "next",
    "omit"
  ],
  "properties": {
    "schemaId": {
      "const": "semantic-asp-search-subagent-graph-route-receipt.v1"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.search-subagent"
    },
    "protocolVersion": {
      "const": "1"
    },
    "kind": {
      "const": "asp-search-subagent"
    },
    "receiptSchema": {
      "const": "asp-search-subagent.graph.v1"
    },
    "intent": {
      "description": "Parent-supplied branch id or short intent slice. This is not a new analysis paragraph.",
      "type": "string",
      "minLength": 1
    },
    "route": {
      "description": "Selected graph route, such as query-axis -> owner -> item/test/dependency.",
      "type": "string",
      "minLength": 1
    },
    "state": {
      "description": "Route readiness state after pollution filtering.",
      "enum": [
        "selector-ready",
        "needs-refine",
        "no-output",
        "inventory-only",
        "stale-index",
        "invalid-selector",
        "empty-payload",
        "quarantined"
      ]
    },
    "evidence": {
      "description": "Rank-ordered EvidenceGraph nodes that justify the selected route. Keep this small; the parent performs exact reads.",
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/evidenceNode"
      }
    },
    "edges": {
      "description": "Optional compact EvidenceGraph relations between returned evidence nodes.",
      "type": "array",
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/routeEdge"
      }
    },
    "next": {
      "description": "Exactly one safe parent action. Usually an exact selector read or bounded refinement command.",
      "$ref": "#/$defs/parentAction"
    },
    "alt": {
      "description": "Optional bounded alternatives; never a dump of every explored owner.",
      "type": "array",
      "maxItems": 2,
      "items": {
        "$ref": "#/$defs/parentAction"
      }
    },
    "avoid": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "omit": {
      "description": "Facts intentionally omitted from the subagent receipt.",
      "type": "array",
      "minItems": 1,
      "contains": {
        "const": "source"
      },
      "items": {
        "enum": [
          "source",
          "source-body",
          "snippet",
          "line-range",
          "confidence",
          "long-explanation",
          "not-found-inventory",
          "missing-coverage"
        ]
      },
      "uniqueItems": true
    },
    "fields": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "evidenceNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "role",
        "owner",
        "selector"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^E[0-9]+$"
        },
        "kind": {
          "enum": [
            "item",
            "owner",
            "test",
            "dependency",
            "doc",
            "policy",
            "scenario",
            "route"
          ]
        },
        "role": {
          "enum": [
            "primary",
            "guard",
            "context",
            "refine",
            "avoid"
          ]
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "selector": {
          "description": "Parser-owned selector or document-provider selector. Display line ranges are not valid identities.",
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": ":[0-9]+([-:][0-9]+)?$"
          }
        },
        "relation": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "enum": [
            "selector-ready",
            "inventory-only",
            "stale-index",
            "invalid-selector",
            "empty-payload",
            "quarantined"
          ]
        }
      }
    },
    "routeEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "relation",
        "to"
      ],
      "properties": {
        "from": {
          "type": "string",
          "pattern": "^E[0-9]+$"
        },
        "relation": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "pattern": "^E[0-9]+$"
        }
      }
    },
    "parentAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref",
        "command"
      ],
      "properties": {
        "ref": {
          "type": "string",
          "pattern": "^E[0-9]+$"
        },
        "command": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
