{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.dev/schemas/semantic-sandtable-large-library-corpora.v1.schema.json",
  "title": "Large library runtime benchmark corpora",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaId", "schemaVersion", "corpora"],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-sandtable-large-library-corpora"
    },
    "schemaVersion": { "const": "1" },
    "corpora": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/corpus" }
    }
  },
  "$defs": {
    "corpus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenarioId",
        "language",
        "repository",
        "directory",
        "environment",
        "inputs"
      ],
      "properties": {
        "scenarioId": { "type": "string", "minLength": 1 },
        "language": {
          "enum": ["julia", "python", "rust", "typescript"]
        },
        "repository": { "type": "string", "minLength": 1 },
        "directory": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "environment": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
        "inputs": {
          "type": "object",
          "additionalProperties": false,
          "required": ["owner", "query", "dependency"],
          "properties": {
            "owner": { "type": "string", "minLength": 1 },
            "query": { "type": "string", "minLength": 1 },
            "dependency": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
