{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/turso-mvcc-batch-write-receipt.v1.schema.json",
  "title": "ASP Turso MVCC Batch Write Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "attemptedRows",
    "committedRows",
    "retryCount",
    "busyCount",
    "snapshotConflictCount",
    "retryDelayMs",
    "optimization"
  ],
  "properties": {
    "schemaId": {
      "const": "asp.turso-mvcc-batch-write-receipt.v1"
    },
    "attemptedRows": {
      "type": "integer",
      "minimum": 0
    },
    "committedRows": {
      "type": "integer",
      "minimum": 0
    },
    "retryCount": {
      "type": "integer",
      "minimum": 0
    },
    "busyCount": {
      "type": "integer",
      "minimum": 0
    },
    "snapshotConflictCount": {
      "type": "integer",
      "minimum": 0
    },
    "retryDelayMs": {
      "type": "integer",
      "minimum": 0
    },
    "optimization": {
      "$ref": "turso-mvcc-optimization-receipt.v1.schema.json"
    }
  }
}
