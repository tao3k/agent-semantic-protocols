{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/software-criterion-extension-report.v1.schema.json",
  "title": "Software Criterion Extension Report v1",
  "description": "Provider-owned optional ecosystem/profile software criteria projected into a shared agent-facing envelope.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "languageId",
    "providerId",
    "projectRoot",
    "extensionId",
    "ecosystem",
    "mode",
    "activationEvidence",
    "findings"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.software-criterion-extension-report"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.software-criterion"
    },
    "protocolVersion": {
      "const": "1"
    },
    "languageId": {
      "$ref": "#/$defs/languageId"
    },
    "providerId": {
      "$ref": "#/$defs/providerId"
    },
    "projectRoot": {
      "type": "string",
      "minLength": 1
    },
    "extensionId": {
      "$ref": "#/$defs/extensionId"
    },
    "ecosystem": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "mode": {
      "$ref": "#/$defs/activationMode"
    },
    "profile": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.:-]*$"
    },
    "activationEvidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/activationEvidence"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "artifactRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifactRef"
      }
    },
    "fields": {
      "$ref": "#/$defs/fields"
    }
  },
  "$defs": {
    "languageId": {
      "enum": ["rust", "typescript", "python", "julia"]
    },
    "providerId": {
      "enum": [
        "rs-harness",
        "ts-harness",
        "py-harness",
        "julia-lang-project-harness"
      ]
    },
    "activationMode": {
      "enum": ["off", "detect", "enable", "strict"]
    },
    "criterionDomain": {
      "enum": [
        "domain-type",
        "error-channel",
        "resource-lifetime",
        "concurrency",
        "observability",
        "schema-boundary",
        "pattern-dispatch",
        "verification",
        "testing",
        "profile",
        "custom"
      ]
    },
    "severity": {
      "enum": [
        "info",
        "advisory",
        "warning",
        "blocking-candidate",
        "error"
      ]
    },
    "sourceKind": {
      "enum": [
        "official-docs",
        "ecosystem-style-guide",
        "provider-docs",
        "parser-fact",
        "project-config",
        "dependency",
        "import",
        "test-fixture",
        "real-project-evidence",
        "custom"
      ]
    },
    "extensionId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*\\.(extension|profile)\\.[a-z][a-z0-9_-]*$"
    },
    "ruleId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*\\.(extension|profile)\\.[a-z][a-z0-9_-]*(?:\\.[a-z][a-z0-9_-]*){1,4}$"
    },
    "projectPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:\\.|(?!/)(?![A-Za-z]:)(?![0-9]+:)(?!\\.\\.?($|/))(?!.*(^|/)\\.\\.?($|/))(?!.*//)[^\\s:\\\\]+(?:/[^\\s:\\\\]+)*)$"
    },
    "scalar": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "boolean" }
            ]
          }
        }
      ]
    },
    "fields": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/scalar"
      }
    },
    "locator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": {
          "$ref": "#/$defs/projectPath"
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "column": {
          "type": "integer",
          "minimum": 1
        },
        "lineRange": {
          "type": "string",
          "pattern": "^[1-9][0-9]*:[1-9][0-9]*$"
        }
      }
    },
    "activationEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "summary"],
      "properties": {
        "kind": {
          "$ref": "#/$defs/sourceKind"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "locator": {
          "$ref": "#/$defs/locator"
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      }
    },
    "sourceDoctrine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "claim"],
      "properties": {
        "kind": {
          "$ref": "#/$defs/sourceKind"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "claim": {
          "type": "string",
          "minLength": 1
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      }
    },
    "repair": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary"],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "recipeId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.:-]*$"
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      }
    },
    "artifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifactKind", "artifactId"],
      "properties": {
        "artifactKind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.:-]*$"
        },
        "artifactId": {
          "type": "string",
          "minLength": 1
        },
        "schemaId": {
          "type": "string",
          "pattern": "^agent\\.semantic-protocols\\.[a-z0-9_.-]+$"
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ruleId",
        "criterionDomain",
        "severity",
        "summary",
        "agentRisk",
        "facts",
        "repair"
      ],
      "properties": {
        "ruleId": {
          "$ref": "#/$defs/ruleId"
        },
        "criterionDomain": {
          "$ref": "#/$defs/criterionDomain"
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "agentRisk": {
          "type": "string",
          "minLength": 1
        },
        "ownerPath": {
          "$ref": "#/$defs/projectPath"
        },
        "locator": {
          "$ref": "#/$defs/locator"
        },
        "facts": {
          "$ref": "#/$defs/fields"
        },
        "repair": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/repair"
          }
        },
        "sourceDoctrine": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sourceDoctrine"
          }
        },
        "artifactRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactRef"
          }
        },
        "fields": {
          "$ref": "#/$defs/fields"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "mode": {
            "const": "off"
          }
        },
        "required": ["mode"]
      },
      "then": {
        "properties": {
          "findings": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "mode": {
            "const": "strict"
          }
        },
        "required": ["mode"]
      },
      "then": {
        "properties": {
          "activationEvidence": {
            "minItems": 1
          }
        }
      }
    }
  ]
}
