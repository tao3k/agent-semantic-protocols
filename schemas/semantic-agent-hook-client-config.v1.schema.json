{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-agent-hook-client-config.v1.schema.json",
  "title": "Semantic Agent Hook Client Config",
  "description": "Optional client-side semantic hook rules loaded by asp hook on each invocation.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.hook.client-config"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.hook"
    },
    "protocolVersion": {
      "const": "1"
    },
    "agentOrgArtifacts": {
      "$ref": "#/$defs/agentOrgArtifacts"
    },
    "aspCommandIntentPolicy": {
      "$ref": "#/$defs/aspCommandIntentPolicy"
    },
    "executionLanes": {
      "$ref": "#/$defs/executionLanes"
    },
    "rules": {
      "description": "Typed client-hook rules. Rule ids are runtime-validated as unique because config-derived decisions use fields.configRuleId as the machine receipt.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      }
    },
    "contractFingerprint": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "experimental": {
      "$ref": "#/$defs/experimental"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "event": {
      "enum": [
        "pre-tool",
        "permission-request",
        "post-tool",
        "user-prompt",
        "session-start",
        "subagent-start",
        "subagent-stop",
        "stop"
      ]
    },
    "experimental": {
      "description": "Project-local experimental hook feature switches. Missing switches preserve the built-in classifier behavior.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "semanticAstPatch": {
          "$ref": "#/$defs/experimentalFeature"
        }
      }
    },
    "experimentalFeature": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "aspCommandIntentPolicy": {
      "description": "Parser-owned classification policy for public asp language commands.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "controlPlane": {
          "$ref": "#/$defs/aspControlPlaneIntent"
        },
        "reasoning": {
          "$ref": "#/$defs/aspReasoningIntent"
        },
        "exactEvidence": {
          "$ref": "#/$defs/aspExactEvidenceIntent"
        },
        "directReadFallback": {
          "$ref": "#/$defs/aspDirectReadFallbackIntent"
        },
        "invalidEvidence": {
          "$ref": "#/$defs/aspInvalidEvidenceIntent"
        }
      }
    },
    "executionLanes": {
      "description": "Deterministic command execution lanes that do not require a reasoning agent.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "testing": {"$ref": "#/$defs/executionLane"}
      }
    },
    "executionLane": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean"},
        "transport": {"const": "current-session"},
        "commandPrefixes": {"$ref": "#/$defs/nonEmptyStringArray"},
        "receiptKind": {"type": "string", "minLength": 1}
      }
    },
    "aspControlPlaneIntent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rootCommands": {"$ref": "#/$defs/nonEmptyStringArray"}
      }
    },
    "aspReasoningIntent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rootCommands": {"$ref": "#/$defs/nonEmptyStringArray"},
        "guideCommand": {"type": "boolean"},
        "searchRoutes": {"$ref": "#/$defs/nonEmptyStringArray"},
        "queryFlags": {"$ref": "#/$defs/nonEmptyStringArray"},
        "unprojectedQuery": {"type": "boolean"}
      }
    },
    "aspExactEvidenceIntent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "queryProjectionFlags": {"$ref": "#/$defs/nonEmptyStringArray"},
        "queryProjectionViews": {"$ref": "#/$defs/nonEmptyStringArray"},
        "selectorKinds": {"$ref": "#/$defs/nonEmptyStringArray"},
        "requireSameLanguage": {"type": "boolean"}
      }
    },
    "aspDirectReadFallbackIntent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fromHookValues": {"$ref": "#/$defs/nonEmptyStringArray"}
      }
    },
    "aspInvalidEvidenceIntent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rejectProjectedQueryWithoutExactSelector": {"type": "boolean"},
        "rejectCrossLanguageSelector": {"type": "boolean"}
      }
    },
    "nonEmptyStringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "agentOrgArtifacts": {
      "description": "Agent Org artifact entry guard. When enabled, hook decisions can direct the agent back to ASP_ORG.org if no Org artifact write has occurred recently and warn when DONE Org records should be archived.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "inactiveAfterMinutes": {
          "type": "integer",
          "minimum": 1
        },
        "artifactsPath": {
          "type": "string",
          "minLength": 1
        },
        "entrySkillPath": {
          "type": "string",
          "minLength": 1
        },
        "archiveWarning": {
          "$ref": "#/$defs/agentOrgArtifactsArchiveWarning"
        }
      }
    },
    "agentOrgArtifactsArchiveWarning": {
      "description": "Warning gate for active Org artifact directories that contain DONE records not yet moved under archives.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "activeOrgFileThreshold": {
          "type": "integer",
          "minimum": 1
        },
        "archivesDir": {
          "type": "string",
          "minLength": 1
        },
        "maxReportedFiles": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "decision"],
      "allOf": [
        {
          "if": {
            "required": ["decisionMaterializer"],
            "properties": {
              "decisionMaterializer": { "type": "string" }
            }
          },
          "then": {
            "properties": {
              "routes": { "maxItems": 0 }
            }
          }
        }
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "enabled": {
          "type": "boolean"
        },
        "priority": {
          "type": "integer"
        },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "decision": {
          "enum": ["deny", "block"]
        },
        "decisionMaterializer": {
          "type": ["string", "null"],
          "enum": [
            "agent-search-json",
            "prompt-search-strategy",
            "invalid-asp-facade",
            "apply-patch",
            "source-access",
            null
          ]
        },
        "reasonKind": {
          "enum": [
            "none",
            "direct-source-read",
            "bulk-source-dump",
            "raw-broad-search",
            "asp-reasoning-routed",
            "agent-search-json",
            "subagent-receipt-required"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "languageIds": {
          "description": "Optional language filter. A rule with languageIds only matches action paths covered by activated providers for one of these languages.",
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "event": {
          "$ref": "#/$defs/event"
        },
        "platform": {
          "enum": ["codex", "claude", "unknown"]
        },
        "match": {
          "$ref": "#/$defs/ruleMatch"
        },
        "routes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/route"
          }
        }
      }
    },
    "ruleMatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tool": {
          "type": "string",
          "minLength": 1
        },
        "toolAny": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "commandAny": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "commandContainsAny": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "pathAny": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "pathGlobAny": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["providerId", "kind", "argv"],
      "properties": {
        "providerId": {
          "$ref": "#/$defs/identifier"
        },
        "languageId": {
          "$ref": "#/$defs/identifier"
        },
        "binary": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+$"
        },
        "kind": {
          "enum": [
            "prime",
            "owner",
            "query",
            "lexical",
            "read",
            "deps",
            "api",
            "ingest",
            "tests",
            "check-changed"
          ]
        },
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "stdinMode": {
          "enum": ["none", "pipe-candidates", "pipe-diff", "unknown"]
        }
      }
    }
  }
}
