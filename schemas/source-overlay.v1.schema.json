{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.dev/schemas/source-overlay.v1.schema.json",
  "title": "ASP source overlay v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaId", "sourceKind", "changes"],
  "properties": {
    "schemaId": { "const": "asp.source-overlay.v1" },
    "sourceKind": { "const": "editor-buffer" },
    "baseRootDigest": { "$ref": "#/$defs/digest" },
    "changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/upsert" },
          { "$ref": "#/$defs/delete" }
        ]
      }
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "upsert": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "operation", "content"],
      "properties": {
        "path": { "$ref": "#/$defs/path" },
        "operation": { "const": "upsert" },
        "content": { "type": "string" }
      }
    },
    "delete": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "operation"],
      "properties": {
        "path": { "$ref": "#/$defs/path" },
        "operation": { "const": "delete" }
      }
    }
  }
}
