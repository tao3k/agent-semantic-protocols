{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agent-semantic-protocols.local/agent-semantic-project-config.v1.schema.json",
  "title": "Agent Semantic Project Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.project-config"
    },
    "schemaVersion": {
      "const": "1"
    },
    "discovery": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ignoredDirNames": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dirName"
          },
          "uniqueItems": true
        },
        "includeHiddenDirNames": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/hiddenDirName"
          },
          "uniqueItems": true
        }
      }
    },
    "providers": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^[a-z][a-z0-9_-]*$": {
          "$ref": "#/$defs/providerConfig"
        }
      },
      "properties": {
        "rust": {
          "$ref": "#/$defs/providerConfig"
        },
        "typescript": {
          "$ref": "#/$defs/providerConfig"
        },
        "python": {
          "$ref": "#/$defs/providerConfig"
        },
        "julia": {
          "$ref": "#/$defs/providerConfig"
        }
      }
    },
    "hook": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "agentOrgArtifacts": {
          "$ref": "#/$defs/agentOrgArtifactsConfig"
        }
      }
    },
    "skills": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "codeql": {
          "$ref": "#/$defs/codeqlExtensionConfig"
        }
      }
    }
  },
  "$defs": {
    "providerConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "binary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "agentOrgArtifactsConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "inactiveAfterMinutes": {
          "type": "integer",
          "minimum": 1,
          "default": 30
        },
        "artifactsPath": {
          "type": "string",
          "minLength": 1,
          "default": ".cache/agent-semantic-protocol/artifacts/org"
        },
        "entrySkillPath": {
          "type": "string",
          "minLength": 1,
          "default": ".cache/agent-semantic-protocol/org/skills/ASP_ORG.org"
        },
        "archiveWarning": {
          "$ref": "#/$defs/agentOrgArtifactsArchiveWarningConfig"
        }
      }
    },
    "agentOrgArtifactsArchiveWarningConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "activeOrgFileThreshold": {
          "type": "integer",
          "minimum": 1,
          "default": 10
        },
        "archivesDir": {
          "type": "string",
          "minLength": 1,
          "default": "archives"
        },
        "maxReportedFiles": {
          "type": "integer",
          "minimum": 1,
          "default": 5
        }
      }
    },
    "codeqlExtensionConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "experimental": {
          "type": "boolean",
          "default": true
        },
        "mode": {
          "type": "string",
          "enum": [
            "disabled",
            "metadata",
            "cache-only",
            "manual",
            "ci"
          ],
          "default": "disabled"
        },
        "allowDatabaseCreate": {
          "type": "boolean",
          "default": false
        },
        "allowHotPath": {
          "const": false,
          "default": false
        },
        "cacheDir": {
          "type": "string",
          "minLength": 1
        },
        "profiles": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "metadata",
              "raw-dbscheme",
              "local-flow",
              "global-flow",
              "taint",
              "security",
              "variant-analysis"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "dirName": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          {
            "const": "."
          },
          {
            "const": ".."
          }
        ]
      },
      "pattern": "^[^/\\\\]+$"
    },
    "hiddenDirName": {
      "allOf": [
        {
          "$ref": "#/$defs/dirName"
        },
        {
          "pattern": "^\\.[^.]|^\\.[^.].*"
        }
      ]
    }
  }
}
