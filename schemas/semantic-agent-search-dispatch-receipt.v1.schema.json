{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.dev/schemas/semantic-agent-search-dispatch-receipt.v1.schema.json",
  "title": "Semantic Agent Search Dispatch Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "dispatchIdentity",
    "rootSessionId",
    "childSessionId",
    "messageTargetId",
    "commandDigest",
    "state",
    "routingTerminal",
    "redispatchAllowed"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.search-dispatch-receipt"
    },
    "schemaVersion": {
      "const": "1"
    },
    "dispatchIdentity": {
      "type": "string",
      "minLength": 1
    },
    "rootSessionId": {
      "type": "string",
      "minLength": 1
    },
    "childSessionId": {
      "type": "string",
      "minLength": 1
    },
    "messageTargetId": {
      "type": "string",
      "minLength": 1
    },
    "commandDigest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "state": {
      "enum": ["accepted", "running", "owner-materialized", "completed", "failed"]
    },
    "routingTerminal": {
      "const": true
    },
    "redispatchAllowed": {
      "const": false
    },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["languageId", "path", "selector"],
      "properties": {
        "languageId": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "selector": { "type": "string", "minLength": 1 }
      }
    },
    "nextCommand": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(?!.*<[^>]+>).+$"
      }
    },
    "failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "message"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "state": { "const": "completed" } },
        "required": ["state"]
      },
      "then": {
        "required": ["owner", "nextCommand"]
      }
    },
    {
      "if": {
        "properties": { "state": { "const": "failed" } },
        "required": ["state"]
      },
      "then": {
        "required": ["failure"]
      }
    }
  ]
}
