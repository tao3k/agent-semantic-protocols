{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-agent-session-graph-turbo-feedback.v1.schema.json",
  "title": "Semantic Agent Session Graph Turbo Feedback",
  "description": "Explicit graph-turbo improvement candidates produced from agent-session observability.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "sessionId",
    "scenarioId",
    "sourceReceiptPath",
    "candidates"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-agent-session-graph-turbo-feedback"
    },
    "schemaVersion": {
      "const": "1"
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "scenarioId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
    },
    "sourceReceiptPath": {
      "type": "string",
      "minLength": 1
    },
    "candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidate"
      }
    }
  },
  "$defs": {
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "confidence", "reason", "evidenceRefs"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": [
            "missing-fact",
            "under-ranked-selector",
            "repeated-query-group",
            "unclear-next-action",
            "profile-rank-change",
            "seed-plan-quality",
            "path-intent-lost",
            "finder-path-ignored",
            "search-flow-drift"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "evidenceRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "matchedSelectors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "packetNodeIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "repeatedQueries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
    "expectedChange": {
      "type": "string",
      "minLength": 1
    },
    "seedQuality": {
      "enum": [
        "good",
        "review",
        "fail",
        "unknown"
      ]
    },
    "riskFactors": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recommendedActions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recommendedAction": {
      "type": "string",
      "minLength": 1
    }
  }
    }
  }
}
