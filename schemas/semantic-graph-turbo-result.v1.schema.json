{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.dev/schemas/semantic-graph-turbo-result.v1.schema.json",
  "title": "Semantic Graph Turbo Result v1",
  "type": "object",
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "packetKind",
    "profile",
    "algorithm",
    "seedIds",
    "rankedNodes",
    "edges"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-graph-turbo-result"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.semantic-language"
    },
    "protocolVersion": {
      "const": "1"
    },
    "packetKind": {
      "const": "graph-turbo-result"
    },
    "profile": {
      "type": "string",
      "minLength": 1
    },
    "algorithm": {
      "type": "string",
      "minLength": 1
    },
    "seedIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "rank": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "rankedNodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    },
    "typedPaths": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "frontier": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "algorithmMetrics": {
      "type": "object"
    },
    "algorithmTrace": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": [
        "id",
        "kind"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string"
        },
        "value": {
          "type": "string"
        },
        "action": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "edge": {
      "type": "object",
      "required": [
        "source",
        "target",
        "relation"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "relation": {
          "type": "string",
          "minLength": 1
        },
        "weight": {
          "type": "number"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
