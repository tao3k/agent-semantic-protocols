{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-db-engine-report.v1.schema.json",
  "title": "Semantic DB Engine Report",
  "description": "Analyzer-facing DB Engine diagnostic report. Default builds report turso as the active replacement backend; sqlite-v1 remains valid only for no-default-features migration/control validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "backend",
    "futureBackend",
    "layoutVersion",
    "dbFileName",
    "schemaVersion",
    "durability",
    "features",
    "clientDir",
    "dbPath",
    "manifestPath",
    "artifactPath",
    "repoId",
    "workspaceId",
    "scopeId",
    "futureBackendReport",
    "sqliteReport"
  ],
  "properties": {
    "backend": {
      "enum": [
        "sqlite-v1",
        "turso"
      ]
    },
    "futureBackend": {
      "const": "turso"
    },
    "layoutVersion": {
      "const": "state-v2"
    },
    "dbFileName": {
      "enum": [
        "client.sqlite3",
        "client.turso"
      ]
    },
    "schemaVersion": {
      "const": 1
    },
    "durability": {
      "enum": [
        "sqlite-file",
        "turso-local-file"
      ]
    },
    "features": {
      "$ref": "#/$defs/activeEngineFeatures"
    },
    "clientDir": {
      "type": "string",
      "pattern": "/live/client$"
    },
    "dbPath": {
      "type": "string",
      "pattern": "/live/client/client\\.(sqlite3|turso)$"
    },
    "manifestPath": {
      "type": "string",
      "pattern": "/live/client/manifest\\.json$"
    },
    "artifactPath": {
      "type": "string",
      "pattern": "/artifacts$"
    },
    "repoId": {
      "type": "string",
      "pattern": "^repo-[0-9a-f]{16}$"
    },
    "workspaceId": {
      "type": "string",
      "pattern": "^workspace-[0-9a-f]{16}$"
    },
    "scopeId": {
      "const": "default"
    },
    "sqliteReport": {
      "$ref": "#/$defs/sqliteReport"
    },
    "futureBackendReport": {
      "$ref": "#/$defs/tursoReport"
    }
  },
  "$defs": {
    "activeEngineFeatures": {
      "oneOf": [
        {
          "$ref": "#/$defs/engineFeatures"
        },
        {
          "$ref": "#/$defs/tursoFeatures"
        }
      ]
    },
    "engineFeatures": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asyncIo",
        "concurrentWrites",
        "fts",
        "vector",
        "overlaySearch",
        "sync",
        "encryption"
      ],
      "properties": {
        "asyncIo": {
          "const": false
        },
        "concurrentWrites": {
          "const": false
        },
        "fts": {
          "const": false
        },
        "vector": {
          "const": false
        },
        "overlaySearch": {
          "const": false
        },
        "sync": {
          "const": false
        },
        "encryption": {
          "const": false
        }
      }
    },
    "sqliteReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dbPath",
        "status",
        "generationCount",
        "syntaxRowGenerationCount",
        "syntaxRowMatchCount",
        "syntaxRowCaptureCount",
        "structuralIndexGenerationCount",
        "structuralIndexOwnerCount",
        "structuralIndexSymbolCount",
        "structuralIndexDependencyUsageCount",
        "sourceIndexGenerationCount",
        "sourceIndexOwnerCount",
        "sourceIndexSelectorCount",
        "artifactEventCount",
        "rawSourceStored",
        "runtimePragmas",
        "reason"
      ],
      "properties": {
        "dbPath": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "missing",
            "present",
            "invalid"
          ]
        },
        "generationCount": {
          "type": "integer",
          "minimum": 0
        },
        "syntaxRowGenerationCount": {
          "type": "integer",
          "minimum": 0
        },
        "syntaxRowMatchCount": {
          "type": "integer",
          "minimum": 0
        },
        "syntaxRowCaptureCount": {
          "type": "integer",
          "minimum": 0
        },
        "structuralIndexGenerationCount": {
          "type": "integer",
          "minimum": 0
        },
        "structuralIndexOwnerCount": {
          "type": "integer",
          "minimum": 0
        },
        "structuralIndexSymbolCount": {
          "type": "integer",
          "minimum": 0
        },
        "structuralIndexDependencyUsageCount": {
          "type": "integer",
          "minimum": 0
        },
        "sourceIndexGenerationCount": {
          "type": "integer",
          "minimum": 0
        },
        "sourceIndexOwnerCount": {
          "type": "integer",
          "minimum": 0
        },
        "sourceIndexSelectorCount": {
          "type": "integer",
          "minimum": 0
        },
        "artifactEventCount": {
          "type": "integer",
          "minimum": 0
        },
        "rawSourceStored": {
          "type": "boolean"
        },
        "runtimePragmas": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/sqliteRuntimePragmas"
            }
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "sqliteRuntimePragmas": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "journalMode",
        "synchronous",
        "busyTimeoutMs",
        "foreignKeys"
      ],
      "properties": {
        "journalMode": {
          "type": "string",
          "minLength": 1
        },
        "synchronous": {
          "type": "integer"
        },
        "busyTimeoutMs": {
          "type": "integer",
          "minimum": 0
        },
        "foreignKeys": {
          "type": "boolean"
        }
      }
    },
    "tursoReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "backend",
        "status",
        "dbFileName",
        "schemaVersion",
        "schemaBootstrap",
        "durability",
        "features",
        "dbPath",
        "reason"
      ],
      "properties": {
        "backend": {
          "const": "turso"
        },
        "status": {
          "enum": [
            "planned",
            "available",
            "active",
            "unavailable",
            "feature-disabled",
            "missing",
            "ready",
            "bootstrap-smoke"
          ]
        },
        "dbFileName": {
          "const": "client.turso"
        },
        "schemaBootstrap": {
          "enum": [
            "pending-cutover",
            "ready",
            "failed"
          ]
        },
        "durability": {
          "const": "turso-local-file"
        },
        "features": {
          "$ref": "#/$defs/tursoFeatures"
        },
        "dbPath": {
          "type": "string",
          "pattern": "/live/client/client\\.turso$"
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "schemaVersion": {
          "const": 1
        }
      }
    },
    "tursoFeatures": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asyncIo",
        "concurrentWrites",
        "fts",
        "vector",
        "overlaySearch",
        "sync",
        "encryption"
      ],
      "properties": {
        "asyncIo": {
          "const": true
        },
        "concurrentWrites": {
          "const": true
        },
        "fts": {
          "const": true
        },
        "vector": {
          "const": false
        },
        "overlaySearch": {
          "const": true
        },
        "sync": {
          "const": true
        },
        "encryption": {
          "const": false
        }
      }
    }
  }
}
