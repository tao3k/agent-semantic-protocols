{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-db-engine-report.v1.schema.json",
  "title": "Semantic DB Engine Report",
  "description": "Analyzer-facing DB Engine diagnostic report for the active Turso DB Engine.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "backend",
    "layoutVersion",
    "dbFileName",
    "schemaVersion",
    "durability",
    "features",
    "clientDir",
    "dbPath",
    "manifestPath",
    "artifactPath",
    "repoId",
    "workspaceId",
    "scopeId"
  ],
  "properties": {
    "backend": {
      "const": "turso"
    },
    "layoutVersion": {
      "const": "state-v2"
    },
    "dbFileName": {
      "const": "client.turso"
    },
    "schemaVersion": {
      "const": 1
    },
    "durability": {
      "const": "turso-local-file"
    },
    "features": {
      "$ref": "#/$defs/tursoFeatures"
    },
    "clientDir": {
      "type": "string",
      "pattern": "/live/client$"
    },
    "dbPath": {
      "type": "string",
      "pattern": "/live/client/client\\.turso$"
    },
    "manifestPath": {
      "type": "string",
      "pattern": "/live/client/manifest\\.json$"
    },
    "artifactPath": {
      "type": "string",
      "pattern": "/artifacts$"
    },
    "repoId": {
      "type": "string",
      "pattern": "^repo-[0-9a-f]{16}$"
    },
    "workspaceId": {
      "type": "string",
      "pattern": "^workspace-[0-9a-f]{16}$"
    },
    "scopeId": {
      "const": "default"
    }
  },
  "$defs": {
    "tursoReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "backend",
        "status",
        "dbFileName",
        "schemaVersion",
        "schemaBootstrap",
        "durability",
        "features",
        "dbPath",
        "reason"
      ],
      "properties": {
        "backend": {
          "const": "turso"
        },
        "status": {
          "enum": [
            "planned",
            "available",
            "active",
            "unavailable",
            "feature-disabled",
            "missing",
            "ready",
            "bootstrap-smoke"
          ]
        },
        "dbFileName": {
          "const": "client.turso"
        },
        "schemaBootstrap": {
          "enum": [
            "pending-cutover",
            "ready",
            "failed"
          ]
        },
        "durability": {
          "const": "turso-local-file"
        },
        "features": {
          "$ref": "#/$defs/tursoFeatures"
        },
        "dbPath": {
          "type": "string",
          "pattern": "/live/client/client\\.turso$"
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "schemaVersion": {
          "const": 1
        }
      }
    },
    "tursoFeatures": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asyncIo",
        "concurrentWrites",
        "fts",
        "ftsIndexMethod",
        "vector",
        "overlaySearch",
        "sync",
        "encryption",
        "multiProcessWal",
        "serializedWriterSlot",
        "busyTimeoutMs",
        "openLockRetryAttempts",
        "openLockRetryBaseMs",
        "openLockRetryMaxMs",
        "statementLockRetryAttempts",
        "operationLock",
        "operationLockRetryAttempts",
        "operationLockRetryMs",
        "mvcc",
        "beginConcurrent"
      ],
      "properties": {
        "asyncIo": {
          "const": true
        },
        "concurrentWrites": {
          "const": false
        },
        "fts": {
          "const": true
        },
        "ftsIndexMethod": {
          "const": true
        },
        "vector": {
          "const": false
        },
        "overlaySearch": {
          "const": true
        },
        "sync": {
          "const": false
        },
        "encryption": {
          "const": false
        },
        "multiProcessWal": {
          "const": true
        },
        "serializedWriterSlot": {
          "const": true
        },
        "busyTimeoutMs": {
          "const": 5000
        },
        "openLockRetryAttempts": {
          "const": 80
        },
        "openLockRetryBaseMs": {
          "const": 5
        },
        "openLockRetryMaxMs": {
          "const": 200
        },
        "statementLockRetryAttempts": {
          "const": 80
        },
        "operationLock": {
          "const": true
        },
        "operationLockRetryAttempts": {
          "const": 240
        },
        "operationLockRetryMs": {
          "const": 250
        },
        "mvcc": {
          "const": false
        },
        "beginConcurrent": {
          "const": false
        }
      }
    },
    "dbRuntimePragmas": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "journalMode",
        "synchronous",
        "busyTimeoutMs",
        "foreignKeys"
      ],
      "properties": {
        "journalMode": {
          "type": "string",
          "minLength": 1
        },
        "synchronous": {
          "type": "integer"
        },
        "busyTimeoutMs": {
          "type": "integer",
          "minimum": 0
        },
        "foreignKeys": {
          "type": "boolean"
        }
      }
    }
  }
}
