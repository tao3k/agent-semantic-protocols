{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-agent-hook-decision.v1.schema.json",
  "title": "Semantic Agent Hook Decision",
  "description": "Language-neutral decision packet emitted by semantic language agent hook classifiers before platform-specific rendering.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "platform",
    "event",
    "decision",
    "reasonKind",
    "languageIds",
    "subject",
    "routes",
    "message"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.hook.decision"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.hook"
    },
    "protocolVersion": {
      "const": "1"
    },
    "platform": {
      "enum": ["codex", "claude", "unknown"]
    },
    "event": {
      "enum": [
        "session-start",
        "user-prompt",
        "pre-tool",
        "permission-request",
        "post-tool",
        "subagent-start",
        "subagent-stop",
        "stop",
        "unknown"
      ]
    },
    "decision": {
      "enum": ["allow", "context", "deny", "block"]
    },
    "reasonKind": {
      "enum": [
        "none",
        "direct-source-read",
        "bulk-source-dump",
        "raw-broad-search",
        "asp-reasoning-routed",
        "source-directory-enumeration",
        "agent-search-json",
        "semantic-ast-patch-required",
        "edit-before-prime",
        "changed-check-required",
        "subagent-receipt-required",
        "unsupported-platform",
        "policy"
      ]
    },
    "languageIds": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "subject": {
      "$ref": "#/$defs/subject"
    },
    "routes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/route"
      }
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "stateUpdates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stateUpdate"
      }
    },
    "fields": {
      "$ref": "#/$defs/fields"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "toolName": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string"
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "prompt": {
          "type": "string"
        }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["languageId", "providerId", "binary", "kind", "argv"],
      "properties": {
        "languageId": {
          "$ref": "#/$defs/identifier"
        },
        "providerId": {
          "$ref": "#/$defs/identifier"
        },
        "binary": {
          "$ref": "#/$defs/identifier"
        },
        "kind": {
          "enum": [
            "prime",
            "owner",
            "query",
            "lexical",
            "read",
            "deps",
            "api",
            "ingest",
            "tests",
            "check-changed"
          ]
        },
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "stdinMode": {
          "enum": ["none", "pipe-candidates", "pipe-diff", "unknown"]
        },
        "scope": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "stateUpdate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "languageId"],
      "properties": {
        "kind": {
          "enum": [
            "prime-seen",
            "semantic-search-seen",
            "dirty-files",
            "changed-check-seen",
            "subagent-receipt-seen"
          ]
        },
        "languageId": {
          "$ref": "#/$defs/identifier"
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "scalar": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "boolean" }
            ]
          }
        }
      ]
    },
    "fields": {
      "type": "object",
      "properties": {
        "configRuleId": {
          "$ref": "#/$defs/identifier",
          "description": "Client hook config rule id that produced this decision."
        },
        "toolSurface": {
          "type": "string",
          "minLength": 1,
      "description": "Normalized client tool surface that produced the decision, for example shell-command or direct-read."
        },
        "operationIntent": {
          "enum": [
            "apply-patch",
            "directory-read",
            "direct-read",
            "file-search",
            "nested-tools",
            "shell-command",
            "stdin-continuation",
            "unknown"
          ],
          "description": "Normalized operation inferred from the client tool payload before language routing."
        },
        "aspCommandIntent": {
          "enum": [
            "reasoning",
            "exact-evidence",
            "direct-read-fallback",
            "invalid-evidence"
          ],
          "description": "Parser-owned intent for an asp language facade command. Reasoning covers guide and search/query refinement; exact-evidence requires a structural item selector and evidence projection."
        },
        "aspCommandRoute": {
          "type": "string",
          "pattern": "^(guide|search-[a-z][a-z0-9-]*|query-(reasoning|selector|direct-read-fallback))$",
          "description": "Normalized parser-owned asp language command route used to make hook matching and receipts reviewable."
        },
        "executionLane": {
          "const": "asp-testing",
          "description": "Deterministic execution lane selected by parser-owned command-prefix policy."
        },
        "executionTransport": {
          "const": "current-session"
        },
        "executionReceiptKind": {
          "type": "string",
          "minLength": 1
        },
        "executionCommandDigest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "requiredHostCapability": {
          "type": "string",
          "minLength": 1
        },
        "targetAgentName": {
          "type": "string",
          "minLength": 1,
          "description": "Host-native managed profile selected from the hook deny intent, for example asp_explorer."
        },
        "targetAgentRole": {
          "type": "string",
          "minLength": 1
        },
        "targetAgentSelectionSource": {
          "const": "hook-deny-intent"
        },
        "targetAgentRegistrySource": {
          "type": "string",
          "minLength": 1
        },
        "targetAgentHostRegistry": {
          "type": "string",
          "minLength": 1
        },
        "targetAgentLifecycleOwner": {
          "const": "main-agent"
        },
        "targetAgentReusePolicy": {
          "const": "reuse-unique-child-before-spawn"
        },
        "targetAgentRegistryStatus": {
          "enum": [
            "ready",
            "repaired-by-asp-sync",
            "degraded-built-in-route"
          ]
        },
        "targetAgentAutoSync": {
          "type": "string",
          "minLength": 1
        },
        "hookConfigStatus": {
          "enum": [
            "repaired-by-asp-sync",
            "degraded-built-in-fallback"
          ]
        },
        "hookConfigAutoSync": {
          "type": "string",
          "minLength": 1
        },
        "hookConfigFailurePolicy": {
          "const": "continue-with-built-in-policy"
        }
      },
      "additionalProperties": {
        "$ref": "#/$defs/scalar"
      }
    }
  }
}
