{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-agent-runtime-profiles.v1.schema.json",
  "title": "Semantic Agent Runtime Profiles",
  "description": "Repository-local runtime execution profile generated for activated semantic providers.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "projectRoot",
    "runtimeHome",
    "generatedBy",
    "providers"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.runtime.profiles"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.runtime"
    },
    "protocolVersion": {
      "const": "1"
    },
    "projectRoot": {
      "type": "string",
      "minLength": 1
    },
    "runtimeHome": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "$ref": "#/$defs/generatedBy"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/providerProfile"
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "binary": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+$"
    },
    "namespace": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime", "version"],
      "properties": {
        "runtime": {
          "const": "asp"
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "providerProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifestId",
        "manifestDigest",
        "languageId",
        "providerId",
        "binary",
        "providerCommandPrefix",
        "argv",
        "health"
      ],
      "properties": {
        "manifestId": {
          "$ref": "#/$defs/namespace"
        },
        "manifestDigest": {
          "$ref": "#/$defs/digest"
        },
        "languageId": {
          "$ref": "#/$defs/identifier"
        },
        "providerId": {
          "$ref": "#/$defs/identifier"
        },
        "binary": {
          "$ref": "#/$defs/binary"
        },
        "providerCommandPrefix": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "resolvedBinary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "argv": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "health": {
          "$ref": "#/$defs/health"
        }
      }
    },
    "health": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {
          "enum": ["available", "missing", "unexecutable"]
        },
        "checkedAt": {
          "type": "string",
          "format": "date-time"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
