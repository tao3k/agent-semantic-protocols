{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.dev/schemas/agent-action-match.v1.schema.json",
  "title": "Agent Action Match v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "actionAny": { "$ref": "#/$defs/actionKinds" },
    "effectAny": { "$ref": "#/$defs/actionKinds" },
    "subjectKindAny": {
      "type": "array",
      "items": {
        "enum": [
          "registered-language-source",
          "registered-language-source-pattern",
          "directory",
          "structural-selector",
          "other"
        ]
      }
    },
    "authorityAny": { "$ref": "#/$defs/authorities" },
    "authorityExcludeAny": { "$ref": "#/$defs/authorities" },
    "invocationShapeAny": {
      "type": "array",
      "items": { "enum": ["host-native", "command", "wrapped-command"] }
    },
    "wrapperMatchAny": {
      "type": "array",
      "items": { "enum": ["matched", "unmatched", "unknown"] }
    },
    "flagPresenceAny": {
      "type": "array",
      "items": { "enum": ["present", "absent"] }
    },
    "effectRules": {
      "type": "array",
      "items": { "$ref": "#/$defs/effectRule" }
    },
    "authorityRules": {
      "type": "array",
      "items": { "$ref": "#/$defs/authorityRule" }
    }
  },
  "$defs": {
    "actionKind": {
      "type": "string",
      "enum": [
        "read",
        "edit",
        "search",
        "enumerate",
        "execute",
        "test",
        "build",
        "delete",
        "unknown"
      ]
    },
    "actionKinds": {
      "type": "array",
      "items": { "$ref": "#/$defs/actionKind" }
    },
    "authority": {
      "type": "string",
      "enum": [
        "raw-host-action",
        "raw-shell",
        "parser-owned-exact-evidence",
        "parser-owned-search",
        "ast-patch-evidence",
        "unknown"
      ]
    },
    "authorities": {
      "type": "array",
      "items": { "$ref": "#/$defs/authority" }
    },
    "argvPrefix": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "effectRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["effect"],
      "properties": {
        "argvPrefix": { "$ref": "#/$defs/argvPrefix" },
        "commandContainsAny": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "effect": { "$ref": "#/$defs/actionKind" }
      },
      "anyOf": [
        { "required": ["argvPrefix"] },
        { "required": ["commandContainsAny"] }
      ]
    },
    "authorityRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["argvPrefix", "authority"],
      "properties": {
        "argvPrefix": { "$ref": "#/$defs/argvPrefix" },
        "authority": { "$ref": "#/$defs/authority" }
      }
    }
  }
}
