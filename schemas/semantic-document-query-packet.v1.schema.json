{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-document-query-packet.v1.schema.json",
  "title": "Semantic Document Query Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "languageId",
    "providerId",
    "binary",
    "namespace",
    "method",
    "projectRoot",
    "query",
    "queryTerms",
    "documentMode",
    "matchCount",
    "matchLimit",
    "matchesTruncated",
    "documentFacts",
    "contentBlocks",
    "truncated"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-document-query-packet"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.semantic-language"
    },
    "protocolVersion": {
      "const": "1"
    },
    "languageId": {
      "$ref": "semantic-document-search-packet.v1.schema.json#/$defs/documentLanguageId"
    },
    "providerId": {
      "const": "orgize"
    },
    "binary": {
      "const": "orgize"
    },
    "namespace": {
      "type": "string",
      "pattern": "^agent\\.semantic-protocols\\.languages\\.(org|md)\\.orgize$"
    },
    "method": {
      "const": "query/document"
    },
    "projectRoot": {
      "type": "string",
      "minLength": 1
    },
    "query": {
      "type": "string"
    },
    "queryTerms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "documentMode": {
      "enum": [
        "metadata",
        "content"
      ]
    },
    "matchCount": {
      "type": "integer",
      "minimum": 0
    },
    "matchLimit": {
      "type": "integer",
      "minimum": 1
    },
    "matchesTruncated": {
      "type": "boolean"
    },
    "documentFacts": {
      "type": "array",
      "items": {
        "$ref": "semantic-document-search-packet.v1.schema.json#/$defs/documentFact"
      }
    },
    "contentBlocks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/contentBlock"
      }
    },
    "truncated": {
      "type": "boolean"
    }
  },
  "$defs": {
    "contentBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "documentPath",
        "location",
        "parserAuthority",
        "content"
      ],
      "properties": {
        "kind": {
          "enum": [
            "selector"
          ]
        },
        "documentPath": {
          "$ref": "semantic-source-location.v1.schema.json#/$defs/projectPath"
        },
        "location": {
          "$ref": "semantic-source-location.v1.schema.json#/$defs/location"
        },
        "parserAuthority": {
          "$ref": "semantic-document-search-packet.v1.schema.json#/$defs/parserAuthority"
        },
        "content": {
          "type": "string"
        }
      }
    }
  }
}
