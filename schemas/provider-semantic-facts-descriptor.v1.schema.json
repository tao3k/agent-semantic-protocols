{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.dev/schemas/provider-semantic-facts-descriptor.v1.schema.json",
  "title": "Provider Semantic Facts Descriptor v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "descriptorId",
    "descriptorVersion",
    "packetSchemaIds",
    "factKinds",
    "intentAxes"
  ],
  "properties": {
    "descriptorId": {
      "type": "string",
      "minLength": 1
    },
    "descriptorVersion": {
      "const": "1"
    },
    "packetSchemaIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "factKinds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "owner",
          "field",
          "type",
          "collection",
          "concurrency",
          "cancellation",
          "resource-lifecycle",
          "queue",
          "stream",
          "fiber"
        ]
      }
    },
    "intentAxes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/intentAxis"
      }
    }
  },
  "$defs": {
    "intentAxis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["axis", "terms"],
      "properties": {
        "axis": {
          "enum": [
            "data-shape",
            "collection",
            "concurrency",
            "cancellation",
            "resource-lifecycle",
            "stream"
          ]
        },
        "terms": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "roles": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": ["context", "concept", "symbol"]
          }
        }
      }
    }
  }
}
