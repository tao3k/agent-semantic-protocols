{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.dev/schemas/semantic-graph-turbo-calibration.v1.schema.json",
  "title": "Semantic Graph Turbo Calibration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "packetKind",
    "profile",
    "source",
    "kindDeltas",
    "relationDeltas",
    "metrics"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-graph-turbo-calibration"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.semantic-fact-frontier-feedback"
    },
    "protocolVersion": {
      "const": "1"
    },
    "packetKind": {
      "const": "graph-turbo-calibration"
    },
    "profile": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "kindDeltas": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "scoreDelta", "receiptCount", "reasons"],
        "properties": {
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "scoreDelta": {
            "type": "number"
          },
          "receiptCount": {
            "type": "integer",
            "minimum": 0
          },
          "reasons": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "relationDeltas": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "relation",
          "weightMultiplierDelta",
          "receiptCount",
          "reasons"
        ],
        "properties": {
          "relation": {
            "type": "string",
            "minLength": 1
          },
          "weightMultiplierDelta": {
            "type": "number"
          },
          "receiptCount": {
            "type": "integer",
            "minimum": 0
          },
          "reasons": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "feedbackPacketCount",
        "receiptCount",
        "kindDeltaCount",
        "relationDeltaCount"
      ],
      "properties": {
        "feedbackPacketCount": {
          "type": "integer",
          "minimum": 0
        },
        "receiptCount": {
          "type": "integer",
          "minimum": 0
        },
        "kindDeltaCount": {
          "type": "integer",
          "minimum": 0
        },
        "relationDeltaCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
