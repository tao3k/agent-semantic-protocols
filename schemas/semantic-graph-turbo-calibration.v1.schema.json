{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agent-semantic-protocols.local/semantic-graph-turbo-calibration.v1.schema.json",
  "title": "Semantic Graph Turbo Calibration",
  "description": "Profile-level calibration deltas derived from graph-turbo feedback facts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "packetKind",
    "profile",
    "source",
    "kindDeltas",
    "relationDeltas",
    "metrics"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-graph-turbo-calibration"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.semantic-fact-frontier-feedback"
    },
    "protocolVersion": {
      "const": "1"
    },
    "packetKind": {
      "const": "graph-turbo-calibration"
    },
    "profile": {
      "$ref": "#/$defs/profileName"
    },
    "source": {
      "enum": [
        "feedback"
      ]
    },
    "kindDeltas": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/kindDelta"
      }
    },
    "relationDeltas": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relationDelta"
      }
    },
    "metrics": {
      "$ref": "#/$defs/metrics"
    }
  },
  "$defs": {
    "profileName": {
      "enum": [
        "owner-query",
        "query-deps",
        "owner-tests",
        "prime",
        "read-frontier",
        "failure-frontier",
        "field-impact",
        "type-impact",
        "collection-impact",
        "failure-evidence",
        "test-selection",
        "affected"
      ]
    },
    "kindDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "scoreDelta",
        "receiptCount",
        "reasons"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "scoreDelta": {
          "type": "number"
        },
        "receiptCount": {
          "type": "integer",
          "minimum": 1
        },
        "reasons": {
          "$ref": "#/$defs/reasons"
        }
      }
    },
    "relationDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relation",
        "weightMultiplierDelta",
        "receiptCount",
        "reasons"
      ],
      "properties": {
        "relation": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "weightMultiplierDelta": {
          "type": "number"
        },
        "receiptCount": {
          "type": "integer",
          "minimum": 1
        },
        "reasons": {
          "$ref": "#/$defs/reasons"
        }
      }
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_-]*(?::[a-z][a-z0-9_-]*)*$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "feedbackPacketCount",
        "receiptCount",
        "kindDeltaCount",
        "relationDeltaCount"
      ],
      "properties": {
        "feedbackPacketCount": {
          "type": "integer",
          "minimum": 0
        },
        "receiptCount": {
          "type": "integer",
          "minimum": 0
        },
        "kindDeltaCount": {
          "type": "integer",
          "minimum": 0
        },
        "relationDeltaCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
