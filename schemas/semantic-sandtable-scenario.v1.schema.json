{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-sandtable-scenario.v1.schema.json",
  "title": "Semantic Sandtable Scenario",
  "description": "Language-neutral scenario descriptor for replaying bounded agent search flows against semantic language harness CLIs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "language", "workdir"],
  "allOf": [
    {
      "if": {
        "required": ["evidence"],
        "properties": {
          "evidence": {
            "type": "object",
            "required": ["fixtureTier"],
            "properties": {
              "fixtureTier": {
                "const": "large-library"
              }
            }
          }
        }
      },
      "then": {
        "required": ["coverage"],
        "properties": {
          "coverage": {
            "contains": {
              "const": "large-library"
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["liveAgent"]
      },
      "then": {
        "required": ["evidence"],
        "properties": {
          "evidence": {
            "required": ["deepQuestionCases"],
            "properties": {
              "deepQuestionCases": {
                "minItems": 1,
                "maxItems": 1
              }
            }
          }
        }
      }
    }
  ],
  "oneOf": [
    { "required": ["steps"] },
    {
      "required": ["liveAgent"],
      "not": { "required": ["steps"] }
    }
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
    },
    "language": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "coverage": {
      "$ref": "#/$defs/coverageList"
    },
    "tags": {
      "$ref": "#/$defs/stringList"
    },
    "evidence": {
      "$ref": "#/$defs/evidence"
    },
    "workdir": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "$ref": "#/$defs/workdir"
        }
      ]
    },
    "env": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "skipUnlessEnv": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/envName"
      }
    },
    "budgets": {
      "$ref": "#/$defs/budgets"
    },
    "execution": {
      "$ref": "#/$defs/execution"
    },
    "liveAgent": {
      "$ref": "#/$defs/liveAgent"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source"],
      "allOf": [
        {
          "if": {
            "required": ["fixtureTier"],
            "properties": {
              "fixtureTier": {
                "const": "large-library"
              }
            }
          },
          "then": {
            "required": ["targetLibrary", "intentCases"],
            "properties": {
              "targetLibrary": {
                "required": ["repository"],
                "properties": {
                  "workdirKind": {
                    "enum": ["checkout", "registry"]
                  }
                }
              },
              "intentCases": {
                "minItems": 3,
                "allOf": [
                  {
                    "contains": {
                      "type": "object",
                      "required": ["intentKind"],
                      "properties": {
                        "intentKind": {
                          "const": "feature-implementation"
                        }
                      }
                    }
                  },
                  {
                    "contains": {
                      "type": "object",
                      "required": ["intentKind"],
                      "properties": {
                        "intentKind": {
                          "const": "api-usage"
                        }
                      }
                    }
                  },
                  {
                    "contains": {
                      "type": "object",
                      "required": ["intentKind"],
                      "properties": {
                        "intentKind": {
                          "const": "implementation-principle"
                        }
                      }
                    }
                  }
                ]
              }
            }
          }
        }
      ],
      "properties": {
        "source": {
          "enum": ["handwritten", "real-trigger", "recorded-replay"]
        },
        "intent": {
          "type": "string",
          "minLength": 1
        },
        "intentKind": {
          "$ref": "#/$defs/intentKind"
        },
        "targetLibrary": {
          "$ref": "#/$defs/targetLibrary"
        },
        "fixtureTier": {
          "enum": ["large-library"]
        },
        "intentCases": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/intentCase"
          }
        },
        "deepQuestionCases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/deepQuestionCase"
          }
        },
        "recordedAt": {
          "type": "string",
          "minLength": 1
        },
        "receiptPath": {
          "type": "string",
          "minLength": 1
        },
        "failureFrontierComparison": {
          "$ref": "#/$defs/failureFrontierComparison"
        },
        "editBoundary": {
          "enum": ["before-edit", "after-search", "none", "unknown"]
        },
        "metrics": {
          "$ref": "#/$defs/evidenceMetrics"
        },
        "querySetOpportunities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/querySetOpportunity"
          }
        },
        "findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceFinding"
          }
        }
      }
    },
    "intentKind": {
      "enum": [
        "feature-implementation",
        "api-usage",
        "implementation-principle"
      ]
    },
    "targetLibrary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "name", "package", "workdirKind"],
      "properties": {
        "language": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "package": {
          "type": "string",
          "minLength": 1
        },
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "workdirKind": {
          "enum": ["checkout", "registry", "unknown"]
        }
      }
    },
    "intentCase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intentKind", "intent", "stepIds"],
      "properties": {
        "intentKind": {
          "$ref": "#/$defs/intentKind"
        },
        "intent": {
          "type": "string",
          "minLength": 1
        },
        "stepIds": {
          "$ref": "#/$defs/stringList"
        },
        "queryTerms": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "deepQuestionCase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "question", "stepIds", "queryTerms", "audit"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "question": {
          "type": "string",
          "minLength": 1
        },
        "stepIds": {
          "$ref": "#/$defs/stringList"
        },
        "queryTerms": {
          "$ref": "#/$defs/stringList"
        },
        "workdirSubdir": {
          "type": "string",
          "minLength": 1
        },
        "audit": {
          "$ref": "#/$defs/deepQuestionAudit"
        },
        "expectedAspFlow": {
          "$ref": "#/$defs/expectedAspFlow"
        }
      }
    },
    "expectedAspFlow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requiredStages", "forbiddenStages"],
      "properties": {
        "canonicalCommands": {
          "$ref": "#/$defs/stringList"
        },
        "requiredStages": {
          "$ref": "#/$defs/pipeFlowStageList"
        },
        "forbiddenStages": {
          "$ref": "#/$defs/pipeFlowStageList"
        },
        "notes": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "deepQuestionAudit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maxAspCommands",
        "maxSearchCommands",
        "maxQueryCommands",
        "maxRepeatedCommands"
      ],
      "properties": {
        "maxAspCommands": {
          "type": "integer",
          "minimum": 1
        },
        "maxSearchCommands": {
          "type": "integer",
          "minimum": 0
        },
        "maxQueryCommands": {
          "type": "integer",
          "minimum": 0
        },
        "maxRepeatedCommands": {
          "type": "integer",
          "minimum": 0
        },
        "requiresGraphSignals": {
          "type": "boolean"
        },
        "requiresQuerySet": {
          "type": "boolean"
        },
        "requiresHookEvents": {
          "type": "boolean"
        },
        "requiresComplexPipeFlow": {
          "type": "boolean"
        },
        "requiresTokenCost": {
          "type": "boolean"
        }
      }
    },
    "evidenceMetrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "recordedCommandCount": {
          "type": "integer",
          "minimum": 0
        },
        "recordedElapsedMs": {
          "type": "integer",
          "minimum": 0
        },
        "recordedStdoutBytes": {
          "type": "integer",
          "minimum": 0
        },
        "recordedStderrBytes": {
          "type": "integer",
          "minimum": 0
        },
        "aspCommands": {
          "type": "integer",
          "minimum": 0
        },
        "searchCommands": {
          "type": "integer",
          "minimum": 0
        },
        "queryCommands": {
          "type": "integer",
          "minimum": 0
        },
        "directReadCommands": {
          "type": "integer",
          "minimum": 0
        },
        "repeatedCommands": {
          "type": "integer",
          "minimum": 0
        },
        "repeatedSearches": {
          "type": "integer",
          "minimum": 0
        },
        "jsonSearches": {
          "type": "integer",
          "minimum": 0
        },
        "compactSearches": {
          "type": "integer",
          "minimum": 0
        },
        "tokenDelta": {
          "enum": ["lower", "same", "higher", "unknown"]
        }
      }
    },
    "querySetOpportunity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["view", "queries", "saveCommands"],
      "properties": {
        "view": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "queries": {
          "type": "integer",
          "minimum": 2
        },
        "saveCommands": {
          "type": "integer",
          "minimum": 1
        },
        "selector": {
          "enum": ["exact-set", "prefix-set", "stdin-path-set"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "terms": {
          "$ref": "#/$defs/stringList"
        },
        "scope": {
          "$ref": "#/$defs/queryScope"
        },
        "beforeCommandIds": {
          "$ref": "#/$defs/stringList"
        },
        "recommendedCommand": {
          "$ref": "#/$defs/argv"
        }
      }
    },
    "queryScope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "projectRoot": {
          "type": "string",
          "minLength": 1
        },
        "packageName": {
          "type": "string",
          "minLength": 1
        },
        "ownerPath": {
          "type": "string",
          "minLength": 1
        },
        "roots": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "evidenceFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "message"],
      "properties": {
        "kind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "severity": {
          "enum": ["info", "warning", "error"]
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "failureFrontierComparison": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expectedHotBlocks"
      ],
      "anyOf": [
        {
          "required": [
            "baselineReceiptPath",
            "candidateReceiptPath"
          ]
        },
        {
          "required": [
            "baselineTracePath",
            "candidateTracePath"
          ]
        }
      ],
      "properties": {
        "baselineReceiptPath": {
          "type": "string",
          "minLength": 1
        },
        "candidateReceiptPath": {
          "type": "string",
          "minLength": 1
        },
        "baselineTracePath": {
          "type": "string",
          "minLength": 1
        },
        "candidateTracePath": {
          "type": "string",
          "minLength": 1
        },
        "baselineTraceSessionId": {
          "type": "string",
          "minLength": 1
        },
        "candidateTraceSessionId": {
          "type": "string",
          "minLength": 1
        },
        "traceLanguageId": {
          "type": "string",
          "minLength": 1
        },
        "traceProviderId": {
          "type": "string",
          "minLength": 1
        },
        "projectName": {
          "type": "string",
          "minLength": 1
        },
        "projectSource": {
          "enum": [
            "checkout",
            "registry",
            "fixture",
            "unknown"
          ]
        },
        "intent": {
          "type": "string",
          "minLength": 1
        },
        "editBoundary": {
          "enum": [
            "before-edit",
            "after-edit"
          ]
        },
        "recordedAt": {
          "type": "string",
          "minLength": 1
        },
        "expectedHotBlocks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "thresholds": {
          "$ref": "#/$defs/failureFrontierThresholds"
        }
      }
    },
    "failureFrontierThresholds": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minCommandReduction": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "maxDirectSourceReadCode": {
          "type": "integer",
          "minimum": 0
        },
        "maxDuplicateSelectors": {
          "type": "integer",
          "minimum": 0
        },
        "maxSameFileWindowFanout": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "workdir": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "env": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$"
        },
        "relative": {
          "type": "string",
          "minLength": 1
        },
        "candidates": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "git": {
          "$ref": "#/$defs/workdirGit"
        }
      },
      "anyOf": [
        {"required": ["env"]},
        {"required": ["relative"]},
        {"required": ["candidates"]},
        {"required": ["git"]}
      ]
    },
    "workdirGit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "cacheKey"],
      "properties": {
        "url": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "depth": {
          "type": "integer",
          "minimum": 1
        },
        "cacheKey": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "subdir": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxCommands": {
          "type": "integer",
          "minimum": 1
        },
        "maxTotalLinesWarn": {
          "type": "integer",
          "minimum": 1
        },
        "maxTotalElapsedMsWarn": {
          "type": "integer",
          "minimum": 1
        },
        "maxTotalStdoutBytesWarn": {
          "type": "integer",
          "minimum": 1
        },
        "maxTotalStderrBytesWarn": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "enum": ["sequential", "parallel"]
        },
        "maxConcurrentSteps": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "oneOf": [
        {
          "required": ["command"],
          "not": {
            "anyOf": [
              {"required": ["agentCli"]},
              {"required": ["agentSdk"]}
            ]
          }
        },
        {
          "required": ["agentCli"],
          "not": {
            "anyOf": [
              {"required": ["command"]},
              {"required": ["agentSdk"]}
            ]
          }
        },
        {
          "required": ["agentSdk"],
          "not": {
            "anyOf": [
              {"required": ["command"]},
              {"required": ["agentCli"]}
            ]
          }
        }
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "kind": {
          "enum": [
            "command",
            "schema-contract",
            "policy-blackbox",
            "policy-whitebox",
            "performance",
            "security",
            "hook-replay",
            "wrapper",
            "agent-cli",
            "agent-sdk"
          ]
        },
        "coverage": {
          "$ref": "#/$defs/coverageList"
        },
        "tags": {
          "$ref": "#/$defs/stringList"
        },
        "command": {
          "$ref": "#/$defs/argv"
        },
        "agentCli": {
          "$ref": "#/$defs/agentCli"
        },
        "agentSdk": {
          "$ref": "#/$defs/agentSdk"
        },
        "stdin": {
          "type": "string"
        },
        "stdinCommand": {
          "$ref": "#/$defs/argv"
        },
        "stdinCommandAllowNonZero": {
          "type": "boolean"
        },
        "stdinTimeoutSeconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "timeoutSeconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "capture": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "expect": {
          "$ref": "#/$defs/expect"
        }
      }
    },
    "agentCli": {
      "type": "object",
      "additionalProperties": false,
      "required": ["client", "binary", "prompt", "outputFormat"],
      "properties": {
        "client": {
          "enum": ["claude"]
        },
        "binary": {
          "type": "string",
          "minLength": 1
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "outputFormat": {
          "enum": ["text", "json", "stream-json"]
        },
        "inputFormat": {
          "enum": ["text", "stream-json"]
        },
        "includePartialMessages": {
          "type": "boolean"
        },
        "includeHookEvents": {
          "type": "boolean"
        },
        "verbose": {
          "type": "boolean"
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "env": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/envName"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "requiredEnv": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/envName"
          }
        }
      }
    },
    "agentSdk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["client", "prompt", "outputFormat"],
      "properties": {
        "client": {
          "enum": ["claude"]
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "outputFormat": {
          "enum": ["text", "json", "stream-json", "summary-json"]
        },
        "includePartialMessages": {
          "type": "boolean"
        },
        "includeHookEvents": {
          "type": "boolean"
        },
        "verbose": {
          "type": "boolean"
        },
        "allowedTools": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "disallowedTools": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "requireAspBashCommands": {
          "type": "boolean"
        },
        "useRepoClaudeSettings": {
          "type": "boolean"
        },
        "maxTurns": {
          "type": "integer",
          "minimum": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "env": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/envName"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "requiredEnv": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/envName"
          }
        }
      }
    },
    "expect": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exitCode": {
          "type": "integer"
        },
        "allowNonZeroExit": {
          "type": "boolean"
        },
        "lineProtocol": {
          "type": "boolean"
        },
        "stdoutContains": {
          "$ref": "#/$defs/stringList"
        },
        "stderrContains": {
          "$ref": "#/$defs/stringList"
        },
        "stdoutNotContains": {
          "$ref": "#/$defs/stringList"
        },
        "stdoutMatches": {
          "$ref": "#/$defs/stringList"
        },
        "stdoutEmpty": {
          "type": "boolean"
        },
        "stdoutJsonEquals": {
          "$ref": "#/$defs/jsonPathMap"
        },
        "stdoutJsonContains": {
          "$ref": "#/$defs/stringMap"
        },
        "stdoutJsonArrayContains": {
          "$ref": "#/$defs/jsonValueMap"
        },
        "stdoutJsonSchema": {
          "type": "string",
          "minLength": 1
        },
        "stdoutJsonSchemaAt": {
          "$ref": "#/$defs/stringMap"
        },
        "guideQuality": {
          "$ref": "#/$defs/guideQuality"
        },
        "pipeFlow": {
          "$ref": "#/$defs/pipeFlowExpectation"
        },
        "agentAnswer": {
          "$ref": "#/$defs/agentAnswerExpectation"
        },
        "maxStdoutLinesWarn": {
          "type": "integer",
          "minimum": 1
        },
        "maxStderrLinesWarn": {
          "type": "integer",
          "minimum": 1
        },
        "maxStdoutBytesWarn": {
          "type": "integer",
          "minimum": 1
        },
        "maxElapsedMsWarn": {
          "type": "integer",
          "minimum": 1
        },
        "maxAgentInputTokensWarn": {
          "type": "integer",
          "minimum": 1
        },
        "maxAgentOutputTokensWarn": {
          "type": "integer",
          "minimum": 1
        },
        "maxAgentCacheReadInputTokensWarn": {
          "type": "integer",
          "minimum": 1
        },
        "maxAgentTotalTokensWarn": {
          "type": "integer",
          "minimum": 1
        },
        "maxAgentCostUsdWarn": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "liveAgent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["client", "useRepoClaudeSettings"],
      "properties": {
        "client": {
          "enum": ["claude"]
        },
        "outputFormat": {
          "enum": ["text", "json", "stream-json", "summary-json"]
        },
        "includePartialMessages": {
          "type": "boolean"
        },
        "includeHookEvents": {
          "type": "boolean"
        },
        "verbose": {
          "type": "boolean"
        },
        "useRepoClaudeSettings": {
          "const": true
        },
        "timeoutSeconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "env": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/envName"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "requiredEnv": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/envName"
          }
        },
        "expect": {
          "$ref": "#/$defs/expect"
        }
      }
    },
    "agentAnswerExpectation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "boolean"
        },
        "afterLastToolUse": {
          "type": "boolean"
        },
        "minTextBytes": {
          "type": "integer",
          "minimum": 0
        },
        "contains": {
          "$ref": "#/$defs/stringList"
        },
        "matches": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "pipeFlowExpectation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxAspCommands": {
          "type": "integer",
          "minimum": 0
        },
        "maxSearchCommands": {
          "type": "integer",
          "minimum": 0
        },
        "maxQueryCommands": {
          "type": "integer",
          "minimum": 0
        },
        "maxGuideCommands": {
          "type": "integer",
          "minimum": 0
        },
        "maxDirectReadCommands": {
          "type": "integer",
          "minimum": 0
        },
        "maxRepeatedCommands": {
          "type": "integer",
          "minimum": 0
        },
        "maxSearchPipeCommands": {
          "type": "integer",
          "minimum": 0
        },
        "maxSearchPrimeCommands": {
          "type": "integer",
          "minimum": 0
        },
        "maxSearchFailureCommands": {
          "type": "integer",
          "minimum": 0
        },
        "maxReadLoopDirectCodeCommands": {
          "type": "integer",
          "minimum": 0
        },
        "maxReadLoopDuplicateSelectors": {
          "type": "integer",
          "minimum": 0
        },
        "maxReadLoopAdjacentRangeWindows": {
          "type": "integer",
          "minimum": 0
        },
        "maxReadLoopSameOwnerScans": {
          "type": "integer",
          "minimum": 0
        },
        "maxReadLoopMemorySuppressibleReads": {
          "type": "integer",
          "minimum": 0
        },
        "maxAspCommandOutputBytes": {
          "type": "integer",
          "minimum": 0
        },
    "minQuerySelectorCommands": {
      "type": "integer",
      "minimum": 0
    },
    "minFrontierFollowRate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "minContextPrecision": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "minContextUtilization": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "requireComplexPipeFlow": {
      "type": "boolean"
    },
      "requireTokenCost": {
        "type": "boolean"
      },
      "requireSearchPipePrecision": {
        "type": "boolean"
      },
      "requireReadLoopMemory": {
        "type": "boolean"
      },
      "requireFailureFrontierPrecision": {
        "type": "boolean"
      },
      "requireFailureLoopMemory": {
        "type": "boolean"
      },
      "requiredStages": {
        "$ref": "#/$defs/pipeFlowStageList"
      },
        "forbiddenStages": {
          "$ref": "#/$defs/pipeFlowStageList"
        }
      }
    },
    "pipeFlowStageList": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "search-pipe",
          "search-prime",
          "search-fzf",
          "search-reasoning",
          "search-failure",
          "fd-preview",
          "fd-query",
          "rg-query",
          "search-fzf-or-reasoning",
          "query-selector",
          "treesitter-query",
          "direct-read",
          "repeated-commands",
          "repeated-prime",
          "read-loop-risk",
          "read-loop-memory-risk",
          "failure-loop-memory"
        ]
      }
    },
    "guideQuality": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reasonKind": {
          "type": "string",
          "minLength": 1
        },
        "languageId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "routeKind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "commandContains": {
          "$ref": "#/$defs/stringList"
        },
        "outputContains": {
          "$ref": "#/$defs/stringList"
        },
        "outputNotContains": {
          "$ref": "#/$defs/stringList"
        },
        "primeOutput": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
              "requiresStructureStatus": {
                "type": "boolean"
              },
              "requiresTypedEntryAliases": {
                "type": "boolean"
              },
              "entries": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "pattern": "^entries=(?:owner-query|query-deps|owner-tests|finding-frontier|feature-cfg)\\([^)]*\\)(?:,(?:owner-query|query-deps|owner-tests|finding-frontier|feature-cfg)\\([^)]*\\))*$"
              }
            }
          }
        },
        "routeCommandContains": {
          "$ref": "#/$defs/stringList"
        },
        "routeCommandNotContains": {
          "$ref": "#/$defs/stringList"
        },
        "requiresIngestPipe": {
          "type": "boolean"
        },
        "sourceLeakNotContains": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "argv": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "envName": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "coverageList": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "language-registry",
          "json-schema",
          "search-flow",
          "deps-query",
          "policy-blackbox",
          "policy-whitebox",
          "performance",
          "security",
          "codex-hooks",
          "codex-wrapper",
          "evidence-assurance",
          "desktop-hooks",
          "cli-hooks",
          "real-trigger",
          "large-library"
        ]
      }
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "jsonPathMap": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/scalar"
      }
    },
    "jsonValueMap": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/jsonValue"
      }
    },
    "jsonValue": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "integer" },
        { "type": "boolean" },
        { "type": "null" },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        }
      ]
    },
    "scalar": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "integer" },
        { "type": "boolean" },
        { "type": "null" },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scalar"
          }
        }
      ]
    }
  }
}
