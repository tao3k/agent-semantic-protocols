{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-sandtable-scenario.v1.schema.json",
  "title": "Semantic Sandtable Scenario",
  "description": "Language-neutral scenario descriptor for replaying bounded agent search flows against semantic language harness CLIs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "language", "workdir", "steps"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
    },
    "language": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "workdir": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "$ref": "#/$defs/workdir"
        }
      ]
    },
    "env": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "budgets": {
      "$ref": "#/$defs/budgets"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    }
  },
  "$defs": {
    "workdir": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "env": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$"
        },
        "relative": {
          "type": "string",
          "minLength": 1
        },
        "candidates": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "anyOf": [
        {"required": ["env"]},
        {"required": ["relative"]},
        {"required": ["candidates"]}
      ]
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxCommands": {
          "type": "integer",
          "minimum": 1
        },
        "maxTotalLinesWarn": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "command"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "command": {
          "$ref": "#/$defs/argv"
        },
        "stdin": {
          "type": "string"
        },
        "stdinCommand": {
          "$ref": "#/$defs/argv"
        },
        "stdinCommandAllowNonZero": {
          "type": "boolean"
        },
        "stdinTimeoutSeconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "timeoutSeconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "capture": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "expect": {
          "$ref": "#/$defs/expect"
        }
      }
    },
    "expect": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exitCode": {
          "type": "integer"
        },
        "lineProtocol": {
          "type": "boolean"
        },
        "stdoutContains": {
          "$ref": "#/$defs/stringList"
        },
        "stderrContains": {
          "$ref": "#/$defs/stringList"
        },
        "stdoutNotContains": {
          "$ref": "#/$defs/stringList"
        },
        "stdoutMatches": {
          "$ref": "#/$defs/stringList"
        },
        "stdoutEmpty": {
          "type": "boolean"
        },
        "stdoutJsonEquals": {
          "$ref": "#/$defs/jsonPathMap"
        },
        "stdoutJsonContains": {
          "$ref": "#/$defs/stringMap"
        },
        "maxStdoutLinesWarn": {
          "type": "integer",
          "minimum": 1
        },
        "maxStderrLinesWarn": {
          "type": "integer",
          "minimum": 1
        },
        "maxStdoutBytesWarn": {
          "type": "integer",
          "minimum": 1
        },
        "maxElapsedMsWarn": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "argv": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "jsonPathMap": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/scalar"
      }
    },
    "scalar": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "integer" },
        { "type": "boolean" },
        { "type": "null" }
      ]
    }
  }
}
