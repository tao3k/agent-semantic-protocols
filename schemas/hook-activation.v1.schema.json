{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tao3k.github.io/agent-semantic-protocols/schemas/hook-activation.v1.schema.json",
  "title": "ASP Hook Activation v3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "schemaAuthority",
    "protocolId",
    "protocolVersion",
    "projectRoot",
    "generatedBy",
    "providers"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.hook.activation"
    },
    "schemaVersion": {
      "const": "1"
    },
    "schemaAuthority": {
      "type": "string",
      "const": "https://tao3k.github.io/agent-semantic-protocols/schemas/"
    },
    "protocolId": {
      "type": "string",
      "minLength": 1
    },
    "protocolVersion": {
      "type": "string",
      "minLength": 1
    },
    "projectRoot": {
      "type": "string",
      "minLength": 1
    },
    "generatedBy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime",
        "version"
      ],
      "properties": {
        "runtime": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "generatedAt": {
      "type": "string"
    },
    "providers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/activatedProviderConfig"
      }
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "activatedProviderConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifestId",
        "manifestDigest",
        "languageId",
        "providerId",
        "binary",
        "executionCommandDigest",
        "searchCapabilities",
        "queryPackDescriptor",
        "semanticRegistryDigest",
        "routes",
        "coverage"
      ],
      "properties": {
        "manifestId": {
          "type": "string",
          "minLength": 1
        },
        "manifestDigest": {
          "type": "string",
          "minLength": 1
        },
        "languageId": {
          "type": "string",
          "minLength": 1
        },
        "providerId": {
          "type": "string",
          "minLength": 1
        },
        "binary": {
          "type": "string",
          "minLength": 1
        },
        "execution": {
          "$ref": "https://tao3k.github.io/agent-semantic-protocols/schemas/provider-manifest.v1.schema.json#/$defs/providerExecution"
        },
        "providerCommandPrefix": {
          "$ref": "#/$defs/stringArray"
        },
        "executionCommandDigest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "searchCapabilities": {
          "$ref": "https://tao3k.github.io/agent-semantic-protocols/schemas/provider-manifest.v1.schema.json#/$defs/providerSearchCapabilities"
        },
        "semanticFactsDescriptor": {
          "$ref": "https://tao3k.github.io/agent-semantic-protocols/schemas/provider-manifest.v1.schema.json#/$defs/providerSemanticFactsDescriptor"
        },
        "queryPackDescriptor": {
          "$ref": "https://tao3k.github.io/agent-semantic-protocols/schemas/provider-query-pack-descriptor.v1.schema.json"
        },
        "semanticRegistryDigest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "routes": {
          "$ref": "#/$defs/hookRoutes"
        },
        "coverage": {
          "$ref": "#/$defs/activationCoverage"
        }
      }
    },
    "activationCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packageRoots",
        "sourceRoots",
        "configFiles",
        "sourceExtensions",
        "ignoredPathPrefixes"
      ],
      "properties": {
        "packageRoots": {
          "$ref": "#/$defs/stringArray"
        },
        "sourceRoots": {
          "$ref": "#/$defs/stringArray"
        },
        "configFiles": {
          "$ref": "#/$defs/stringArray"
        },
        "sourceExtensions": {
          "$ref": "#/$defs/stringArray"
        },
        "ignoredPathPrefixes": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "hookRoutes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prime",
        "owner",
        "lexical",
        "ingest",
        "checkChanged"
      ],
      "properties": {
        "prime": {
          "$ref": "#/$defs/commandTemplate"
        },
        "owner": {
          "$ref": "#/$defs/commandTemplate"
        },
        "lexical": {
          "$ref": "#/$defs/commandTemplate"
        },
        "query": {
          "$ref": "#/$defs/commandTemplate"
        },
        "ingest": {
          "$ref": "#/$defs/commandTemplate"
        },
        "checkChanged": {
          "$ref": "#/$defs/commandTemplate"
        },
        "dependencyTopology": {
          "$ref": "#/$defs/commandTemplate"
        },
        "dependencyTopologyMetadata": {
          "$ref": "#/$defs/commandTemplate"
        },
        "workspaceScope": {
          "$ref": "#/$defs/commandTemplate"
        },
        "exportIndex": {
          "$ref": "#/$defs/commandTemplate"
        },
        "guide": {
          "$ref": "#/$defs/commandTemplate"
        }
      }
    },
    "commandTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "argv"
      ],
      "properties": {
        "argv": {
          "$ref": "#/$defs/stringArray"
        },
        "stdinMode": {
          "enum": [
            "none",
            "pipe-candidates",
            "pipe-diff",
            "unknown"
          ]
        }
      }
    }
  }
}
