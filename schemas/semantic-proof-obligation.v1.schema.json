{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-proof-obligation.v1.schema.json",
  "title": "Semantic Proof Obligation v1",
  "description": "A selector/topology-scoped invariant that may require formal verification before a branch can be marked legal or illegal.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "obligationId",
    "project",
    "kind",
    "status",
    "claim",
    "topology",
    "branchEffects"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-proof-obligation"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.formal-verification"
    },
    "protocolVersion": {
      "const": "1"
    },
    "obligationId": {
      "$ref": "#/$defs/id"
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "enum": ["architecture-invariant", "schema-invariant", "state-transition", "renderer-contract", "custom"]
    },
    "status": {
      "enum": ["open", "verified", "disproved", "stale", "blocked"]
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    },
    "claim": {
      "$ref": "#/$defs/claim"
    },
    "topology": {
      "$ref": "#/$defs/topology"
    },
    "branchEffects": {
      "$ref": "#/$defs/branchEffects"
    },
    "fields": {
      "$ref": "#/$defs/fields"
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.:-]*$"
    },
    "scalar": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "integer" },
        { "type": "boolean" },
        {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "integer" },
              { "type": "boolean" }
            ]
          }
        }
      ]
    },
    "fields": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/scalar"
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "why", "mustHoldAt"],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "why": {
          "type": "string",
          "minLength": 1
        },
        "mustHoldAt": {
          "type": "string",
          "minLength": 1
        },
        "mustNotBeMovedTo": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "topology": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sliceId", "ownerSelectors"],
      "properties": {
        "sliceId": {
          "$ref": "#/$defs/id"
        },
        "ownerSelectors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "hotEdges": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "branchEffects": {
      "type": "object",
      "additionalProperties": false,
      "required": ["illegalBranches", "legalBranches"],
      "properties": {
        "illegalBranches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/branch"
          }
        },
        "legalBranches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/branch"
          }
        }
      }
    },
    "branch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["branchId", "reason"],
      "properties": {
        "branchId": {
          "$ref": "#/$defs/id"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
