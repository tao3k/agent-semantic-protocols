{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-proof-receipt.v1.schema.json",
  "title": "Semantic Proof Receipt v1",
  "description": "Compact formal-verification receipt that can update DynamicTopology branch legality without exposing full proof text to the agent.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "receiptId",
    "obligationId",
    "recipeId",
    "checker",
    "environment",
    "okay",
    "trustLevel",
    "failedDeclarations",
    "formalStatementDigest",
    "candidateDigest",
    "timings",
    "schemaProjection",
    "packetProjection",
    "validatedClaims",
    "defensiveEngineeringAssessment",
    "branchLegalityUpdate",
    "summaryForAgent"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-proof-receipt"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.formal-verification"
    },
    "protocolVersion": {
      "const": "1"
    },
    "receiptId": {
      "$ref": "#/$defs/id"
    },
    "obligationId": {
      "$ref": "#/$defs/id"
    },
    "recipeId": {
      "$ref": "#/$defs/id"
    },
    "checker": {
      "enum": ["axle.verify_proof", "axle.check", "lean", "custom"]
    },
    "environment": {
      "type": "string",
      "minLength": 1
    },
    "okay": {
      "type": "boolean"
    },
    "trustLevel": {
      "enum": ["compile", "axiom-audited", "verify-proof", "external-checker", "untrusted"]
    },
    "failedDeclarations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "formalStatementDigest": {
      "$ref": "#/$defs/digest"
    },
    "candidateDigest": {
      "$ref": "#/$defs/digest"
    },
    "timings": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "schemaProjection": {
      "$ref": "#/$defs/schemaProjection"
    },
    "packetProjection": {
      "$ref": "#/$defs/packetProjection"
    },
    "validatedClaims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/validatedClaim"
      }
    },
    "defensiveEngineeringAssessment": {
      "$ref": "#/$defs/defensiveEngineeringAssessment"
    },
    "branchLegalityUpdate": {
      "$ref": "#/$defs/branchLegalityUpdate"
    },
    "summaryForAgent": {
      "type": "string",
      "minLength": 1
    },
    "fields": {
      "$ref": "#/$defs/fields"
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.:-]*$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "scalar": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "integer" },
        { "type": "boolean" },
        {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "integer" },
              { "type": "boolean" }
            ]
          }
        }
      ]
    },
    "fields": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/scalar"
      }
    },
    "validatedClaim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "verified", "meaning", "theorem"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "verified": {
          "type": "boolean"
        },
        "meaning": {
          "type": "string",
          "minLength": 1
        },
        "theorem": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "defensiveEngineeringAssessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result", "blockedBranch", "whyBlocked", "correctBoundary", "replacementBranches"],
      "properties": {
        "result": {
          "enum": ["blocked", "allowed", "unproven"]
        },
        "blockedBranch": {
          "$ref": "#/$defs/id"
        },
        "whyBlocked": {
          "type": "string",
          "minLength": 1
        },
        "correctBoundary": {
          "type": "string",
          "minLength": 1
        },
        "replacementBranches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        }
      }
    },
    "branchLegalityUpdate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["illegal", "legal"],
      "properties": {
        "illegal": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "legal": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        }
      }
    },
    "schemaProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceSchema", "facts", "formalLeanPath", "candidateLeanPath"],
      "properties": {
        "sourceSchema": {
          "type": "string",
          "minLength": 1
        },
        "formalLeanPath": {
          "type": "string",
          "minLength": 1
        },
        "candidateLeanPath": {
          "type": "string",
          "minLength": 1
        },
        "facts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/schemaProjectionFact"
          }
        }
      }
    },
    "schemaProjectionFact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "owner", "field", "role"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "field": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "enum": ["executable-selector", "display-only"]
        }
      }
    },
    "packetProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceKind",
        "sourcePacket",
        "facts",
        "formalLeanPath",
        "candidateLeanPath",
        "identityKind",
        "contractValid"
      ],
      "properties": {
        "sourceKind": {
          "enum": ["contract-fixture", "provider-output"]
        },
        "sourcePacket": {
          "type": "string",
          "minLength": 1
        },
        "formalLeanPath": {
          "type": "string",
          "minLength": 1
        },
        "candidateLeanPath": {
          "type": "string",
          "minLength": 1
        },
        "identityKind": {
          "enum": ["selector-owned", "path-line-only", "missing"]
        },
        "contractValid": {
          "type": "boolean"
        },
        "facts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/packetProjectionFact"
          }
        }
      }
    },
    "packetProjectionFact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "role", "value", "meaning"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "enum": [
            "executable-selector",
            "display-only",
            "identity-kind",
            "contract-valid"
          ]
        },
        "value": {
          "type": "string",
          "minLength": 1
        },
        "meaning": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
