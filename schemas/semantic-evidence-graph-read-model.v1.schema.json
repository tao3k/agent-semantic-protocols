{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-evidence-graph-read-model.v1.schema.json",
  "title": "Semantic EvidenceGraph Read Model",
  "description": "DB-owned read-model projection over stable source and structural index facts. Node identifiers are generation/selector/entity based; display line ranges are not executable identity.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "generationId",
    "projectRoot",
    "nodes",
    "edges"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.evidence-graph-read-model"
    },
    "schemaVersion": {
      "const": "1"
    },
    "generationId": {
      "type": "string",
      "minLength": 1
    },
    "projectRoot": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "label",
        "path",
        "selector",
        "queryKeys",
        "languageId",
        "providerId"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": ":[0-9]+:[0-9]+$"
          }
        },
        "kind": {
          "enum": [
            "source-owner",
            "structural-owner",
            "selector",
            "symbol",
            "dependency-usage"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        },
        "selector": {
          "type": [
            "string",
            "null"
          ]
        },
        "queryKeys": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "languageId": {
          "type": [
            "string",
            "null"
          ]
        },
        "providerId": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "to",
        "kind"
      ],
      "properties": {
        "from": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": [
            "contains-selector",
            "defines-symbol",
            "uses-dependency"
          ]
        }
      }
    }
  }
}
