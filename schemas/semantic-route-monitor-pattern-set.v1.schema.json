{
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-route-monitor-pattern-set.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ASP route monitor pattern set",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "monitorPatternSetVersion",
    "patterns"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-route-monitor-pattern-set"
    },
    "schemaVersion": {
      "const": "1"
    },
    "monitorPatternSetVersion": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "patterns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/monitorPattern"
      }
    }
  },
  "$defs": {
    "monitorPattern": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "riskKind",
        "feedbackReason",
        "severity",
        "trigger",
        "description",
        "addedFrom",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]*$"
        },
        "riskKind": {
          "$ref": "semantic-route-verification-trace.v1.schema.json#/$defs/riskKind"
        },
        "feedbackReason": {
          "$ref": "semantic-route-verification-trace.v1.schema.json#/$defs/feedbackReason"
        },
        "severity": {
          "enum": [
            "info",
            "warning",
            "error"
          ]
        },
        "trigger": {
          "$ref": "#/$defs/monitorTrigger"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "addedFrom": {
          "enum": [
            "sandtable",
            "live-agent",
            "user-feedback",
            "agentic-reviewer"
          ]
        },
        "status": {
          "enum": [
            "active",
            "retired"
          ]
        },
        "evidenceRefs": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "monitorTrigger": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "routes": {
          "type": "array",
          "items": {
            "$ref": "semantic-route-verification-trace.v1.schema.json#/$defs/routeId"
          },
          "uniqueItems": true
        },
        "evidenceAnchors": {
          "type": "array",
          "items": {
            "$ref": "semantic-route-verification-trace.v1.schema.json#/$defs/evidenceAnchor"
          },
          "uniqueItems": true
        },
        "minimumOccurrences": {
          "type": "integer",
          "minimum": 1
        },
        "selectorShape": {
          "enum": [
            "path-line-range",
            "structural-selector",
            "unknown"
          ]
        },
        "selectorPosition": {
          "enum": [
            "display-hint",
            "executable",
            "hidden"
          ]
        },
        "requiresVerificationEvidence": {
          "type": "boolean"
        },
        "minimumExecutedRoutes": {
          "type": "integer",
          "minimum": 0
        },
        "outputShape": {
          "enum": [
            "owner-topology-only-graph",
            "unknown"
          ]
        },
        "redundantFields": {
          "type": "array",
          "items": {
            "enum": [
              "rank",
              "frontier",
              "rankedEvidence",
              "evidenceFrontier"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
