{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-artifact-edge.v1.schema.json",
  "title": "ASP Merkle artifact edge v1",
  "description": "Queryable edge between two artifact roots in the Merkle artifact forest.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "edgeHash",
    "role",
    "ordinal",
    "parent",
    "child"
  ],
  "properties": {
    "schemaId": {
      "const": "semantic-artifact-edge"
    },
    "schemaVersion": {
      "const": "1"
    },
    "edgeHash": {
      "$ref": "#/$defs/artifactHash"
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "ordinal": {
      "type": "integer",
      "minimum": 0
    },
    "parent": {
      "$ref": "#/$defs/artifactRootRef"
    },
    "child": {
      "$ref": "#/$defs/artifactRootRef"
    }
  },
  "$defs": {
    "artifactHash": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "value"
      ],
      "properties": {
        "algorithm": {
          "const": "blake3"
        },
        "value": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "artifactRootRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repoId",
        "workspaceId",
        "scopeId",
        "generation",
        "rootKind",
        "rootHash",
        "nodeHash"
      ],
      "properties": {
        "repoId": {
          "type": "string",
          "minLength": 1
        },
        "workspaceId": {
          "type": "string",
          "minLength": 1
        },
        "scopeId": {
          "type": "string",
          "minLength": 1
        },
        "generation": {
          "type": "string",
          "minLength": 1
        },
        "rootKind": {
          "enum": [
            "artifactExport",
            "changeSet",
            "compactGraph",
            "dynamicOverlay",
            "eventLogCheckpoint",
            "evidenceGraph",
            "graphDiff",
            "howFixFrame",
            "howFromFrame",
            "proofReceipt",
            "providerOutput",
            "searchReceipt",
            "sourceIndexBundle",
            "sourceSnapshot"
          ]
        },
        "rootHash": {
          "$ref": "#/$defs/artifactHash"
        },
        "nodeHash": {
          "$ref": "#/$defs/artifactHash"
        },
        "producerHash": {
          "$ref": "#/$defs/artifactHash"
        },
        "schemaHash": {
          "$ref": "#/$defs/artifactHash"
        },
        "contentHash": {
          "$ref": "#/$defs/artifactHash"
        }
      }
    }
  }
}
