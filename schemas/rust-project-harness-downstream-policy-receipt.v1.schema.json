{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.dev/schemas/rust-project-harness-downstream-policy-receipt.v1.schema.json",
  "title": "Rust Project Harness Downstream Policy Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "gate_label",
    "package",
    "source_snapshot",
    "policy_digest",
    "execution_command_digest",
    "cache_payload_digest",
    "dependency_baseline_packages",
    "active_verification_task_count",
    "performance_task_count",
    "stability_task_count",
    "performance_report_obligation",
    "stability_report_obligation",
    "report_obligations"
  ],
  "properties": {
    "schema_id": {
      "const": "rust-lang-project-harness.downstream-policy-receipt"
    },
    "schema_version": {
      "const": "1"
    },
    "gate_label": {
      "type": "string",
      "minLength": 1
    },
    "package": {
      "$ref": "#/$defs/package"
    },
    "source_snapshot": {
      "$ref": "#/$defs/sourceSnapshot"
    },
    "policy_digest": {
      "$ref": "#/$defs/contentDigest"
    },
    "execution_command_digest": {
      "$ref": "#/$defs/contentDigest"
    },
    "cache_payload_digest": {
      "$ref": "#/$defs/contentDigest"
    },
    "dependency_baseline_packages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dependencyBaselinePackage"
      }
    },
    "active_verification_task_count": {
      "type": "integer",
      "minimum": 0
    },
    "performance_task_count": {
      "type": "integer",
      "minimum": 0
    },
    "stability_task_count": {
      "type": "integer",
      "minimum": 0
    },
    "performance_report_obligation": {
      "type": "boolean"
    },
    "stability_report_obligation": {
      "type": "boolean"
    },
    "report_obligations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reportObligation"
      }
    }
  },
  "$defs": {
    "contentDigest": {
      "type": "string",
      "pattern": "^blake3:[0-9a-f]{64}$"
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "directory"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "directory": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "sourceSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "digest",
        "file_count",
        "byte_count"
      ],
      "properties": {
        "digest": {
          "$ref": "#/$defs/contentDigest"
        },
        "file_count": {
          "type": "integer",
          "minimum": 0
        },
        "byte_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "dependencyBaselinePackage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "source_contains"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "source_contains": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "reportObligation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "renderer",
        "suggested_artifact_name",
        "reason",
        "task_kinds",
        "task_fingerprints"
      ],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "renderer": {
          "type": "string",
          "minLength": 1
        },
        "suggested_artifact_name": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "task_kinds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "task_fingerprints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    }
  }
}
