{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-performance-gate.v1.schema.json",
  "title": "Semantic Performance Gate v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "scenarioId",
    "languageId",
    "phase",
    "gateClass",
    "command",
    "expected",
    "observed",
    "verdict"
  ],
  "properties": {
    "schemaId": {
      "const": "semantic-performance-gate.v1"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.performance-gate"
    },
    "protocolVersion": {
      "const": "1"
    },
    "scenarioId": {
      "type": "string",
      "minLength": 1
    },
    "languageId": {
      "type": "string",
      "minLength": 1
    },
    "workspace": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "enum": [
        "cold-path",
        "warm-path",
        "hot-path",
        "dynamic-overlay",
        "source-index"
      ]
    },
    "gateClass": {
      "enum": [
        "functionality",
        "latency",
        "regression",
        "contract"
      ]
    },
    "command": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expected": {
      "$ref": "#/$defs/expectation"
    },
    "observed": {
      "$ref": "#/$defs/observation"
    },
    "verdict": {
      "enum": [
        "pass",
        "fail",
        "skip",
        "unknown"
      ]
    },
    "whereFrameId": {
      "type": "string",
      "minLength": 1
    },
    "howFrameId": {
      "type": "string",
      "minLength": 1
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "positiveMilliseconds": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "routeName": {
      "type": "string",
      "minLength": 1
    },
    "expectation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targetTotalMs"
      ],
      "properties": {
        "targetTotalMs": {
          "$ref": "#/$defs/positiveMilliseconds"
        },
        "maxTotalMs": {
          "$ref": "#/$defs/positiveMilliseconds"
        },
        "maxStartupMs": {
          "$ref": "#/$defs/positiveMilliseconds"
        },
        "maxProviderSpawnCount": {
          "type": "integer",
          "minimum": 0
        },
        "maxHarnessParseCount": {
          "type": "integer",
          "minimum": 0
        },
        "maxStdoutBytes": {
          "type": "integer",
          "minimum": 0
        },
        "requireExitCode": {
          "type": "integer",
          "minimum": 0
        },
        "requireColdCache": {
          "type": "boolean"
        },
        "requireSourceIndexHit": {
          "type": "boolean"
        },
        "requireOverlayHit": {
          "type": "boolean"
        },
        "requireNoExecutableLineRange": {
          "type": "boolean"
        },
        "requiredRoutes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/routeName"
          }
        },
        "forbiddenRoutes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/routeName"
          }
        }
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exitCode",
        "elapsedMs",
        "elapsedSeconds",
        "providerSpawnCount"
      ],
      "properties": {
        "exitCode": {
          "type": "integer",
          "minimum": 0
        },
        "elapsedMs": {
          "type": "number",
          "minimum": 0
        },
        "elapsedSeconds": {
          "type": "number",
          "minimum": 0
        },
        "providerSpawnCount": {
          "type": "integer",
          "minimum": 0
        },
        "harnessParseCount": {
          "type": "integer",
          "minimum": 0
        },
        "stdoutBytes": {
          "type": "integer",
          "minimum": 0
        },
        "cacheState": {
          "enum": [
            "cold",
            "warm",
            "hot",
            "overlay",
            "unknown"
          ]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "firstRoute": {
          "$ref": "#/$defs/routeName"
        },
        "executedRoutes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/routeName"
          }
        },
        "sourceIndexHit": {
          "type": "boolean"
        },
        "overlayHit": {
          "type": "boolean"
        },
        "executableLineRangeSelectorCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
