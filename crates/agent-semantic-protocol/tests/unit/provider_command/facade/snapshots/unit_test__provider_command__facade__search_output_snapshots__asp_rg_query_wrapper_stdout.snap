---
source: crates/agent-semantic-protocol/tests/unit/provider_command/facade/search_output_snapshots.rs
expression: normalize_search_output(&stdout)
---
[search-rg] view=seeds querySet=6 source=query-overlay ranker=graph-turbo:owner-query
query=Fiber|Queue + stale|refresh|turso|cache
queryPack=clauses=2 quality=high reason=ok
queryClauses=C1='Fiber|Queue';C2='stale|refresh|turso|cache'
terms=fiber,queue,stale,refresh,turso,cache
scopeQuality=high
clauseCoverage=C1 matched=fiber,queue missing=-
clauseCoverage=C2 matched=stale,refresh,turso,cache missing=-
packageCohesion=high packages=effect.ts
sourceTrace=query-overlay:used[collectMs=<ms>;elapsedMs=<ms>;qualityMs=<ms>]
nextCommand=asp fd -query 'Fiber|Queue|stale|refresh|turso|cache' --workspace src
nextClasses=owner-items,query-selector,fd-query
avoid=repeat-rg,manual-window-scan,raw-read
