      "expectedGoldSelectors": [
        "python://Lib/asyncio/taskgroups.py#item/class/TaskGroup",
        "python://Lib/asyncio/taskgroups.py#item/function/TaskGroup.create_task",
        "python://Lib/asyncio/tasks.py#item/function/create_task"
      ],
      "metrics": {
        "commandBudgetMax": 6,
        "firstRouteIsPrime": false,
        "unnecessaryPrimeCount": 0,
        "fullFileReadCount": 0,
        "lineRangeExecutableSelectorCount": 0,
        "ownerSkeletonCountMin": 1,
        "syntaxFactQueryCountMin": 1,
        "capsuleProjectionCountMin": 1
      },
      "simulatedPacket": {
        "evidenceState": "known-owner+symbol",
        "routeGraph": [
          {
            "route": "owner-skeleton",
            "reason": "asyncio owners and symbols are already known"
          },
          {
            "route": "flow-capsule",
            "reason": "cancellation behavior needs compact async control-flow facts"
          }
        ],
        "actionFrontier": [
          "owner-skeleton:Lib/asyncio/taskgroups.py",
          "symbol-skeleton:TaskGroup.create_task",
          "flow-capsule:asyncio-taskgroup-cancel"
