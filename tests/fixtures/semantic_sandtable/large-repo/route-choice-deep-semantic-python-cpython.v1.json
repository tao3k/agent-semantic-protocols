          "TaskGroup",
          "create_task",
          "CancelledError",
          "ExceptionGroup"
        ]
      },
      "routeExpectation": {
        "evidenceState": "known-owner+symbol",
        "allowedFirstRoutes": [
          "owner-skeleton",
          "symbol-skeleton",
          "flow-capsule"
