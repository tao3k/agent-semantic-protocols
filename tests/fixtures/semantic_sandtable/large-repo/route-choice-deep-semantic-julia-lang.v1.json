        "symbols": [
          "typeinf_ext",
          "abstract_call_gf_by_type",
          "InferenceState",
          "MethodMatch"
        ]
      },
      "routeExpectation": {
        "evidenceState": "known-owner+symbol",
        "allowedFirstRoutes": [
          "owner-skeleton",
          "symbol-skeleton",
          "syntax-fact-query"
        ],
        "forbiddenFirstRoutes": [
          "search-prime",
          "full-file-read",
          "direct-source-read"
        ],
        "requiredRejectedRoutes": [
          "search-prime",
          "full-file-read",
          "line-selector-code"
        ],
        "recommendedNext": "owner-skeleton",
