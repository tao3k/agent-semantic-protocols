{
  "schemaVersion": "1",
  "id": "route-choice-deep-semantic-julia-lang",
  "title": "Large-repo route choice fixture for JuliaLang/julia",
  "purpose": "Validate that Julia search reasoning starts from known owner and symbol evidence, not prime or executable line selectors.",
