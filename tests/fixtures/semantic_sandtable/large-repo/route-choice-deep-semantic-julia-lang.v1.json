      "requiredFacts": [
        "typeInferenceEntrypoint",
        "abstractCallDispatch",
        "inferenceStateMutation",
        "methodMatchResolution"
      ],
      "expectedGoldSelectors": [
        "julia://base/compiler/typeinfer.jl#item/function/typeinf_ext",
        "julia://base/compiler/abstractinterpretation.jl#item/function/abstract_call_gf_by_type",
        "julia://base/compiler/inferenceresult.jl#item/struct/InferenceResult"
      ],
      "metrics": {
        "commandBudgetMax": 6,
        "firstRouteIsPrime": false,
        "unnecessaryPrimeCount": 0,
        "fullFileReadCount": 0,
        "lineRangeExecutableSelectorCount": 0,
        "ownerSkeletonCountMin": 1,
        "syntaxFactQueryCountMin": 1,
        "capsuleProjectionCountMin": 1
      },
      "simulatedPacket": {
        "evidenceState": "known-owner+symbol",
        "routeGraph": [
          {
            "route": "owner-skeleton",
            "reason": "compiler owner files are already known"
          },
          {
            "route": "syntax-fact-query",
            "reason": "inference behavior needs compact call and mutation facts"
          }
        ],
        "actionFrontier": [
          "owner-skeleton:base/compiler/typeinfer.jl",
          "symbol-skeleton:typeinf_ext",
          "syntax-fact-query:abstract_call_gf_by_type InferenceState"
