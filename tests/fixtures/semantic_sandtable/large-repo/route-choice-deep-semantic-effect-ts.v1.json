            "route": "runtime-flow-capsule",
            "reason": "interrupt, async resume, and runtime flag behavior needs compact flow facts"
          }
        ],
        "actionFrontier": [
          "owner-skeleton:packages/effect/src/internal/fiberRuntime.ts",
          "class-skeleton:FiberRuntime",
          "runtime-flow-capsule:fiber-interrupt-async"
        ],
        "recommendedNext": "owner-skeleton:packages/effect/src/internal/fiberRuntime.ts",
        "avoid": [
          "search-prime",
          "full-file-read",
          "line-selector-code"
        ]
      }
    }
  ],
  "globalGates": {
    "firstRouteIsPrime": false,
    "unnecessaryPrimeCount": 0,
    "fullFileReadCount": 0,
