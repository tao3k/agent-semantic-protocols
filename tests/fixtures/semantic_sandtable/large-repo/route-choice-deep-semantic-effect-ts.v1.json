      },
      "requiredFacts": [
        "interruptSignalPath",
        "queueDrainPath",
        "evaluateEffectLoop",
        "runtimeFlagsWindDown",
        "supervisorResumeSuspend"
      ],
      "expectedGoldSelectors": [
        "ts://packages/effect/src/internal/fiberRuntime.ts#class:FiberRuntime/method:tell",
        "ts://packages/effect/src/internal/fiberRuntime.ts#class:FiberRuntime/method:processNewInterruptSignal",
        "ts://packages/effect/src/internal/fiberRuntime.ts#class:FiberRuntime/method:sendInterruptSignalToAllChildren",
        "ts://packages/effect/src/internal/fiberRuntime.ts#class:FiberRuntime/method:evaluateEffect"
      ],
      "metrics": {
        "commandBudgetMax": 6,
        "firstRouteIsPrime": false,
        "unnecessaryPrimeCount": 0,
        "fullFileReadCount": 0,
        "lineRangeExecutableSelectorCount": 0,
        "ownerSkeletonCountMin": 1,
        "syntaxFactQueryCountMin": 1,
        "runtimeFlowCapsuleCountMin": 1
      },
      "simulatedPacket": {
        "evidenceState": "known-package+owner+symbol",
        "routeGraph": [
          {
            "route": "owner-skeleton",
